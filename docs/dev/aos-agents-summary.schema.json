{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/michaelblum/agent-os/docs/dev/aos-agents-summary.schema.json",
  "title": "AOS Agent Runtime Summary",
  "description": "Runtime summary artifact written by the AOS-owned agent runtime contract under .runtime/dev/aos-agents/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "engine",
    "role",
    "agent_spec",
    "active_profile",
    "task_hash",
    "execute",
    "max_turns",
    "base_commit",
    "target_branch",
    "output_dir",
    "summary_path"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "status": { "enum": ["ready", "completed", "blocked", "error"] },
    "engine": { "enum": ["native-codex", "provider-sdk"] },
    "role": { "enum": ["explorer", "reviewer", "validator", "historian", "implementer"] },
    "agent_spec": {
      "type": "string",
      "pattern": "^\\.codex/agents/(explorer|reviewer|validator|historian|implementer)\\.toml$"
    },
    "active_profile": { "type": "string", "minLength": 1 },
    "task_hash": { "type": "string", "pattern": "^[a-f0-9]{12}$" },
    "execute": { "type": "boolean" },
    "max_turns": { "type": "integer", "minimum": 1 },
    "base_commit": { "type": "string", "minLength": 1 },
    "target_branch": { "type": "string", "minLength": 1 },
    "output_dir": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/(explorer|reviewer|validator|historian|implementer)/[^/]+$"
    },
    "summary_path": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/(explorer|reviewer|validator|historian|implementer)/[^/]+/summary\\.json$"
    },
    "result_path": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/(explorer|reviewer|validator|historian|implementer)/[^/]+/result\\.json$"
    },
    "patch_path": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/implementer/[^/]+/patch\\.diff$"
    },
    "touched_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "context_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "suggested_review_command": {
      "type": "string",
      "pattern": "^git apply --check /.*/\\.runtime/dev/aos-agents/runs/implementer/[^/]+/patch\\.diff$"
    },
    "suggested_apply_command": {
      "type": "string",
      "pattern": "^git apply /.*/\\.runtime/dev/aos-agents/runs/implementer/[^/]+/patch\\.diff$"
    },
    "error": { "type": "string", "minLength": 1 },
    "native_spawn_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": ["tool", "tool_contract", "arguments", "provider_side_checkout_mutation"],
      "properties": {
        "tool": { "const": "spawn_agent" },
        "tool_contract": { "const": "multi_agent_v2" },
        "blocked_if_only_multi_agent_v1": { "type": "boolean" },
        "provider_side_checkout_mutation": { "const": false },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_name", "agent_type", "fork_turns", "message"],
          "properties": {
            "task_name": {
              "type": "string",
              "pattern": "^(explorer|reviewer|validator|historian|implementer)-[a-f0-9]{12}$"
            },
            "agent_type": { "enum": ["explorer", "reviewer", "validator", "historian", "implementer"] },
            "fork_turns": { "const": "none" },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "native_dispatch_path": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/(explorer|reviewer|validator|historian|implementer)/[^/]+/native-dispatch\\.json$"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "ready" } }, "required": ["status"] },
      "then": {
        "properties": { "execute": { "const": false } },
        "not": {
          "anyOf": [
            { "required": ["result_path"] },
            { "required": ["patch_path"] },
            { "required": ["error"] }
          ]
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
      "then": {
        "properties": { "execute": { "const": true } },
        "required": ["result_path"],
        "not": { "required": ["error"] }
      }
    },
    {
      "if": { "properties": { "status": { "const": "error" } }, "required": ["status"] },
      "then": {
        "properties": { "execute": { "const": true } },
        "required": ["error"],
        "not": { "required": ["patch_path"] }
      }
    },
    {
      "if": { "properties": { "status": { "const": "blocked" } }, "required": ["status"] },
      "then": {
        "properties": { "execute": { "const": true } },
        "required": ["error"],
        "not": {
          "anyOf": [
            { "required": ["result_path"] },
            { "required": ["patch_path"] }
          ]
        }
      }
    },
    {
      "if": { "properties": { "engine": { "const": "native-codex" } }, "required": ["engine"] },
      "then": { "required": ["native_spawn_contract", "native_dispatch_path"] }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "completed" },
          "role": { "const": "implementer" }
        },
        "required": ["status", "role"]
      },
      "then": {
        "required": [
          "patch_path",
          "touched_paths",
          "suggested_review_command",
          "suggested_apply_command"
        ]
      }
    }
  ]
}
