{
  "$schema": "../../shared/schemas/dev-workflow-rules.schema.json",
  "schema_version": 1,
  "summary": "Repo development workflow routing rules for changed files.",
  "rules": [
    {
      "id": "app-subtree-local-contract",
      "summary": "App subtree changes delegate app-specific workflow details to the nearest local contract.",
      "patterns": [
        "apps/**"
      ],
      "classes": [
        "app",
        "local_contract"
      ],
      "actions": [
        "read_local_contract"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [],
      "verification": [],
      "notes": [
        "Repo-wide routing should not encode app-specific behavior; read the nearest subtree AGENTS.md or local playbook before choosing app tests."
      ]
    },
    {
      "id": "swift-core",
      "summary": "Unified aos binary or Swift IPC sources changed.",
      "patterns": [
        "src/**/*.swift",
        "shared/swift/ipc/**/*.swift"
      ],
      "classes": [
        "swift",
        "aos_binary"
      ],
      "actions": [
        "swift_build"
      ],
      "hot_swappable": false,
      "tcc_identity_sensitive": true,
      "commands": [
        {
          "id": "dev-build",
          "command": "node scripts/aos-dev-build.mjs build --no-restart --json",
          "reason": "Swift source changes require a current repo-mode ./aos binary. The repo-local build wrapper preserves the signing/TCC warning surface."
        }
      ],
      "verification": [
        {
          "id": "ready",
          "command": "./aos ready --post-permission",
          "reason": "After a real rebuild and user TCC reset/regrant, verify the rebuilt binary and managed daemon still agree on repo-mode readiness."
        }
      ],
      "notes": [
        "If the repo-local ./aos binary is missing or exits 137, recover with `bash build.sh --force --no-restart` because the normal post-build verification cannot run through a broken ./aos artifact.",
        "Repo-mode rebuilds must stay raw: direct build.sh swiftc output only, no post-build codesign, explicit signing identifier, entitlements, app bundle, allowlist assumption, or spctl launch gate."
      ]
    },
    {
      "id": "repo-build-tooling",
      "summary": "Repo-mode build wrapper, signing, or rebuild alert behavior changed.",
      "patterns": [
        "build.sh",
        "scripts/aos-dev-build.mjs",
        "tests/build-rebuild-policy.sh"
      ],
      "classes": [
        "build_tooling",
        "aos_binary"
      ],
      "actions": [
        "focused_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "build-rebuild-policy-test",
          "command": "bash tests/build-rebuild-policy.sh",
          "reason": "Verify content-based rebuilds, no repo-mode post-signing, and rebuild alert/TCC handoff behavior."
        }
      ],
      "verification": [],
      "notes": [
        "The raw recovery command for a missing or launch-killed repo ./aos is `bash build.sh --force --no-restart`; do not repair by adding post-build codesign or an spctl acceptance gate.",
        "spctl rejection is expected for the repo-local raw binary shape; launchability of ./aos is the operational gate."
      ]
    },
    {
      "id": "root-skill-packages",
      "summary": "Root skill package instructions or registry-backed skill contracts changed.",
      "patterns": [
        "skills/**",
        "scripts/aos-skills*.mjs",
        "tests/aos-skills-*.test.mjs"
      ],
      "classes": [
        "skills"
      ],
      "actions": [
        "skill_validation"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "skills-validate",
          "command": "node scripts/aos-skills-validate.mjs --json",
          "reason": "Validate root skill package metadata, body budgets, durable backing, and install target support."
        },
        {
          "id": "skills-registry-test",
          "command": "node --test tests/aos-skills-registry.test.mjs",
          "reason": "Verify root skill registry coverage and split-skill contracts."
        }
      ],
      "verification": []
    },
    {
      "id": "toolkit-components",
      "summary": "Reusable toolkit component or runtime browser code changed.",
      "patterns": [
        "packages/toolkit/components/**",
        "packages/toolkit/panel/**",
        "packages/toolkit/runtime/**",
        "packages/toolkit/package.json",
        "packages/toolkit/package-lock.json"
      ],
      "classes": [
        "toolkit",
        "web_surface"
      ],
      "actions": [
        "component_reload",
        "focused_toolkit_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [],
      "verification": [
        {
          "id": "toolkit-test",
          "command": "node --test tests/toolkit/*.test.mjs",
          "reason": "Use focused toolkit/runtime tests for pure browser-surface changes."
        },
        {
          "id": "show-wait",
          "command": "./aos show wait --id <canvas-id> --json --timeout 15s",
          "reason": "When manually verifying a canvas-backed component, use diagnostic JSON waits so timeout failures include runtime verdict detail."
        }
      ]
    },
    {
      "id": "browser-intent-sensor",
      "summary": "Browser intent sensor or JS adapter path changed.",
      "patterns": [
        "packages/toolkit/browser-intent-sensor/**"
      ],
      "classes": [
        "toolkit",
        "browser_intent_sensor"
      ],
      "actions": [
        "focused_js_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "browser-intent-test",
          "command": "node --test packages/toolkit/browser-intent-sensor",
          "reason": "Browser intent sensor changes stay in the JavaScript test loop unless an adapter contract changes."
        }
      ],
      "verification": []
    },
    {
      "id": "schemas",
      "summary": "Shared schema contracts changed.",
      "patterns": [
        "shared/schemas/**",
        "scripts/generate-input-event-validator.mjs"
      ],
      "classes": [
        "schema"
      ],
      "actions": [
        "schema_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "schema-tests",
          "command": "node --test tests/schemas/*.test.mjs",
          "reason": "Schema changes should run schema validation tests without daemon restart."
        }
      ],
      "verification": []
    },
    {
      "id": "command-surface-manifests",
      "summary": "Command metadata or external command manifest changed.",
      "patterns": [
        "manifests/commands/*.json",
        "manifests/commands/source/**",
        "scripts/generate-command-manifests.mjs",
        "shared/schemas/aos-external-command-manifest-v0.schema.json",
        "tests/schemas/aos-external-command-manifest-v0.test.mjs",
        "tests/command-manifest-generation.sh",
        "tests/aos-dev-gh-help-parity.test.mjs",
        "tests/external-command-dispatch.sh",
        "tests/help-contract.sh"
      ],
      "classes": [
        "command_contract",
        "schema"
      ],
      "actions": [
        "schema_test",
        "help_contract",
        "focused_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "command-manifest-generation",
          "command": "bash tests/command-manifest-generation.sh",
          "reason": "Source command manifests and generated command artifacts must stay in sync."
        },
        {
          "id": "external-command-manifest-schema",
          "command": "node --test tests/schemas/aos-external-command-manifest-v0.test.mjs",
          "reason": "External command manifest changes must preserve launcher schema, script targets, and help-manifest route coverage."
        },
        {
          "id": "external-command-dispatch",
          "command": "bash tests/external-command-dispatch.sh",
          "reason": "Manifest-backed command routes must still dispatch through external modules."
        },
        {
          "id": "dev-gh-help-parity",
          "command": "node --test tests/aos-dev-gh-help-parity.test.mjs",
          "reason": "Repo-local GitHub helper subcommands must stay dispatchable through direct script help."
        },
        {
          "id": "help-contract",
          "command": "bash tests/help-contract.sh",
          "reason": "Command metadata and manifests must stay aligned with discoverable help and parser contracts."
        }
      ],
      "verification": []
    },
    {
      "id": "command-surface-implementations",
      "summary": "Hot-swappable external command implementation changed.",
      "patterns": [
        "scripts/aos-*.mjs",
        "scripts/aos-*",
        "scripts/sign-aos-runtime",
        "packages/cli/**",
        "packages/gateway/dist/doctor-cli.js"
      ],
      "classes": [
        "command_contract",
        "command_implementation"
      ],
      "actions": [
        "focused_test",
        "help_contract"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "external-command-dispatch",
          "command": "bash tests/external-command-dispatch.sh",
          "reason": "External command implementation changes must keep manifest dispatch and wrapper integration intact."
        },
        {
          "id": "external-parser-flags",
          "command": "bash tests/external-parser-flags.sh",
          "reason": "External command wrappers should reject malformed flags and arguments before falling through to Swift primitives."
        },
        {
          "id": "dev-gh-help-parity",
          "command": "node --test tests/aos-dev-gh-help-parity.test.mjs",
          "reason": "Repo-local GitHub helper subcommands must stay dispatchable through direct script help."
        },
        {
          "id": "help-contract",
          "command": "bash tests/help-contract.sh",
          "reason": "Command implementation changes must stay aligned with discoverable help and parser contracts."
        }
      ],
      "verification": []
    },
    {
      "id": "dev-gh-helper",
      "summary": "Repo-local GitHub helper implementation or contract changed.",
      "patterns": [
        "scripts/aos-dev-gh.mjs",
        "scripts/aos-dev-gh-spec.mjs",
        "tests/aos-dev-gh-contract.test.mjs",
        "tests/aos-dev-gh-help-parity.test.mjs"
      ],
      "classes": [
        "command_contract",
        "dev_workflow"
      ],
      "actions": [
        "focused_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "dev-gh-contract",
          "command": "node --test tests/aos-dev-gh-contract.test.mjs",
          "reason": "Verify the repo-local GitHub helper wraps only the sanctioned non-interactive gh subset."
        },
        {
          "id": "dev-gh-help-parity",
          "command": "node --test tests/aos-dev-gh-help-parity.test.mjs",
          "reason": "Verify the repo-local GitHub helper allowlist and direct script help stay aligned."
        }
      ],
      "verification": []
    },
    {
      "id": "dev-workflow-manifest",
      "summary": "Developer workflow router manifest or tests changed.",
      "patterns": [
        "docs/dev/workflow-rules.json",
        "docs/dev/agent-capabilities.json",
        "docs/dev/active-profile.json",
        "docs/dev/test-proof-registry.json",
        "docs/dev/test-proof-registry.d/**",
        "docs/dev/workflow-profiles.json",
        "docs/dev/workflow-profiles/**",
        "scripts/aos-dev-workflow.mjs",
        "scripts/aos-dev-situation.mjs",
        "scripts/aos-dev-drift-lint.mjs",
        "scripts/lib/dev-test-proof-registry.mjs",
        "shared/schemas/dev-test-proof-registry.schema.json",
        "shared/schemas/fixtures/dev-test-proof-registry/**",
        "shared/schemas/dev-workflow-rules.schema.json",
        "shared/schemas/fixtures/dev-workflow-rules/**",
        "shared/schemas/dev-active-profile.schema.json",
        "shared/schemas/dev-workflow-profiles.md",
        "shared/schemas/dev-workflow-profiles.schema.json",
        "shared/schemas/fixtures/dev-workflow-profiles/**",
        "tests/dev-workflow-router.sh",
        "tests/dev-audit.sh",
        "tests/dev-situation.sh",
        "tests/dev-drift-lint.sh",
        "tests/schemas/dev-test-proof-registry.test.mjs",
        "tests/schemas/dev-workflow-rules.test.mjs",
        "tests/schemas/dev-active-profile.test.mjs",
        "tests/schemas/dev-workflow-profiles.test.mjs"
      ],
      "classes": [
        "dev_workflow",
        "schema"
      ],
      "actions": [
        "schema_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "dev-test-proof-registry-schema-test",
          "command": "node --test tests/schemas/dev-test-proof-registry.test.mjs",
          "reason": "Validate the proof-worth registry, fixtures, and focused evaluator behavior."
        },
        {
          "id": "dev-workflow-schema-test",
          "command": "node --test tests/schemas/dev-workflow-rules.test.mjs",
          "reason": "Validate the router manifest and fixtures against the schema."
        },
        {
          "id": "dev-active-profile-schema-test",
          "command": "node --test tests/schemas/dev-active-profile.test.mjs",
          "reason": "Validate the active development integration profile selector and its referenced profile."
        },
        {
          "id": "dev-workflow-profile-schema-test",
          "command": "node --test tests/schemas/dev-workflow-profiles.test.mjs",
          "reason": "Validate the workflow profiles manifest and fixtures against the schema."
        },
        {
          "id": "dev-workflow-router-test",
          "command": "bash tests/dev-workflow-router.sh",
          "reason": "Verify the maintainer workflow parser, proof-worth ratchet, and manifest-backed recommendations agree."
        },
        {
          "id": "dev-audit-test",
          "command": "bash tests/dev-audit.sh",
          "reason": "Verify the maintainer workflow audit reports evidence-backed pass and fail claims."
        },
        {
          "id": "dev-situation-test",
          "command": "bash tests/dev-situation.sh",
          "reason": "Verify live orientation packets preserve per-source status, source traces, and no-synthesis partial failures."
        },
        {
          "id": "dev-drift-lint-test",
          "command": "bash tests/dev-drift-lint.sh",
          "reason": "Verify the heuristic durable-status tripwire distinguishes historical blocks from unmarked standing claims."
        }
      ],
      "verification": []
    },
    {
      "id": "agent-capability-manifest",
      "summary": "Agent capability manifest schema, canonical manifest, or tests changed.",
      "patterns": [
        "docs/dev/agent-capabilities.json",
        "shared/schemas/aos-agent-capability-manifest-v0.md",
        "shared/schemas/aos-agent-capability-manifest-v0.schema.json",
        "shared/schemas/fixtures/aos-agent-capability-manifest-v0/**",
        "tests/schemas/aos-agent-capability-manifest-v0.test.mjs"
      ],
      "classes": [
        "capability_manifest",
        "schema"
      ],
      "actions": [
        "schema_test",
        "focused_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "agent-capability-schema-test",
          "command": "node --test tests/schemas/aos-agent-capability-manifest-v0.test.mjs",
          "reason": "Validate the capability manifest schema, canonical manifest, and fixtures."
        }
      ],
      "verification": []
    },
    {
      "id": "package-gateway",
      "summary": "Gateway package TypeScript changed.",
      "patterns": [
        "packages/gateway/**"
      ],
      "classes": [
        "package",
        "gateway"
      ],
      "actions": [
        "package_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "gateway-test",
          "command": "cd packages/gateway && npm test",
          "reason": "Gateway changes stay in the package-local TypeScript test loop."
        }
      ],
      "verification": []
    },
    {
      "id": "package-host",
      "summary": "Host package TypeScript changed.",
      "patterns": [
        "packages/host/**"
      ],
      "classes": [
        "package",
        "host"
      ],
      "actions": [
        "package_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "host-test",
          "command": "cd packages/host && npm test",
          "reason": "Host changes stay in the package-local TypeScript test loop."
        }
      ],
      "verification": []
    },
    {
      "id": "command-contract-docs",
      "summary": "CLI/API contract documentation changed.",
      "patterns": [
        "docs/api/**/*.md",
        "docs/api/*.md"
      ],
      "classes": [
        "docs",
        "command_contract"
      ],
      "actions": [
        "help_contract"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "help-contract",
          "command": "bash tests/help-contract.sh",
          "reason": "Public CLI docs must stay aligned with discoverable help and parser contracts."
        }
      ],
      "verification": []
    },
    {
      "id": "docs-only",
      "summary": "Docs, plans, or recipes changed.",
      "patterns": [
        "AGENTS.md",
        "CLAUDE.md",
        "**/AGENTS.md",
        "**/CLAUDE.md",
        "docs/**/*.md",
        "recipes/**",
        "README.md"
      ],
      "classes": [
        "docs"
      ],
      "actions": [
        "docs_review"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [],
      "verification": [],
      "notes": [
        "Docs-only changes do not require runtime verification unless they change command contracts or executable examples.",
        "For docs that route runtime, canvas, input, status-item, lifecycle, visual, supervised, or cross-layer testing decisions, link to the foundational harness ladder in tests/README.md and docs/guides/test-harness-ladder-and-prep.md."
      ]
    },
    {
      "id": "visual-harness-primitives",
      "summary": "Visual harness primitives or app-specific visual harness compositions changed.",
      "patterns": [
        "tests/lib/visual-harness.sh",
        "tests/lib/sigil/visual-harness.sh",
        "tests/lib/sigil/radial-menu.sh",
        "tests/visual-harness-*.sh"
      ],
      "classes": [
        "tests",
        "visual_harness"
      ],
      "actions": [
        "focused_test",
        "harness_boundary"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [
        {
          "id": "visual-harness-boundary",
          "command": "bash tests/visual-harness-boundary.sh",
          "reason": "Prove generic visual primitives and app-specific visual compositions stay separated."
        },
        {
          "id": "visual-harness-canonical-url",
          "command": "bash tests/visual-harness-canonical-url-primitives.sh",
          "reason": "Prove canonical aos:// URL generation and resolved URL equivalence stay deterministic."
        },
        {
          "id": "visual-harness-content-preflight",
          "command": "bash tests/visual-harness-content-preflight.sh",
          "reason": "Prove stale live content-root detection remains deterministic."
        },
        {
          "id": "harness-composability-contracts",
          "command": "bash tests/harness-composability-contracts.sh",
          "reason": "Prove shared harness guards fail fast and release cleanly."
        }
      ],
      "verification": [],
      "notes": [
        "Run this battery before adding inference-heavy visual or live checks for harness primitive changes."
      ]
    },
    {
      "id": "tests",
      "summary": "Test harnesses or scenarios changed.",
      "patterns": [
        "tests/**"
      ],
      "classes": [
        "tests"
      ],
      "actions": [
        "focused_test"
      ],
      "hot_swappable": true,
      "tcc_identity_sensitive": false,
      "commands": [],
      "verification": [
        {
          "id": "focused-test",
          "command": "bash <changed-test>",
          "reason": "Run the changed shell scenario or the smallest adjacent test set."
        }
      ],
      "notes": [
        "Use the foundational harness ladder in tests/README.md and docs/guides/test-harness-ladder-and-prep.md before adding runtime, canvas, input, status-item, lifecycle, visual, supervised, or cross-layer test helpers."
      ]
    }
  ],
  "fallback": {
    "id": "unclassified",
    "summary": "No workflow rule matched the changed path.",
    "patterns": [],
    "classes": [
      "unclassified"
    ],
    "actions": [
      "inspect_manually"
    ],
    "hot_swappable": true,
    "tcc_identity_sensitive": false,
    "commands": [],
    "verification": [],
    "notes": [
      "No manifest rule matched this path; inspect the nearest AGENTS.md or CLAUDE.md before choosing a verification loop."
    ]
  }
}
