{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/michaelblum/agent-os/docs/dev/aos-agents-native-dispatch.schema.json",
  "title": "AOS Agent Native Dispatch Artifact",
  "description": "Native Codex dispatch packet written under .runtime/dev/aos-agents/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "engine",
    "role",
    "task_hash",
    "base_commit",
    "target_branch",
    "output_dir",
    "summary_path",
    "native_dispatch_path",
    "native_spawn_contract",
    "patch_output",
    "provider_side_checkout_mutation",
    "completion_command"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "status": { "enum": ["ready", "blocked"] },
    "engine": { "const": "native-codex" },
    "role": { "enum": ["explorer", "reviewer", "validator", "historian", "implementer"] },
    "task_hash": { "type": "string", "pattern": "^[a-f0-9]{12}$" },
    "base_commit": { "type": "string", "minLength": 1 },
    "target_branch": { "type": "string", "minLength": 1 },
    "output_dir": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/(explorer|reviewer|validator|historian|implementer)/[^/]+$"
    },
    "summary_path": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/(explorer|reviewer|validator|historian|implementer)/[^/]+/summary\\.json$"
    },
    "native_dispatch_path": {
      "type": "string",
      "pattern": "^/.*/\\.runtime/dev/aos-agents/runs/(explorer|reviewer|validator|historian|implementer)/[^/]+/native-dispatch\\.json$"
    },
    "native_spawn_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": ["tool", "tool_contract", "arguments", "provider_side_checkout_mutation"],
      "properties": {
        "tool": { "const": "spawn_agent" },
        "tool_contract": { "const": "multi_agent_v2" },
        "blocked_if_only_multi_agent_v1": { "type": "boolean" },
        "provider_side_checkout_mutation": { "const": false },
        "arguments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["task_name", "agent_type", "fork_turns", "message"],
          "properties": {
            "task_name": {
              "type": "string",
              "pattern": "^(explorer|reviewer|validator|historian|implementer)-[a-f0-9]{12}$"
            },
            "agent_type": { "enum": ["explorer", "reviewer", "validator", "historian", "implementer"] },
            "fork_turns": { "const": "none" },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "patch_output": { "type": "boolean" },
    "context_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "provider_side_checkout_mutation": { "const": false },
    "completion_command": { "type": "string", "pattern": "^\\./aos dev agents --complete-native-run " },
    "error": { "type": "string", "minLength": 1 }
  }
}
