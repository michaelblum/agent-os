{
  "canonical_docs": [
    "AGENTS.md",
    "docs/SESSION_CONTRACT.md",
    "ARCHITECTURE.md"
  ],
  "startup_surfaces": [
    ".agents/hooks/session-common.sh",
    ".agents/hooks/session-start.sh",
    ".agents/hooks/check-messages.sh",
    ".agents/hooks/session-stop.sh",
    ".agents/hooks/final-response.sh",
    ".claude/settings.json",
    ".codex/hooks.json",
    ".codex/config.toml",
    "scripts/claude-agent-os",
    "claude-aos"
  ],
  "bootstrap_surfaces": [
    "scripts/handoff",
    "scripts/parallel-codex"
  ],
  "bootstrap_storage": {
    "payload_dir_function": "aos_session_bootstrap_dir",
    "payload_file_function": "aos_session_bootstrap_payload_file",
    "launcher_file_function": "aos_session_bootstrap_launcher_file"
  },
  "non_canonical_surfaces": [
    "provider-local memory files",
    "runtime-specific startup personas",
    ".claude/settings.local.json",
    ".claude/launch.json",
    "historical docs/superpowers archaeology that contradicts the session contract"
  ],
  "memory_promotion_rule": "If durable knowledge is discovered in provider-local memory, promote it into repo-native docs or issues instead of relying on hidden recall.",
  "unavoidable_global_state": [
    "~/.claude plugin cache and install metadata",
    "~/.codex project trust state",
    "user-global PATH and shell environment"
  ]
}
