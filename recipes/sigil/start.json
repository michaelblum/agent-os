{
  "id": "sigil/start",
  "version": 1,
  "summary": "Activate the Sigil AOS experience layer.",
  "scope": "source",
  "mutates": true,
  "requires": ["content", "service", "show"],
  "docs": "apps/sigil/AGENTS.md",
  "owned_resources": [
    {
      "name": "experience",
      "type": "config",
      "id": "sigil"
    }
  ],
  "steps": [
    {
      "id": "activate-sigil-experience",
      "kind": "aos_command",
      "command": {
        "path": ["experience", "activate"],
        "form_id": "activate-experience"
      },
      "argv": ["sigil"],
      "timeout_ms": 45000,
      "mutates": true
    }
  ]
}
