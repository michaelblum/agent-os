{
  "id": "sigil/start-agent-terminal",
  "version": 1,
  "summary": "Launch the Sigil Agent Terminal through the generic app launcher.",
  "scope": "source",
  "mutates": true,
  "requires": ["content", "show"],
  "docs": "apps/sigil/AGENTS.md",
  "owned_resources": [
    {
      "name": "avatar",
      "type": "surface",
      "id": "avatar-main"
    },
    {
      "name": "terminal",
      "type": "surface",
      "id": "sigil-agent-terminal"
    },
    {
      "name": "bridge",
      "type": "process",
      "id": "sigil-agent-bridge-17761"
    }
  ],
  "steps": [
    {
      "id": "launch-agent-terminal",
      "kind": "aos_command",
      "command": {
        "path": ["launch"],
        "form_id": "launch-app"
      },
      "argv": ["sigil", "agent-terminal"],
      "timeout_ms": 45000,
      "mutates": true
    },
    {
      "id": "verify-surfaces",
      "kind": "shell",
      "shell": {
        "script": "scripts/recipes-sigil-verify-surfaces.sh",
        "cwd": "."
      },
      "argv": ["avatar-main", "sigil-agent-terminal"],
      "timeout_ms": 15000,
      "mutates": false,
      "assertions": [
        {
          "path": ["status"],
          "equals": "success"
        }
      ]
    }
  ]
}
