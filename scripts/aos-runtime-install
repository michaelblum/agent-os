#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JSON=false

unknown_arg() {
  local arg="$1"
  local kind="argument"
  local code="UNKNOWN_ARG"
  if [[ "$arg" == --* ]]; then
    kind="flag"
    code="UNKNOWN_FLAG"
  fi
  python3 - <<'PY' "$code" "Unknown ${kind}: ${arg}. Usage: aos runtime install [--json]"
import json
import sys

print(json.dumps({"code": sys.argv[1], "error": sys.argv[2]}, separators=(",", ":")), file=sys.stderr)
PY
  exit 1
}

for arg in "$@"; do
  case "$arg" in
    --json) JSON=true ;;
    *) unknown_arg "$arg" ;;
  esac
done

bash "$SCRIPT_DIR/install-aos-runtime"

if [[ "$JSON" == true ]]; then
  bash "$SCRIPT_DIR/aos-runtime-status" --json
fi
