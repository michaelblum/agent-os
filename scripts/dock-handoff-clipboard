#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/dock-handoff-clipboard --target-dock <dock>

Reads a handoff message from stdin, validates it against the target dock's
inbound message contract, applies contract compatibility cleanup, then delegates
clipboard and chat output to scripts/agent-handoff:

  Recipient: <dock>
  ----- BEGIN HANDOFF -----
  <clipboard payload>
  ----- END HANDOFF -----

  (copied to clipboard)
  Fri May 8 6:47AM

Rules:
  - Handoff payloads are copied as plain instructions.
  - The recipient line is printed only; it is not copied.
  - Accidental provider entry prefixes are removed only when declared by the
    target dock inbound contract.
  - Forbidden prompt shapes are rejected before clipboard mutation.
  - The parenthetical and timestamp are printed only; they are not copied.

Environment:
  AOS_HANDOFF_PBCOPY       Override pbcopy command path for tests.
  AOS_HANDOFF_TIMESTAMP    Override printed timestamp for tests.
EOF
}

target_dock=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --target-dock)
      target_dock="${2:-}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "FAIL: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$target_dock" ]]; then
  echo "FAIL: --target-dock is required" >&2
  usage >&2
  exit 2
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
message="$(cat || true)"
if ! contract_json="$(printf '%s' "$message" | "$script_dir/dock-inbound-message-contract" --target-dock "$target_dock" --provider codex --json 2>&1)"; then
  echo "$contract_json" >&2
  exit 1
fi
payload="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["clipboard_payload"], end="")' <<<"$contract_json")"
options_json="$(python3 - "$target_dock" <<'PY'
import json
import sys

print(json.dumps({
    "recipient": sys.argv[1],
    "timestamp": True,
    "gateStringStart": "----- BEGIN HANDOFF -----",
    "gateStringEnd": "----- END HANDOFF -----",
    "addPostInstructions": "(copied to clipboard)",
    "addHRTimestamp": True,
}))
PY
)"
"$script_dir/agent-handoff" --text "$payload" --options-json "$options_json"
