#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/dock-handoff-clipboard --target-dock <dock>

Reads a handoff message from stdin, applies dock compatibility cleanup, then
delegates clipboard and chat output to scripts/agent-handoff:

  Recipient: <dock>
  ----- BEGIN HANDOFF -----
  <clipboard payload>
  ----- END HANDOFF -----

  (copied to clipboard)
  Fri May 8 6:47AM

Rules:
  - Handoff payloads are copied as plain instructions.
  - The recipient line is printed only; it is not copied.
  - One accidental legacy command prefix is removed for every target dock.
  - The parenthetical and timestamp are printed only; they are not copied.

Environment:
  AOS_HANDOFF_PBCOPY       Override pbcopy command path for tests.
  AOS_HANDOFF_TIMESTAMP    Override printed timestamp for tests.
EOF
}

target_dock=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --target-dock)
      target_dock="${2:-}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "FAIL: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$target_dock" ]]; then
  echo "FAIL: --target-dock is required" >&2
  usage >&2
  exit 2
fi

message="$(cat || true)"
payload="$message"
legacy_command_name="goal"
legacy_command_prefix="/${legacy_command_name} "

if [[ "$payload" == "$legacy_command_prefix"* ]]; then
  payload="${payload:${#legacy_command_prefix}}"
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
options_json="$(python3 - "$target_dock" <<'PY'
import json
import sys

print(json.dumps({
    "recipient": sys.argv[1],
    "timestamp": True,
    "gateStringStart": "----- BEGIN HANDOFF -----",
    "gateStringEnd": "----- END HANDOFF -----",
    "addPostInstructions": "(copied to clipboard)",
    "addHRTimestamp": True,
}))
PY
)"
"$script_dir/agent-handoff" --text "$payload" --options-json "$options_json"
