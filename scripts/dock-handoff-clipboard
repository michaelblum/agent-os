#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/dock-handoff-clipboard --target-dock <dock>

Retired surface. The .docks runtime files and Foreman/GDI/Operator dock handoff
workflow are no longer active AOS surfaces. This command fails closed before
clipboard mutation.

Environment:
  AOS_HANDOFF_PBCOPY       Ignored by the retired surface; retained for tests.
  AOS_HANDOFF_TIMESTAMP    Ignored by the retired surface; retained for tests.
EOF
}

retired() {
  cat >&2 <<'EOF'
FAIL: scripts/dock-handoff-clipboard is retired after .docks removal.
Dock handoff clipboard routing is no longer an active AOS workflow surface.
No clipboard mutation was attempted.
EOF
}

target_dock=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --target-dock)
      target_dock="${2:-}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "FAIL: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$target_dock" ]]; then
  echo "FAIL: --target-dock is required" >&2
  usage >&2
  exit 2
fi

retired
exit 1
