#!/usr/bin/env python3
"""Generate the packaged source-backed ops recipe index."""

import json
import pathlib
import sys


def iter_recipe_files(repo_root: pathlib.Path):
    roots = [
        ("repo", "repo", repo_root / "recipes"),
        ("toolkit", "packages/toolkit", repo_root / "packages" / "toolkit" / "recipes"),
    ]
    apps_root = repo_root / "apps"
    if apps_root.exists():
        for app_dir in sorted(p for p in apps_root.iterdir() if p.is_dir()):
            roots.append(("app", f"apps/{app_dir.name}", app_dir / "recipes"))

    for source_kind, owner, root in roots:
        if not root.exists():
            continue
        for path in sorted(root.rglob("*.json")):
            yield source_kind, owner, path


def main(argv):
    if len(argv) != 3:
        print("Usage: generate-ops-recipe-index <repo-root> <out-path>", file=sys.stderr)
        return 2

    repo_root = pathlib.Path(argv[1]).resolve()
    out_path = pathlib.Path(argv[2])
    recipes = []
    seen = {}

    for source_kind, owner, path in iter_recipe_files(repo_root):
        with path.open("r", encoding="utf-8") as handle:
            manifest = json.load(handle)
        recipe_id = manifest.get("id")
        if not recipe_id:
            raise SystemExit(f"recipe missing id: {path}")
        if recipe_id in seen:
            raise SystemExit(f"duplicate recipe id {recipe_id}: {seen[recipe_id]} and {path}")
        seen[recipe_id] = str(path.relative_to(repo_root))
        recipes.append({
            "id": recipe_id,
            "version": manifest.get("version"),
            "summary": manifest.get("summary", ""),
            "owner": owner,
            "path": str(path.relative_to(repo_root)),
            "source_kind": source_kind,
            "manifest": manifest,
        })

    out = {
        "schema": "aos-ops-recipe-index",
        "version": 1,
        "recipes": recipes,
    }
    out_path.parent.mkdir(parents=True, exist_ok=True)
    with out_path.open("w", encoding="utf-8") as handle:
        json.dump(out, handle, indent=2, sort_keys=True)
        handle.write("\n")


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
