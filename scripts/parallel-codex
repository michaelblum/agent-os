#!/bin/bash
# scripts/parallel-codex — prepare two clipboard-first Codex session launchers.
#
# Usage:
#   scripts/parallel-codex
#   scripts/parallel-codex --copy wiki
#   scripts/parallel-codex --display-name display-focus --wiki-name wiki-focus
#
# What it does:
#   1. Writes paired launcher scripts under the runtime coordination bootstrap dir
#   2. Embeds each session brief directly in its launcher prompt
#   3. Each launcher primes the clipboard with the other launch command
#   4. Copies the requested first launch command to the clipboard

set -euo pipefail

ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel 2>/dev/null || pwd)"
# shellcheck source=/dev/null
source "$ROOT/.agents/hooks/session-common.sh"

COPY_ROLE="display"
DISPLAY_NAME="display-worker"
WIKI_NAME="wiki-worker"
DISPLAY_TASK="Continue display, toolkit, canvas, and visual verification work in agent-os."
WIKI_TASK="Focus on aos wiki, content, and docs work while avoiding display interference."
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --copy)
      COPY_ROLE="${2:-}"
      shift 2
      ;;
    --display-name)
      DISPLAY_NAME="${2:-}"
      shift 2
      ;;
    --wiki-name)
      WIKI_NAME="${2:-}"
      shift 2
      ;;
    --display-task)
      DISPLAY_TASK="${2:-}"
      shift 2
      ;;
    --wiki-task)
      WIKI_TASK="${2:-}"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

if [[ "$COPY_ROLE" != "display" && "$COPY_ROLE" != "wiki" ]]; then
  echo "--copy must be 'display' or 'wiki'" >&2
  exit 1
fi

sanitize_name() {
  printf '%s' "$1" | tr -cs 'A-Za-z0-9._:-' '-'
}

copy_to_clipboard() {
  local content="$1"
  if [[ -n "${AOS_CLIPBOARD_FILE:-}" ]]; then
    printf '%s\n' "$content" > "$AOS_CLIPBOARD_FILE"
    return
  fi
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s\n' "$content" | pbcopy
    return
  fi
  echo "warning: clipboard unavailable; command was not copied" >&2
}

build_brief() {
  local role="$1"
  local task="$2"

  python3 - "$role" "$task" <<'PY'
import sys

role = sys.argv[1]
task = sys.argv[2]

if role == "display":
    brief = f"""You are the display-focused session.

Primary scope:
- {task}
- Use real aos canvases, toolkit surfaces, and visual verification when needed.

Parallel-session protocol:
- Assume another Codex session is active in parallel on wiki/content work.
- Before disruptive or aos-heavy steps, check inbound coordination messages and current sessions with ./aos tell --who when needed.
- If you need exclusive use of the extended display, send: STEER: don't use extended display until further notice
- If you need daemon maintenance, aos clean, reset-like behavior, or anything else that could disrupt the other session, stop and alert the user first. Do not proceed unilaterally.
- If aos behavior suddenly seems wrong, suspect cross-session interference first instead of repeatedly hammering the same step.

Direct messaging reminder:
- Discover the peer session id via ./aos tell --who
- Use ./aos tell --session-id <peer_session_id> "STEER: ..."
- Use ./aos tell --session-id <peer_session_id> "BLOCK UNTIL FURTHER NOTICE: ..."
- Wait for the user's CLEAR message before resuming after a block."""
elif role == "wiki":
    brief = f"""You are the wiki-focused session.

Primary scope:
- {task}
- Prefer aos wiki, docs, content structure, and non-display work.

Parallel-session protocol:
- Assume another Codex session is actively doing display/toolkit verification.
- Before disruptive or aos-heavy steps, check inbound coordination messages and current sessions with ./aos tell --who when needed.
- If you receive a steer message about the extended display, avoid using that display until a CLEAR message arrives.
- Do not restart the daemon, run aos clean, reset state, or otherwise disrupt shared aos runtime state without stopping and alerting the user first.
- If aos behavior suddenly seems wrong, suspect cross-session interference first instead of repeatedly hammering the same step.

Direct messaging reminder:
- Discover the peer session id via ./aos tell --who
- Use ./aos tell --session-id <peer_session_id> "STEER: ..."
- Use ./aos tell --session-id <peer_session_id> "BLOCK UNTIL FURTHER NOTICE: ..."
- Wait for the user's CLEAR message before resuming after a block."""
else:
    raise SystemExit(f"Unknown role: {role}")

print(brief)
PY
}

write_launcher() {
  local launcher="$1"
  local name="$2"
  local prompt="$3"
  local peer_launcher="$4"
  local role_label="$5"
  local quoted_prompt

  printf -v quoted_prompt '%q' "$prompt"

  cat > "$launcher" <<EOF
#!/bin/bash
set -euo pipefail
cd "$ROOT"
NEXT_COMMAND='bash $peer_launcher'
if [[ -n "\${AOS_CLIPBOARD_FILE:-}" ]]; then
  printf '%s\n' "\$NEXT_COMMAND" > "\$AOS_CLIPBOARD_FILE"
elif command -v pbcopy >/dev/null 2>&1; then
  printf '%s\n' "\$NEXT_COMMAND" | pbcopy
fi
echo "Launching $role_label session: $name"
echo "Clipboard primed with: \$NEXT_COMMAND"
export AOS_SESSION_NAME="$name"
rm -f -- "\$0"
PROMPT=$quoted_prompt
exec "\${AOS_CODEX_BIN:-codex}" -C "$ROOT" "\$PROMPT"
EOF
  chmod +x "$launcher"
}

DISPLAY_NAME="$(sanitize_name "$DISPLAY_NAME")"
WIKI_NAME="$(sanitize_name "$WIKI_NAME")"
BOOTSTRAP_DIR="$(aos_session_bootstrap_dir)"
aos_prune_session_bootstrap_dir
DISPLAY_BRIEF="$(build_brief "display" "$DISPLAY_TASK")"
WIKI_BRIEF="$(build_brief "wiki" "$WIKI_TASK")"
DISPLAY_LAUNCHER="$(aos_session_bootstrap_launcher_file "$DISPLAY_NAME")"
WIKI_LAUNCHER="$(aos_session_bootstrap_launcher_file "$WIKI_NAME")"

if ! $DRY_RUN; then
  write_launcher "$DISPLAY_LAUNCHER" "$DISPLAY_NAME" "$DISPLAY_BRIEF" "$WIKI_LAUNCHER" "display"
  write_launcher "$WIKI_LAUNCHER" "$WIKI_NAME" "$WIKI_BRIEF" "$DISPLAY_LAUNCHER" "wiki"
fi

FIRST_COMMAND="bash $DISPLAY_LAUNCHER"
if [[ "$COPY_ROLE" == "wiki" ]]; then
  FIRST_COMMAND="bash $WIKI_LAUNCHER"
fi

if ! $DRY_RUN; then
  copy_to_clipboard "$FIRST_COMMAND"
fi

echo "Prepared parallel Codex session launchers."
echo "  bootstrap dir:     $BOOTSTRAP_DIR"
echo "  display launcher:  $DISPLAY_LAUNCHER"
echo "  wiki launcher:     $WIKI_LAUNCHER"
echo "  clipboard:         $FIRST_COMMAND"
