#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
APP_NAME="AOS"
BUNDLE_ID="${AOS_BUNDLE_ID:-com.agent-os.aos}"
APP_VERSION="${AOS_APP_VERSION:-0.1.0}"
BUILD_VERSION="${AOS_BUILD_VERSION:-$(date +%Y.%m.%d.%H%M%S)}"
DIST_DIR="${AOS_DIST_DIR:-$REPO_ROOT/dist}"
APP_DIR="$DIST_DIR/$APP_NAME.app"
CONTENTS_DIR="$APP_DIR/Contents"
MACOS_DIR="$CONTENTS_DIR/MacOS"
RESOURCES_DIR="$CONTENTS_DIR/Resources"
EXECUTABLE_NAME="aos"
EXECUTABLE_SRC="$REPO_ROOT/aos"
EXECUTABLE_DST="$MACOS_DIR/$EXECUTABLE_NAME"
SIGIL_RESOURCE_ROOT="$RESOURCES_DIR/agent-os"
INFO_PLIST="$CONTENTS_DIR/Info.plist"
SIGN_SCRIPT="$SCRIPT_DIR/sign-aos-runtime"
SIGN_OUTPUT=""
SIGNED_IDENTITY="${AOS_SIGN_IDENTITY:-auto}"

mkdir -p "$DIST_DIR"

echo "Packaging $APP_NAME.app..."
bash "$REPO_ROOT/build.sh"

rm -rf "$APP_DIR"
mkdir -p "$MACOS_DIR" "$RESOURCES_DIR"
cp "$EXECUTABLE_SRC" "$EXECUTABLE_DST"
chmod 755 "$EXECUTABLE_DST"

mkdir -p \
  "$SIGIL_RESOURCE_ROOT/apps/sigil" \
  "$SIGIL_RESOURCE_ROOT/packages/toolkit/components"
cp "$REPO_ROOT/apps/sigil/radial-menu-config.json" "$SIGIL_RESOURCE_ROOT/apps/sigil/radial-menu-config.json"
cp "$REPO_ROOT/packages/toolkit/components/cursor-decor.html" "$SIGIL_RESOURCE_ROOT/packages/toolkit/components/cursor-decor.html"

cat >"$INFO_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key>
  <string>$APP_NAME</string>
  <key>CFBundleDisplayName</key>
  <string>$APP_NAME</string>
  <key>CFBundleIdentifier</key>
  <string>$BUNDLE_ID</string>
  <key>CFBundleVersion</key>
  <string>$BUILD_VERSION</string>
  <key>CFBundleShortVersionString</key>
  <string>$APP_VERSION</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleExecutable</key>
  <string>$EXECUTABLE_NAME</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>
  <key>LSUIElement</key>
  <true/>
  <key>NSHighResolutionCapable</key>
  <true/>
</dict>
</plist>
PLIST

SIGN_OUTPUT="$("$SIGN_SCRIPT" "$APP_DIR")"
SIGNED_IDENTITY="$(printf '%s\n' "$SIGN_OUTPUT" | awk -F': ' '/^Identity:/{print $2; exit}')"

cat <<EOF
Created: $APP_DIR
Bundle ID: $BUNDLE_ID
Executable: $EXECUTABLE_DST
Version: $APP_VERSION ($BUILD_VERSION)
Signed with: ${SIGNED_IDENTITY:-unknown}
EOF
