#!/bin/bash
# scripts/session-name — inspect or rename the current session registration.

set -euo pipefail

ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel 2>/dev/null || pwd)"
AOS="$ROOT/aos"

# shellcheck source=/dev/null
source "$ROOT/.agents/hooks/session-common.sh"

NAME=""
SESSION_ID="${AOS_SESSION_ID:-}"
HARNESS="${AOS_SESSION_HARNESS:-}"
ROLE="worker"
PRINT_ONLY=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)
      NAME="${2:-}"
      shift 2
      ;;
    --session-id)
      SESSION_ID="${2:-}"
      shift 2
      ;;
    --harness)
      HARNESS="${2:-}"
      shift 2
      ;;
    --role)
      ROLE="${2:-}"
      shift 2
      ;;
    --current|--print)
      PRINT_ONLY=true
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$SESSION_ID" ]]; then
  SESSION_ID="$(aos_resolve_session_id)"
fi
if [[ -z "$HARNESS" ]]; then
  HARNESS="$(aos_detect_harness)"
fi

CURRENT_NAME="$(aos_resolve_session_name "$SESSION_ID" "$HARNESS")"
CURRENT_CHANNEL="$(aos_session_channel "$SESSION_ID" "$CURRENT_NAME")"

if $PRINT_ONLY || [[ -z "$NAME" ]]; then
  python3 - "$SESSION_ID" "$HARNESS" "$CURRENT_NAME" "$CURRENT_CHANNEL" <<'PY'
import json, sys
print(json.dumps({
    "status": "ok",
    "session_id": sys.argv[1],
    "harness": sys.argv[2],
    "name": sys.argv[3],
    "channel": sys.argv[4],
}, sort_keys=True))
PY
  exit 0
fi

NAME="$(aos_sanitize_token "$NAME")"
if [[ -z "$SESSION_ID" ]]; then
  echo '{"code":"MISSING_SESSION_ID","error":"No stable session id found. Pass --session-id explicitly."}' >&2
  exit 1
fi

aos_write_session_name_override "$SESSION_ID" "$NAME"

if [[ -x "$AOS" ]]; then
  "$AOS" tell --register --session-id "$SESSION_ID" --name "$NAME" --role "$ROLE" --harness "$HARNESS" >/dev/null 2>&1 || true
fi

python3 - "$SESSION_ID" "$HARNESS" "$CURRENT_NAME" "$NAME" "$SESSION_ID" <<'PY'
import json, sys
print(json.dumps({
    "status": "ok",
    "session_id": sys.argv[1],
    "harness": sys.argv[2],
    "old_name": sys.argv[3],
    "name": sys.argv[4],
    "channel": sys.argv[5],
}, sort_keys=True))
PY
