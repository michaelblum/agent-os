#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BUILD_SCRIPT="${AOS_BUILD_SCRIPT:-$REPO_ROOT/build.sh}"

usage() {
  cat <<'EOF'
Usage: scripts/aos-after-build [build.sh args ...] -- <command> [args ...]

Wait for any in-flight aos rebuild, ensure the binary is current, then run the
given command. If this invocation actually rebuilds ./aos, the command must be
the exact first-launch checkpoint: ./aos help --json.

Examples:
  scripts/aos-after-build -- ./aos tell --who
  scripts/aos-after-build --no-restart -- ./aos doctor --json
EOF
}

build_args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --)
      shift
      break
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      build_args+=("$1")
      shift
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "aos-after-build requires a command after --" >&2
  usage >&2
  exit 1
fi

BUILD_OUTPUT="$(mktemp "${TMPDIR:-/tmp}/aos-after-build-output.XXXXXX")"
trap 'rm -f "$BUILD_OUTPUT"' EXIT
if [[ ${#build_args[@]} -gt 0 ]]; then
  bash "$BUILD_SCRIPT" "${build_args[@]}" | tee "$BUILD_OUTPUT"
else
  bash "$BUILD_SCRIPT" | tee "$BUILD_OUTPUT"
fi

if grep -q '^Rebuilt: ./aos\b' "$BUILD_OUTPUT"; then
  expected_aos="${AOS_PATH:-$REPO_ROOT/aos}"
  expected_aos="$(cd "$(dirname "$expected_aos")" && pwd)/$(basename "$expected_aos")"
  command_aos="$(cd "$(dirname "$1")" 2>/dev/null && pwd)/$(basename "$1")"
  if [[ $# -ne 3 || "$command_aos" != "$expected_aos" || "$2" != "help" || "$3" != "--json" ]]; then
    echo "aos-after-build stopped: a real rebuild requires '$expected_aos help --json' as the exact next command" >&2
    exit 75
  fi
fi
exec "$@"
