#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel 2>/dev/null || pwd)"
mkdir -p "$ROOT/.runtime/claude"

export CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR:-$ROOT/.runtime/claude}"
export CLAUDE_CODE_DISABLE_AUTO_MEMORY="${CLAUDE_CODE_DISABLE_AUTO_MEMORY:-1}"
export CLAUDE_CODE_DISABLE_1M_CONTEXT="${CLAUDE_CODE_DISABLE_1M_CONTEXT:-1}"

exec "${AOS_CLAUDE_CLI_BIN:-claude}" "$@"
