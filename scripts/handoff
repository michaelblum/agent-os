#!/bin/bash
# scripts/handoff — Post a structured handoff brief to the daemon-native
# coordination bus and generate a short launcher command for the next
# Claude Code session.
#
# Usage:
#   scripts/handoff --to <name> --from <name> --task "<description>"
#   scripts/handoff --to verify-lifecycle --from lifecycle-impl \
#     --task "Run Task 8: integration test" \
#     --context "See plan Task 8 for steps."
#
# What it does:
#   1. Gathers git state, daemon status, recent commits
#   2. Writes a structured handoff brief to a JSON payload
#   3. Writes a launcher script to /tmp/aos-handoff-<name>
#   4. Copies "bash /tmp/aos-handoff-<name>" to clipboard
#
# The launcher script sets AOS_SESSION_NAME and calls `claude -n "<name>"
# "Bootstrap: /tmp/aos-handoff-<name>.json"`. The session-start hook reads
# the bootstrap file automatically. The brief is also posted via `aos tell`
# by the CALLING session (both 'handoff' and named channel) for turn-hook
# detection if the target session is already running.
#
# Options:
#   --to       NAME    Next session name (required)
#   --from     NAME    Current session name (required)
#   --task     TEXT    One-line task description (required)
#   --context  TEXT    Additional context (optional)
#   --branch   NAME    Override branch detection (optional)
#   --resume          Use --resume instead of -n (optional)
#   --dry-run         Print everything but don't write or copy (optional)

set -euo pipefail
ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel 2>/dev/null || pwd)"

# --- Parse args ---
TO="" FROM="" TASK="" CONTEXT="" BRANCH="" RESUME=false DRY_RUN=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --to)       TO="$2"; shift 2 ;;
    --from)     FROM="$2"; shift 2 ;;
    --task)     TASK="$2"; shift 2 ;;
    --context)  CONTEXT="$2"; shift 2 ;;
    --branch)   BRANCH="$2"; shift 2 ;;
    --resume)   RESUME=true; shift ;;
    --dry-run)  DRY_RUN=true; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$TO" || -z "$FROM" || -z "$TASK" ]]; then
  echo "Usage: scripts/handoff --to <name> --from <name> --task \"<description>\"" >&2
  exit 1
fi

# --- Gather context ---
BRANCH="${BRANCH:-$(git -C "$ROOT" branch --show-current 2>/dev/null || echo "unknown")}"
AHEAD=$(git -C "$ROOT" rev-list --count "origin/main..HEAD" 2>/dev/null || echo "?")
DIRTY=$(git -C "$ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
LAST_COMMITS=$(git -C "$ROOT" log --oneline -5 2>/dev/null || echo "unavailable")
HEAD_SHA=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "?")

AOS="$ROOT/aos"
DAEMON_STATUS="unknown"
if [[ -x "$AOS" ]]; then
  DAEMON_STATUS=$("$AOS" doctor --json 2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    mode = d.get('identity',{}).get('mode','?')
    status = d.get('status','?')
    pid = d.get('runtime',{}).get('daemon_pid','?')
    print(f'{status} (mode={mode} pid={pid})')
except: print('unavailable')
" 2>/dev/null || echo "unavailable")
fi

# --- Build the brief ---
BRIEF="## Handoff: ${FROM} → ${TO}

**Task:** ${TASK}

### Git State
- branch: \`${BRANCH}\`
- head: \`${HEAD_SHA}\`
- ahead of origin/main: ${AHEAD}
- dirty files: ${DIRTY}

### Recent Commits
\`\`\`
${LAST_COMMITS}
\`\`\`

### AOS Runtime
${DAEMON_STATUS}"

if [[ -n "$CONTEXT" ]]; then
  BRIEF="${BRIEF}

### Additional Context
${CONTEXT}"
fi

# --- Build the bootstrap payload ---
PAYLOAD_FILE="/tmp/aos-handoff-${TO}.json"
AOS_FROM="$FROM" AOS_TO="$TO" AOS_TASK="$TASK" AOS_BRIEF="$BRIEF" AOS_PAYLOAD="$PAYLOAD_FILE" \
  python3 -c "
import json, os
payload = {
    'type': 'session_handoff',
    'from': os.environ['AOS_FROM'],
    'to': os.environ['AOS_TO'],
    'task': os.environ['AOS_TASK'],
    'brief': os.environ['AOS_BRIEF'],
}
json.dump(payload, open(os.environ['AOS_PAYLOAD'], 'w'), indent=2)
"

# --- Build the seed prompt ---
SEED="Bootstrap: /tmp/aos-handoff-${TO}.json"

# --- Build the launcher script ---
LAUNCHER="/tmp/aos-handoff-${TO}"
if $RESUME; then
  CLAUDE_FLAG="--resume"
else
  CLAUDE_FLAG="-n"
fi

# --- Output ---
if $DRY_RUN; then
  echo "=== BRIEF ==="
  echo "$BRIEF"
  echo ""
  echo "=== SEED PROMPT ==="
  echo "$SEED"
  echo ""
  echo "=== LAUNCHER ==="
  echo "AOS_SESSION_NAME=\"${TO}\" claude ${CLAUDE_FLAG} \"${TO}\" \"${SEED}\""
  echo ""
  echo "=== CLIPBOARD ==="
  echo "bash ${LAUNCHER}"
  exit 0
fi

# Write the launcher
cat > "$LAUNCHER" << LAUNCHEOF
#!/bin/bash
cd "$ROOT"
export AOS_SESSION_NAME="$TO"
exec claude ${CLAUDE_FLAG} "$TO" "$SEED"
LAUNCHEOF
chmod +x "$LAUNCHER"

# Copy short command to clipboard
echo "bash ${LAUNCHER}" | pbcopy

# --- Post to coordination channels via aos tell ---
if command -v aos >/dev/null 2>&1; then
  PAYLOAD_CONTENT=$(cat "$PAYLOAD_FILE")
  aos tell handoff "$PAYLOAD_CONTENT" --from "$FROM" 2>/dev/null || true
  aos tell "$TO" "$PAYLOAD_CONTENT" --from "$FROM" 2>/dev/null || true
  echo "  Posted to 'handoff' and '${TO}' channels via aos tell."
fi

echo "Handoff ready."
echo ""
echo "  Bootstrap payload: ${PAYLOAD_FILE}"
echo "  Launcher:        ${LAUNCHER}"
echo "  Clipboard:       bash ${LAUNCHER}"
echo ""
echo "  Channels posted via aos tell (handoff + ${TO})."
echo "  If daemon was unavailable, manually post:"
echo "    aos tell handoff \"\$(cat ${PAYLOAD_FILE})\" --from '${FROM}'"
echo "    aos tell ${TO} \"\$(cat ${PAYLOAD_FILE})\" --from '${FROM}'"
echo "  Then paste the clipboard command in a new terminal to launch."
