#!/bin/bash
# scripts/handoff — Post a structured handoff brief to the daemon-native
# coordination bus and generate a repo-scoped launcher for the next session.
#
# Usage:
#   scripts/handoff --to <name> --from <name> --task "<description>"
#   scripts/handoff --runtime codex --to verify-lifecycle --from lifecycle-impl \
#     --task "Run Task 8: integration test" \
#     --context "See plan Task 8 for steps."

set -euo pipefail

ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel 2>/dev/null || pwd)"
AOS="$ROOT/aos"
# shellcheck source=/dev/null
source "$ROOT/.agents/hooks/session-common.sh"

copy_to_clipboard() {
  local content="$1"
  if [[ -n "${AOS_CLIPBOARD_FILE:-}" ]]; then
    printf '%s\n' "$content" > "$AOS_CLIPBOARD_FILE"
    return 0
  fi
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s\n' "$content" | pbcopy
    return 0
  fi
  echo "warning: clipboard unavailable; command was not copied" >&2
  return 1
}

runtime_seed_prompt() {
  local runtime="$1"
  local session_name="$2"
  case "$runtime" in
    codex)
      printf 'Use the repo-scoped agent-os bootstrap payload for session %s and follow docs/SESSION_CONTRACT.md.\n' "$session_name"
      ;;
    claude|claude-code)
      printf 'Use the repo-scoped agent-os bootstrap payload for session %s and follow docs/SESSION_CONTRACT.md.\n' "$session_name"
      ;;
    *)
      echo "Unsupported runtime: $runtime" >&2
      return 1
      ;;
  esac
}

write_launcher() {
  local runtime="$1"
  local launcher="$2"
  local session_name="$3"
  local prompt="$4"
  local resume="$5"
  local quoted_prompt

  quoted_prompt="$(printf '%s' "$prompt" | python3 -c 'import json, sys; print(json.dumps(sys.stdin.read()))')"

  case "$runtime" in
    codex)
      cat > "$launcher" <<EOF
#!/bin/bash
set -euo pipefail
cd "$ROOT"
export AOS_SESSION_NAME="$session_name"
PROMPT=$quoted_prompt
exec "\${AOS_CODEX_BIN:-codex}" -C "$ROOT" "\$PROMPT"
EOF
      ;;
    claude|claude-code)
      local claude_flag="-n"
      if [[ "$resume" == "true" ]]; then
        claude_flag="--resume"
      fi
      cat > "$launcher" <<EOF
#!/bin/bash
set -euo pipefail
cd "$ROOT"
export AOS_SESSION_NAME="$session_name"
PROMPT=$quoted_prompt
exec "\${AOS_CLAUDE_WRAPPER_BIN:-$ROOT/scripts/claude-agent-os}" ${claude_flag} "$session_name" "\$PROMPT"
EOF
      ;;
  esac

  chmod +x "$launcher"
}

TO=""
FROM=""
TASK=""
CONTEXT=""
BRANCH=""
RESUME=false
DRY_RUN=false
RUNTIME="${AOS_SESSION_HARNESS:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --to)       TO="$2"; shift 2 ;;
    --from)     FROM="$2"; shift 2 ;;
    --task)     TASK="$2"; shift 2 ;;
    --context)  CONTEXT="$2"; shift 2 ;;
    --branch)   BRANCH="$2"; shift 2 ;;
    --runtime)  RUNTIME="$2"; shift 2 ;;
    --resume)   RESUME=true; shift ;;
    --dry-run)  DRY_RUN=true; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$TO" || -z "$FROM" || -z "$TASK" ]]; then
  echo "Usage: scripts/handoff --to <name> --from <name> --task \"<description>\"" >&2
  exit 1
fi

if [[ -z "$RUNTIME" || "$RUNTIME" == "unknown" ]]; then
  RUNTIME="$(aos_detect_harness)"
fi
if [[ "$RUNTIME" == "claude-code" ]]; then
  RUNTIME="claude"
fi
if [[ "$RUNTIME" != "codex" && "$RUNTIME" != "claude" ]]; then
  echo "Unsupported or unknown runtime '$RUNTIME'. Pass --runtime codex or --runtime claude." >&2
  exit 1
fi
if $RESUME && [[ "$RUNTIME" == "codex" ]]; then
  echo "--resume is only supported for Claude launchers in this helper" >&2
  exit 1
fi

BRANCH="${BRANCH:-$(git -C "$ROOT" branch --show-current 2>/dev/null || echo "unknown")}"
AHEAD=$(git -C "$ROOT" rev-list --count "origin/main..HEAD" 2>/dev/null || echo "?")
DIRTY=$(git -C "$ROOT" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
LAST_COMMITS=$(git -C "$ROOT" log --oneline -5 2>/dev/null || echo "unavailable")
HEAD_SHA=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "?")

DAEMON_STATUS="unknown"
if [[ -x "$AOS" ]]; then
  DAEMON_STATUS=$("$AOS" doctor --json 2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    mode = d.get('identity',{}).get('mode','?')
    status = d.get('status','?')
    pid = d.get('runtime',{}).get('daemon_pid','?')
    print(f'{status} (mode={mode} pid={pid})')
except: print('unavailable')
" 2>/dev/null || echo "unavailable")
fi

BRIEF="## Handoff: ${FROM} → ${TO}

**Task:** ${TASK}

### Git State
- branch: \`${BRANCH}\`
- head: \`${HEAD_SHA}\`
- ahead of origin/main: ${AHEAD}
- dirty files: ${DIRTY}

### Recent Commits
\`\`\`
${LAST_COMMITS}
\`\`\`

### AOS Runtime
${DAEMON_STATUS}

### Session Contract
- Canonical repo contract: \`AGENTS.md\`
- Session contract: \`docs/SESSION_CONTRACT.md\`
- Machine-readable session manifest: \`docs/session-contract.json\`"

if [[ -n "$CONTEXT" ]]; then
  BRIEF="${BRIEF}

### Additional Context
${CONTEXT}"
fi

aos_prune_session_bootstrap_dir
PAYLOAD_FILE="$(aos_session_bootstrap_payload_file "$TO")"
LAUNCHER="$(aos_session_bootstrap_launcher_file "$TO")"
PROMPT="$(runtime_seed_prompt "$RUNTIME" "$TO")"

AOS_FROM="$FROM" AOS_TO="$TO" AOS_TASK="$TASK" AOS_BRIEF="$BRIEF" AOS_PAYLOAD="$PAYLOAD_FILE" \
  python3 -c "
import json, os
payload = {
    'type': 'session_handoff',
    'from': os.environ['AOS_FROM'],
    'to': os.environ['AOS_TO'],
    'task': os.environ['AOS_TASK'],
    'brief': os.environ['AOS_BRIEF'],
}
json.dump(payload, open(os.environ['AOS_PAYLOAD'], 'w'), indent=2)
"

if $DRY_RUN; then
  echo "=== BRIEF ==="
  echo "$BRIEF"
  echo ""
  echo "=== PAYLOAD ==="
  echo "$PAYLOAD_FILE"
  echo ""
  echo "=== LAUNCHER ==="
  if [[ "$RUNTIME" == "codex" ]]; then
    echo "AOS_SESSION_NAME=\"${TO}\" codex -C \"$ROOT\" \"$PROMPT\""
  else
    FLAG="-n"
    if $RESUME; then
      FLAG="--resume"
    fi
    echo "AOS_SESSION_NAME=\"${TO}\" \"$ROOT/scripts/claude-agent-os\" ${FLAG} \"$TO\" \"$PROMPT\""
  fi
  echo ""
  echo "=== CLIPBOARD ==="
  echo "bash ${LAUNCHER}"
  exit 0
fi

write_launcher "$RUNTIME" "$LAUNCHER" "$TO" "$PROMPT" "$RESUME"

CLIPBOARD_COMMAND="bash ${LAUNCHER}"
copy_to_clipboard "$CLIPBOARD_COMMAND" || true

if [[ -x "$AOS" ]]; then
  PAYLOAD_CONTENT=$(cat "$PAYLOAD_FILE")
  "$AOS" tell handoff "$PAYLOAD_CONTENT" --from "$FROM" 2>/dev/null || true
  "$AOS" tell "$TO" "$PAYLOAD_CONTENT" --from "$FROM" 2>/dev/null || true
  echo "  Posted to 'handoff' and '${TO}' channels via $AOS."
fi

echo "Handoff ready."
echo ""
echo "  runtime:         ${RUNTIME}"
echo "  bootstrap payload: ${PAYLOAD_FILE}"
echo "  launcher:          ${LAUNCHER}"
echo "  clipboard:         ${CLIPBOARD_COMMAND}"
echo ""
echo "  Channels posted via $AOS tell (handoff + ${TO})."
echo "  Then paste the clipboard command in a new terminal to launch."
