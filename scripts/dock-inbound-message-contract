#!/usr/bin/env node
import process from 'node:process';
import { dockInboundContractsRetiredError, repoRootFromScript } from './lib/dock-inbound-message-contract.mjs';

function usageText() {
  return `Usage:
  scripts/dock-inbound-message-contract --target-dock <dock> [--provider <name>] [--payload <text>] [--json]

Refuses retired inbound dock message routing without reading .docks contracts.
Historical schema fixtures remain valid through schema tests, but this script is not an active AOS workflow surface.`;
}

function parseArgs(argv) {
  const args = {
    targetDock: '',
  };
  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === '--target-dock') {
      args.targetDock = argv[++index] ?? '';
    } else if (arg === '--provider') {
      index += 1;
    } else if (arg === '--payload') {
      index += 1;
    } else if (arg === '--json') {
      continue;
    } else if (arg === '--help' || arg === '-h') {
      process.stdout.write(`${usageText()}\n`);
      process.exit(0);
    } else {
      throw new Error(`unknown argument: ${arg}`);
    }
  }
  if (!args.targetDock) {
    throw new Error('--target-dock is required');
  }
  return args;
}

try {
  const args = parseArgs(process.argv.slice(2));
  const repoRoot = repoRootFromScript(import.meta.url);
  throw dockInboundContractsRetiredError(repoRoot, args.targetDock);
} catch (error) {
  const code = error.code ? `${error.code}: ` : '';
  process.stderr.write(`FAIL: ${code}${error.message}\n`);
  process.stderr.write(`${usageText()}\n`);
  process.exit(error.code === 'DOCK_INBOUND_CONTRACTS_RETIRED' ? 1 : 2);
}
