#!/usr/bin/env node
import fs from 'node:fs';
import process from 'node:process';
import { repoRootFromScript, validateDockInboundMessage } from './lib/dock-inbound-message-contract.mjs';

function usage() {
  console.error(`Usage:
  scripts/dock-inbound-message-contract --target-dock <dock> [--provider codex] [--payload <text>] [--json]
  printf '%s' "$payload" | scripts/dock-inbound-message-contract --target-dock foreman --json

Formats and validates a legacy inbound dock message without writing to the clipboard.
Current Foreman work should use ./aos dev agents instead of retired clipboard/goal handoff.`);
}

function parseArgs(argv) {
  const args = {
    provider: 'codex',
    json: false,
    payloadSet: false,
    payload: '',
  };
  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === '--target-dock') {
      args.targetDock = argv[++index] ?? '';
    } else if (arg === '--provider') {
      args.provider = argv[++index] ?? '';
    } else if (arg === '--payload') {
      args.payload = argv[++index] ?? '';
      args.payloadSet = true;
    } else if (arg === '--json') {
      args.json = true;
    } else if (arg === '--help' || arg === '-h') {
      usage();
      process.exit(0);
    } else {
      throw new Error(`unknown argument: ${arg}`);
    }
  }
  if (!args.targetDock) {
    throw new Error('--target-dock is required');
  }
  return args;
}

function readStdin() {
  return fs.readFileSync(0, 'utf8');
}

function validate({ repoRoot, targetDock, provider, payload }) {
  return validateDockInboundMessage({ repoRoot, targetDock, provider, payload });
}

function printText(result) {
  console.log(`ok=${result.ok}`);
  console.log(`target_dock=${result.target_dock}`);
  console.log(`provider=${result.provider}`);
  console.log(`clipboard_payload=${result.clipboard_payload}`);
  console.log(`provider_entry_prefix=${result.provider_entry_prefix}`);
  console.log(`provider_entry_preview=${result.provider_entry_preview}`);
  console.log(`context_reset_command=${result.context_reset_command}`);
  console.log(`stale_goal_recovery_command=${result.stale_goal_recovery_command ?? ''}`);
  for (const diagnostic of result.diagnostics) {
    console.log(`${diagnostic.severity}:${diagnostic.code}:${diagnostic.message}`);
  }
}

try {
  const args = parseArgs(process.argv.slice(2));
  const repoRoot = repoRootFromScript(import.meta.url);
  const payload = args.payloadSet ? args.payload : readStdin();
  const result = validate({
    repoRoot,
    targetDock: args.targetDock,
    provider: args.provider,
    payload,
  });
  if (args.json) {
    console.log(JSON.stringify(result, null, 2));
  } else {
    printText(result);
  }
  process.exit(result.ok ? 0 : 1);
} catch (error) {
  console.error(`FAIL: ${error.message}`);
  usage();
  process.exit(2);
}
