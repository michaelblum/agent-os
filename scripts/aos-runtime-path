#!/bin/bash
set -euo pipefail

TARGET_APP="${AOS_INSTALL_PATH:-$HOME/Applications/AOS.app}"
JSON=false

unknown_arg() {
  local arg="$1"
  local kind="argument"
  local code="UNKNOWN_ARG"
  if [[ "$arg" == --* ]]; then
    kind="flag"
    code="UNKNOWN_FLAG"
  fi
  python3 - <<'PY' "$code" "Unknown ${kind}: ${arg}. Usage: aos runtime path [--json]"
import json
import sys

print(json.dumps({"code": sys.argv[1], "error": sys.argv[2]}, separators=(",", ":")), file=sys.stderr)
PY
  exit 1
}

for arg in "$@"; do
  case "$arg" in
    --json) JSON=true ;;
    *) unknown_arg "$arg" ;;
  esac
done

if [[ "$JSON" == true ]]; then
  python3 - <<'PY' "$TARGET_APP"
import json
import sys

print(json.dumps({"path": sys.argv[1]}, separators=(",", ":")))
PY
else
  printf '%s\n' "$TARGET_APP"
fi
