#!/bin/bash
set -euo pipefail

cd "$(dirname "$0")/.."
REPO_ROOT="$PWD"

paths=(
  "$REPO_ROOT/aos"
  "$REPO_ROOT/dist"
  "$REPO_ROOT/apps/sigil/build"
  "$REPO_ROOT/apps/sigil/avatar-sub"
  "$REPO_ROOT/tools/dogfood/avatar-sub"
  "$REPO_ROOT/tools/dogfood/__pycache__"
)

removed_any=false
for path in "${paths[@]}"; do
  if [[ -e "$path" ]]; then
    rm -rf "$path"
    echo "removed $path"
    removed_any=true
  fi
done

if [[ "$removed_any" == false ]]; then
  echo "no known build artifacts found"
fi
