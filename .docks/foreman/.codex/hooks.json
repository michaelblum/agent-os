{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/Michael/Code/agent-os/.docks/foreman/hooks/session-start.sh",
            "statusMessage": "Binding Foreman voice",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/Michael/Code/agent-os/.docks/foreman/hooks/stop.sh",
            "statusMessage": "Speaking Foreman stop notice",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
