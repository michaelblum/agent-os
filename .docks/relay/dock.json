{
  "$schema": "../../shared/schemas/aos-dock-profile-v0.schema.json",
  "type": "aos.dock_profile",
  "schema_version": "2026-05-dock-profile-v0",
  "name": "relay",
  "role": "foreman",
  "harness": "remote-github",
  "summary": "Remote/GitHub-only Foreman adapter. Reviews GDI branches, requests local probes when needed, merges or routes correction, and maintains workstream continuity.",
  "default_entry_path": "agent_harness",
  "allowed_entry_paths": [
    "agent_harness",
    "aos_developer"
  ],
  "capability_manifest": "docs/dev/agent-capabilities.json",
  "allowed_capability_classes": [
    "read_only"
  ],
  "allowed_capabilities": [
    "dev.github.context",
    "dev.github.ci_inspect",
    "dev.github.review_comments"
  ],
  "hook_timeout_seconds": 8,
  "stop_notice": "Relay session ended.",
  "handoff": {
    "requires_goal_prefix": false
  },
  "voice": {
    "enabled": false
  }
}
