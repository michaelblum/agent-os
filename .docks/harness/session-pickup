#!/usr/bin/env node
import fs from 'node:fs';
import path from 'node:path';
import process from 'node:process';
import { spawnSync } from 'node:child_process';

const RECORD_TYPE = 'aos.dock_session_pickup';
const SCHEMA_VERSION = '2026-05-dock-session-pickup-v0';

function usage() {
  console.error(`Usage:
  .docks/harness/session-pickup --dock <dock> --provider codex --card <path> --start-ref <ref> --output-branch <branch> [--json]

Prepares a deterministic dock session work surface and emits compact JSON.`);
}

function parseArgs(argv) {
  const args = { provider: 'codex', json: false };
  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === '--dock') {
      args.dock = argv[++index] ?? '';
    } else if (arg === '--provider') {
      args.provider = argv[++index] ?? '';
    } else if (arg === '--card') {
      args.card = argv[++index] ?? '';
    } else if (arg === '--start-ref') {
      args.startRef = argv[++index] ?? '';
    } else if (arg === '--output-branch') {
      args.outputBranch = argv[++index] ?? '';
    } else if (arg === '--json') {
      args.json = true;
    } else if (arg === '--help' || arg === '-h') {
      usage();
      process.exit(0);
    } else {
      throw new Error(`unknown argument: ${arg}`);
    }
  }
  if (!args.dock) throw new Error('--dock is required');
  if (!args.card) throw new Error('--card is required');
  if (!args.startRef) throw new Error('--start-ref is required');
  if (args.provider !== 'codex') throw new Error('v0 only supports --provider codex');
  return args;
}

function run(command, args, options = {}) {
  const result = spawnSync(command, args, {
    cwd: options.cwd,
    env: options.env ?? process.env,
    encoding: 'utf8',
    input: options.input,
  });
  return {
    command: [command, ...args].join(' '),
    exit_code: result.status ?? 1,
    stdout: result.stdout ?? '',
    stderr: result.stderr ?? '',
    error: result.error ? result.error.message : null,
  };
}

function git(repoRoot, args) {
  return run('git', args, { cwd: repoRoot });
}

function trimOutput(value) {
  return value.trim();
}

function repoRoot() {
  const result = run('git', ['rev-parse', '--show-toplevel'], { cwd: process.cwd() });
  if (result.exit_code !== 0) {
    throw new Error('current directory is not inside a git repository');
  }
  const root = trimOutput(result.stdout);
  if (!fs.existsSync(path.join(root, '.docks'))) {
    throw new Error(`resolved repo root is missing .docks: ${root}`);
  }
  return root;
}

function statusSummary(repoRootValue) {
  const branchResult = git(repoRootValue, ['branch', '--show-current']);
  const headResult = git(repoRootValue, ['rev-parse', 'HEAD']);
  const porcelainResult = git(repoRootValue, ['status', '--porcelain']);
  const entries = porcelainResult.stdout.split('\n').filter(Boolean);
  return {
    branch: trimOutput(branchResult.stdout) || null,
    head: trimOutput(headResult.stdout) || null,
    status: {
      dirty: entries.length > 0,
      entries,
      count: entries.length,
    },
  };
}

function parseHeadingValue(markdown, heading) {
  const lines = markdown.split(/\r?\n/);
  const target = heading.toLowerCase();
  for (let index = 0; index < lines.length; index += 1) {
    const match = lines[index].match(/^##+\s+(.+?)\s*$/);
    if (!match || match[1].trim().toLowerCase() !== target) continue;
    for (let cursor = index + 1; cursor < lines.length; cursor += 1) {
      const line = lines[cursor].trim();
      if (line.startsWith('#')) break;
      if (!line) continue;
      return line.replace(/^`|`$/g, '');
    }
  }
  return null;
}

function parseListValue(markdown, key) {
  const escaped = key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const regex = new RegExp(`^[-*]\\s+${escaped}:\\s*(.+?)\\s*$`, 'im');
  const match = markdown.match(regex);
  return match ? match[1].replace(/^`|`$/g, '').trim() : null;
}

function parseCard(repoRootValue, cardPath) {
  const absolutePath = path.resolve(repoRootValue, cardPath);
  const exists = fs.existsSync(absolutePath);
  const card = {
    path: path.relative(repoRootValue, absolutePath),
    exists,
    title: null,
    recipient: null,
    transfer_kind: null,
    required_start_ref: null,
    expected_output_branch: null,
  };
  if (!exists) return card;
  const markdown = fs.readFileSync(absolutePath, 'utf8');
  card.title = markdown.match(/^#\s+(.+?)\s*$/m)?.[1] ?? null;
  card.recipient = parseHeadingValue(markdown, 'Recipient');
  card.transfer_kind = parseHeadingValue(markdown, 'Transfer Kind');
  card.required_start_ref = parseListValue(markdown, 'required_start_ref');
  card.expected_output_branch = parseListValue(markdown, 'expected_output_branch');
  return card;
}

function resolveStartRef(repoRootValue, input) {
  const result = git(repoRootValue, ['rev-parse', '--verify', `${input}^{commit}`]);
  if (result.exit_code !== 0) {
    return {
      input,
      resolved: false,
      sha: null,
      failure_reason: trimOutput(result.stderr) || trimOutput(result.stdout) || 'start ref did not resolve to a commit',
    };
  }
  return {
    input,
    resolved: true,
    sha: trimOutput(result.stdout),
    failure_reason: null,
  };
}

function branchExists(repoRootValue, branch) {
  return git(repoRootValue, ['show-ref', '--verify', '--quiet', `refs/heads/${branch}`]).exit_code === 0;
}

function branchHead(repoRootValue, branch) {
  const result = git(repoRootValue, ['rev-parse', '--verify', `${branch}^{commit}`]);
  return result.exit_code === 0 ? trimOutput(result.stdout) : null;
}

function prepareOutputBranch(repoRootValue, name, startSha, diagnostics) {
  if (!name) {
    return { name: null, action: 'not_requested', refused: false, current_sha: null };
  }
  if (branchExists(repoRootValue, name)) {
    const currentSha = branchHead(repoRootValue, name);
    if (currentSha === startSha) {
      const result = git(repoRootValue, ['switch', name]);
      if (result.exit_code === 0) {
        return { name, action: 'switched_existing_at_start_ref', refused: false, current_sha: currentSha };
      }
      diagnostics.push({ severity: 'error', code: 'output_branch_switch_failed', message: trimOutput(result.stderr) });
      return { name, action: 'refused', refused: true, current_sha: currentSha };
    }
    diagnostics.push({
      severity: 'error',
      code: 'output_branch_exists_at_different_sha',
      message: `output branch ${name} exists at ${currentSha}, not requested start ref ${startSha}`,
    });
    return { name, action: 'refused', refused: true, current_sha: currentSha };
  }
  const result = git(repoRootValue, ['switch', '-c', name, startSha]);
  if (result.exit_code === 0) {
    return { name, action: 'created_from_start_ref', refused: false, current_sha: startSha };
  }
  diagnostics.push({ severity: 'error', code: 'output_branch_create_failed', message: trimOutput(result.stderr) });
  return { name, action: 'refused', refused: true, current_sha: null };
}

function readiness(repoRootValue) {
  const aosBin = process.env.AOS_DOCK_PICKUP_AOS_BIN || './aos';
  const result = run(aosBin, ['ready'], { cwd: repoRootValue });
  const combined = `${result.stdout}\n${result.stderr}`;
  const tccBlocked = /Accessibility|Input Monitoring|input[- ]tap|tap=inactive|permission/i.test(combined);
  return {
    status: result.exit_code === 0 ? 'ready' : (tccBlocked ? 'human_needed' : 'blocked'),
    command: `${aosBin} ready`,
    exit_code: result.exit_code,
    stdout: trimOutput(result.stdout),
    stderr: trimOutput(result.stderr),
  };
}

function main() {
  const args = parseArgs(process.argv.slice(2));
  const root = repoRoot();
  const diagnostics = [];
  const before = statusSummary(root);
  const startRef = resolveStartRef(root, args.startRef);
  let outputBranch = {
    name: args.outputBranch || null,
    action: 'not_attempted',
    refused: false,
    current_sha: null,
  };
  let card = parseCard(root, args.card);
  let ready = {
    status: 'not_run',
    command: `${process.env.AOS_DOCK_PICKUP_AOS_BIN || './aos'} ready`,
    exit_code: null,
    stdout: '',
    stderr: '',
  };
  let nextAction = 'proceed';

  if (before.status.dirty) {
    diagnostics.push({
      severity: 'error',
      code: 'dirty_worktree',
      message: 'worktree is dirty before branch preparation; refusing to switch or reset branches',
    });
    nextAction = 'blocked';
  } else if (!startRef.resolved) {
    diagnostics.push({
      severity: 'error',
      code: 'start_ref_unresolved',
      message: startRef.failure_reason,
    });
    nextAction = 'blocked';
  } else {
    outputBranch = prepareOutputBranch(root, args.outputBranch, startRef.sha, diagnostics);
    if (outputBranch.refused) {
      nextAction = 'blocked';
    } else {
      card = parseCard(root, args.card);
      if (!card.exists) {
        diagnostics.push({
          severity: 'error',
          code: 'work_card_missing',
          message: `work card does not exist after preparing requested base: ${card.path}`,
        });
        nextAction = 'misrouted';
      } else {
        ready = readiness(root);
        if (ready.status === 'human_needed') {
          nextAction = 'human_needed';
        } else if (ready.status !== 'ready') {
          nextAction = 'blocked';
        }
      }
    }
  }

  const after = statusSummary(root);
  const stallPath = nextAction === 'human_needed'
    ? path.join('.docks', args.dock, 'scripts', 'human-needed-tcc-reset')
    : null;
  const result = {
    record_type: RECORD_TYPE,
    schema_version: SCHEMA_VERSION,
    dock: args.dock,
    provider: args.provider,
    repo_root: root,
    worktree: after,
    worktree_before: before,
    card,
    start_ref: startRef,
    output_branch: outputBranch,
    readiness: ready,
    stall_path: stallPath,
    next_action: nextAction,
    diagnostics,
  };

  console.log(JSON.stringify(result, null, 2));
  process.exit(nextAction === 'proceed' ? 0 : 1);
}

try {
  main();
} catch (error) {
  const fallback = {
    record_type: RECORD_TYPE,
    schema_version: SCHEMA_VERSION,
    dock: null,
    provider: 'codex',
    next_action: 'blocked',
    diagnostics: [{ severity: 'error', code: 'pickup_exception', message: error.message }],
  };
  console.log(JSON.stringify(fallback, null, 2));
  process.exit(2);
}
