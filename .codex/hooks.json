{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "AOS_SESSION_HARNESS=codex bash \"$(git rev-parse --show-toplevel)/.agents/hooks/session-start.sh\"",
            "statusMessage": "Loading agent-os session context",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/git-health.sh\"",
            "statusMessage": "Checking git health",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'CAVEMAN MODE ACTIVE. Rules: Drop articles/filler/pleasantries/hedging. Fragments OK. Short synonyms. Pattern: [thing] [action] [reason]. [next step]. Not: Sure! I would be happy to help you with that. Yes: Bug in auth middleware. Fix: Code/commits/security: write normal. User says stop caveman or normal mode to deactivate.'",
            "timeout": 5,
            "statusMessage": "Loading caveman mode"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AOS_SESSION_HARNESS=codex bash \"$(git rev-parse --show-toplevel)/.agents/hooks/check-messages.sh\"",
            "statusMessage": "Checking coordination messages",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/pre-tool-use.sh\"",
            "statusMessage": "Checking command policy",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
