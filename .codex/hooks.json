{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/session-start.sh\"",
            "statusMessage": "Loading agent-os session context",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/git-health.sh\"",
            "statusMessage": "Checking git health",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/pre-tool-use.sh\"",
            "statusMessage": "Checking command policy",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

