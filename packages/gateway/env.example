# Copy this file to packages/gateway/.env for local broker credentials.
# The broker will read this file automatically on startup.

AOS_SLACK_BOT_TOKEN=replace-with-bot-token
AOS_SLACK_APP_TOKEN=replace-with-socket-mode-app-token
# Optional:
# AOS_SLACK_SIGNING_SECRET=your-signing-secret
# AOS_SLACK_COMMAND=/aos
