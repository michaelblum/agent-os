#!/usr/bin/env bash
# Canned responses for aos browser-adapter tests.
# Invoked as `playwright-cli [-s=<session>] <verb> [args]`. Behavior is
# controlled by FAKE_PWCLI_VERSION and FAKE_PWCLI_MODE env vars set by each
# test.
set -uo pipefail

# Capture the session (stripped from the front) so we can reconstruct
# "fake <verb> invoked: -s=<session> <verb> <args>" for tests that assert on
# the full argv.
SESSION_ARG=""
if [[ "${1:-}" == -s=* ]]; then
    SESSION_ARG="$1"
    shift
fi
VERB="${1:-}"

case "$VERB" in
    --version)
        echo "${FAKE_PWCLI_VERSION:-0.9.9}"
        exit 0
        ;;
    attach)
        if [[ "${FAKE_PWCLI_MODE:-new}" == "old" ]]; then
            echo "Unknown command: attach" >&2
            exit 1
        fi
        # New-mode attach --help output shape used by version probe
        shift
        if [[ "${1:-}" == "--help" ]]; then
            cat <<'EOF'
Usage: playwright-cli attach [options]

Options:
  --extension       connect via browser extension
  --cdp=<target>    attach to CDP endpoint
  --help            display help
EOF
            exit 0
        fi
        echo "fake attach invoked: $*"
        exit 0
        ;;
    snapshot)
        shift
        # If --filename=/path passed, write canned markdown content so consumers
        # (seeCaptureXray) get a non-empty element list.
        for arg in "$@"; do
            case "$arg" in
                --filename=*)
                    cat > "${arg#--filename=}" <<'SNAP'
- generic [ref=e1]:
  - button "Click me" [ref=e2]
  - link "Go" [ref=e3]
SNAP
                    ;;
            esac
        done
        echo "fake snapshot invoked: $*"
        exit 0
        ;;
    screenshot)
        shift
        echo "fake screenshot invoked: $*"
        for arg in "$@"; do
            case "$arg" in
                --filename=*)
                    # PNG magic so `file` recognizes output as PNG
                    printf '\x89PNG\r\n\x1a\nfake' > "${arg#--filename=}"
                    ;;
            esac
        done
        exit 0
        ;;
    bigstdout)
        # Emit ~128 KB to stress the pipe buffer
        # (macOS pipe buffer is typically 16KB or 64KB).
        for i in $(seq 1 2048); do printf '%064d\n' "$i"; done
        exit 0
        ;;
    click|hover|drag|dblclick|mousewheel|type|press|fill|goto|open|close)
        shift
        # Simulate real playwright-cli behavior: when FAKE_PWCLI_ERROR_VERB
        # matches the current verb, emit an "### Error" marker on stdout while
        # still exiting 0. Exercises the orchestrator's requireSuccess() guard.
        if [[ "${FAKE_PWCLI_ERROR_VERB:-}" == "${VERB}" ]]; then
            echo "### Error"
            echo "${FAKE_PWCLI_ERROR_MSG:-fake ${VERB} error}"
            exit 0
        fi
        # Format the invocation two ways — a loose "fake <verb> invoked: ..."
        # that Task 9's tests grep for, and a full-argv form with the stripped
        # session prefix ("fake <verb> invoked: -s=<s> <verb> <args>") that
        # Task 10/11 tests grep for. Emit both on one line so either grep hits.
        # Collapse any double spaces when SESSION_ARG is empty.
        line="fake ${VERB} invoked: ${SESSION_ARG} ${VERB} $*"
        # Normalize multiple spaces to single spaces.
        line=$(echo "$line" | tr -s ' ')
        echo "$line"
        exit 0
        ;;
    eval)
        # Mimic real playwright-cli: wrap the value in a "### Result" envelope.
        # The canned rect serves anchor-resolver. When FAKE_PWCLI_EVAL_MODE is
        # set, produce alternative shapes for regression coverage:
        #   (default)            -> plain object, our primary decode path
        #   stringified          -> a quoted JSON string (JSON.stringify'd in JS)
        #   error                -> "### Error" marker
        case "${FAKE_PWCLI_EVAL_MODE:-object}" in
            object)
                printf '### Result\n{"x":100,"y":200,"w":300,"h":40}\n'
                ;;
            stringified)
                printf '### Result\n"{\\"x\\":100,\\"y\\":200,\\"w\\":300,\\"h\\":40}"\n'
                ;;
            error)
                printf '### Error\n%s\n' "${FAKE_PWCLI_ERROR_MSG:-blocked by browser}"
                ;;
            *)
                echo "fake shim: unknown FAKE_PWCLI_EVAL_MODE=${FAKE_PWCLI_EVAL_MODE}" >&2
                exit 2
                ;;
        esac
        exit 0
        ;;
    *)
        echo "fake-playwright-cli does not implement: $VERB" >&2
        exit 2
        ;;
esac
