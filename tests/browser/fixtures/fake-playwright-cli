#!/usr/bin/env bash
# Canned responses for aos browser-adapter tests.
# Invoked as `playwright-cli [-s=<session>] <verb> [args]`. Behavior is
# controlled by FAKE_PWCLI_VERSION and FAKE_PWCLI_MODE env vars set by each
# test.
set -uo pipefail

# Skip -s=<session> prefix if present (real playwright-cli accepts it as a
# global flag; runPlaywright always emits it).
if [[ "${1:-}" == -s=* ]]; then
    shift
fi
VERB="${1:-}"

case "$VERB" in
    --version)
        echo "${FAKE_PWCLI_VERSION:-0.9.9}"
        exit 0
        ;;
    attach)
        if [[ "${FAKE_PWCLI_MODE:-new}" == "old" ]]; then
            echo "Unknown command: attach" >&2
            exit 1
        fi
        # New-mode attach --help output shape used by version probe
        shift
        if [[ "${1:-}" == "--help" ]]; then
            cat <<'EOF'
Usage: playwright-cli attach [options]

Options:
  --extension       connect via browser extension
  --cdp=<target>    attach to CDP endpoint
  --help            display help
EOF
            exit 0
        fi
        echo "fake attach invoked: $*"
        exit 0
        ;;
    snapshot)
        shift
        echo "fake snapshot invoked: $*"
        # If --filename=/path passed, touch the file so the Swift side sees it
        for arg in "$@"; do
            case "$arg" in
                --filename=*) : > "${arg#--filename=}" ;;
            esac
        done
        exit 0
        ;;
    screenshot)
        shift
        echo "fake screenshot invoked: $*"
        for arg in "$@"; do
            case "$arg" in
                --filename=*)
                    # PNG magic so `file` recognizes output as PNG
                    printf '\x89PNG\r\n\x1a\nfake' > "${arg#--filename=}"
                    ;;
            esac
        done
        exit 0
        ;;
    bigstdout)
        # Emit ~128 KB to stress the pipe buffer
        # (macOS pipe buffer is typically 16KB or 64KB).
        for i in $(seq 1 2048); do printf '%064d\n' "$i"; done
        exit 0
        ;;
    *)
        echo "fake-playwright-cli does not implement: $VERB" >&2
        exit 2
        ;;
esac
