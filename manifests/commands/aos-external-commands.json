{
  "schema_version": 1,
  "commands": [
    {
      "path": ["dev", "afk-dry-run"],
      "summary": "Run the AFK dry-run command from the external Node prototype.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/afk-dry-run-prototype.mjs"],
      "cwd": "repo"
    },
    {
      "path": ["dev", "afk-launch-attempt"],
      "summary": "Run the AFK launch-attempt command from the external Node prototype.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/afk-launch-attempt-prototype.mjs"],
      "cwd": "repo"
    },
    {
      "path": ["dev", "afk-session-trigger"],
      "summary": "Run the AFK session-trigger command from the external Node prototype.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/afk-session-trigger-prototype.mjs"],
      "cwd": "repo"
    },
    {
      "path": ["dev", "gh"],
      "summary": "Run GitHub workflow helpers through the external dev gh command.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/aos-dev-gh.mjs"],
      "cwd": "repo",
      "env": {
        "REPO_ROOT": "$REPO_ROOT"
      }
    },
    {
      "path": ["runtime", "install"],
      "summary": "Package and install the stable AOS.app runtime from an external script.",
      "executable": "/bin/bash",
      "argv_prefix": ["scripts/aos-runtime-install"],
      "cwd": "repo"
    },
    {
      "path": ["runtime", "status"],
      "summary": "Inspect the installed AOS.app runtime from an external script.",
      "executable": "/bin/bash",
      "argv_prefix": ["scripts/aos-runtime-status"],
      "cwd": "repo"
    },
    {
      "path": ["runtime", "path"],
      "summary": "Print the installed AOS.app runtime path from an external script.",
      "executable": "/bin/bash",
      "argv_prefix": ["scripts/aos-runtime-path"],
      "cwd": "repo"
    },
    {
      "path": ["runtime", "sign"],
      "summary": "Sign the packaged AOS.app runtime from an external script.",
      "executable": "/bin/bash",
      "argv_prefix": ["scripts/sign-aos-runtime"],
      "cwd": "repo"
    },
    {
      "path": ["gate", "ask"],
      "summary": "Run the gate ask verb from the external Node implementation.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "packages/cli/verbs/gate-ask.js"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": ["gate", "defer"],
      "summary": "Run the gate defer verb from the external Node implementation.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "packages/cli/verbs/gate-defer.js"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": ["gate", "submit"],
      "summary": "Run the gate submit verb from the external Node implementation.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "packages/cli/verbs/gate-submit.js"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": ["gate", "continuations"],
      "summary": "Run the gate continuations verb from the external Node implementation.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "packages/cli/verbs/gate-continuations.js"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": ["gate", "records"],
      "summary": "Run the gate records verb from the external Node implementation.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "packages/cli/verbs/gate-records.js"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": ["doctor", "gateway"],
      "summary": "Run the gateway doctor reporter from the external Node implementation.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "packages/gateway/dist/doctor-cli.js", "--mode", "$AOS_RUNTIME_MODE", "--state-root", "$AOS_STATE_ROOT"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": ["config", "get"],
      "summary": "Read an AOS config value from the external config command.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/aos-config-command.mjs"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": ["config"],
      "summary": "Dump AOS config from the external config command.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/aos-config-command.mjs", "dump"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": ["config", "set"],
      "summary": "Write an AOS config value from the external config command.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/aos-config-command.mjs"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": ["introspect", "review"],
      "summary": "Review recent AOS usage from the external introspection command.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/aos-introspect-review.mjs"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT",
        "AOS_SESSION_ID": "$AOS_SESSION_KEY",
        "AOS_SESSION_HARNESS": "$AOS_SESSION_HARNESS",
        "AOS_INVOCATION_DISPLAY_NAME": "$AOS_INVOCATION_DISPLAY_NAME"
      }
    },
    {
      "path": ["set"],
      "summary": "Read or write AOS config through the external config shorthand command.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/aos-config-command.mjs", "set-shorthand"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": ["clean"],
      "summary": "Clean stale AOS daemons and canvases from an external command.",
      "executable": "/usr/bin/env",
      "argv_prefix": ["node", "scripts/aos-clean.mjs"],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT",
        "AOS_PATH": "$AOS_PATH"
      }
    }
  ]
}
