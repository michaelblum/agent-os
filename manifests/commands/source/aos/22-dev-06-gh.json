{
  "schema_version": 1,
  "id": "dev-06-gh",
  "path_prefix": [
    "dev"
  ],
  "commands": [
    {
      "consumer_discovery": false,
      "forms": [
        {
          "args": [
            {
              "id": "group",
              "kind": "positional",
              "required": true,
              "summary": "GitHub workflow group: context, issue, pr, ci, or review-comments",
              "value_type": "string"
            },
            {
              "id": "repo",
              "kind": "flag",
              "required": false,
              "summary": "GitHub repository in owner/name form",
              "token": "--repo",
              "value_type": "string"
            },
            {
              "id": "cwd",
              "kind": "flag",
              "required": false,
              "summary": "Local checkout path used for git context and gh execution",
              "token": "--cwd",
              "value_type": "string"
            },
            {
              "id": "json",
              "kind": "flag",
              "required": false,
              "summary": "Emit machine-readable output where the selected operation supports it",
              "token": "--json",
              "value_type": "bool"
            },
            {
              "id": "body-file",
              "kind": "flag",
              "required": false,
              "summary": "Markdown file used for issue or PR comment writes",
              "token": "--body-file",
              "value_type": "string"
            },
            {
              "id": "pr",
              "kind": "flag",
              "required": false,
              "summary": "PR number for CI inspection or review-thread reads",
              "token": "--pr",
              "value_type": "string"
            },
            {
              "id": "state",
              "kind": "flag",
              "required": false,
              "summary": "Issue or PR list state filter: open, closed, merged, or all",
              "token": "--state",
              "value_type": "string"
            },
            {
              "id": "limit",
              "kind": "flag",
              "required": false,
              "summary": "Maximum issue or PR list result count",
              "token": "--limit",
              "value_type": "int"
            },
            {
              "id": "label",
              "kind": "flag",
              "required": false,
              "summary": "Issue or PR list label filter; repeat for multiple labels",
              "token": "--label",
              "value_type": "string"
            },
            {
              "id": "author",
              "kind": "flag",
              "required": false,
              "summary": "Issue or PR list author login filter",
              "token": "--author",
              "value_type": "string"
            },
            {
              "id": "assignee",
              "kind": "flag",
              "required": false,
              "summary": "Issue or PR list assignee login filter",
              "token": "--assignee",
              "value_type": "string"
            },
            {
              "id": "search",
              "kind": "flag",
              "required": false,
              "summary": "Issue or PR list search query",
              "token": "--search",
              "value_type": "string"
            },
            {
              "id": "milestone",
              "kind": "flag",
              "required": false,
              "summary": "Issue list milestone filter",
              "token": "--milestone",
              "value_type": "string"
            },
            {
              "id": "base",
              "kind": "flag",
              "required": false,
              "summary": "PR list base branch filter",
              "token": "--base",
              "value_type": "string"
            },
            {
              "id": "head",
              "kind": "flag",
              "required": false,
              "summary": "PR list head branch filter",
              "token": "--head",
              "value_type": "string"
            },
            {
              "id": "draft",
              "kind": "flag",
              "required": false,
              "summary": "PR list draft filter",
              "token": "--draft",
              "value_type": "bool"
            },
            {
              "id": "arg",
              "kind": "positional",
              "required": false,
              "summary": "Subcommand-specific argument",
              "value_type": "string",
              "variadic": true
            }
          ],
          "examples": [
            "aos dev gh context --json",
            "aos dev gh issue list --state open --limit 50 --milestone v0 --json",
            "aos dev gh issue view 298 --json",
            "aos dev gh issue comment 298 --body-file /tmp/comment.md",
            "aos dev gh pr list --state all --limit 30 --json",
            "aos dev gh ci inspect --pr 298 --json",
            "aos dev gh review-comments --pr 298 --json"
          ],
          "execution": {
            "auto_starts_daemon": false,
            "interactive": false,
            "mutates_state": true,
            "read_only": false,
            "requires_permissions": false,
            "streaming": false,
            "supports_dry_run": false
          },
          "id": "dev-gh",
          "output": {
            "default_mode": "text",
            "error_mode": "json_stderr",
            "streaming": false,
            "supports_json_flag": true
          },
          "usage": "aos dev gh <context|issue|pr|ci|review-comments> [--repo owner/name] [--cwd <path>] [--json] [--body-file <path>] [--pr n] [--state <state>] [--limit n] [--label <name>] [--author <login>] [--assignee <login>] [--search <query>] [--milestone <name>] [--base <branch>] [--head <branch>] [--draft]"
        }
      ],
      "path": [
        "dev"
      ],
      "summary": "Repo development workflow router and build surface"
    }
  ]
}
