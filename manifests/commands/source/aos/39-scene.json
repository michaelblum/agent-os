{
  "schema_version": 1,
  "id": "scene",
  "path_prefix": ["scene"],
  "commands": [{
    "path": ["scene"],
    "summary": "Stream declarative scenes to a shared DesktopWorld stage",
    "forms": [{
      "id": "scene-follow",
      "usage": "aos scene --stage desktop-world/main --owner <id> --resource <id> --follow",
      "args": [
        {"id":"stage","kind":"flag","token":"--stage","value_type":"string","required":true,"summary":"Stage identifier"},
        {"id":"owner","kind":"flag","token":"--owner","value_type":"string","required":true,"summary":"Consumer owner identifier"},
        {"id":"resource","kind":"flag","token":"--resource","value_type":"string","required":true,"summary":"Owner-scoped resource identifier"},
        {"id":"follow","kind":"flag","token":"--follow","value_type":"bool","required":true,"summary":"Read scene operations as NDJSON"}
      ],
      "stdin":{"supported":true,"content_type":"ndjson","used_when":"always"},
      "output":{"default_mode":"ndjson","error_mode":"json_stderr","streaming":true,"supports_json_flag":false},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":true,"read_only":false,"requires_permissions":false,"streaming":true,"supports_dry_run":false},
      "examples":["printf '%s\\n' '{\"op\":\"subscribe\",\"events\":[\"gesture\"]}' '{\"op\":\"inspect\"}' '{\"op\":\"close\"}' | aos scene --stage desktop-world/main --owner example.consumer --resource companion/main --follow"]
    }]
  }, {
    "path": ["scene", "cartridge", "validate"],
    "summary": "Validate a data-only DesktopWorld scene cartridge",
    "forms": [{
      "id": "scene-cartridge-validate",
      "usage": "aos scene cartridge validate <path> [--json]",
      "args": [
        {"id":"path","kind":"positional","value_type":"string","required":true,"summary":"Local scene cartridge directory"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":false,"summary":"Emit a machine-readable validation summary"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"text","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":false,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene cartridge validate ./examples/spinning-object --json"]
    }]
  }, {
    "path": ["scene", "extension", "validate"],
    "summary": "Validate one trusted DesktopWorld projection extension",
    "forms": [{
      "id": "scene-extension-validate",
      "usage": "aos scene extension validate <path> --json",
      "args": [
        {"id":"path","kind":"positional","value_type":"string","required":true,"summary":"Local scene extension directory"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit a redacted machine-readable validation summary"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":false,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene extension validate ./dist/companion-renderer --json"]
    }]
  }, {
    "path": ["scene", "extension", "install"],
    "summary": "Install one reviewed immutable DesktopWorld projection extension",
    "forms": [{
      "id": "scene-extension-install",
      "usage": "aos scene extension install <path> --expected-digest <sha256> --json",
      "args": [
        {"id":"path","kind":"positional","value_type":"string","required":true,"summary":"Validated local scene extension directory"},
        {"id":"expected_digest","kind":"flag","token":"--expected-digest","value_type":"string","required":true,"summary":"Exact reviewed artifact SHA-256"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit a redacted machine-readable installation summary"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":false,"interactive":false,"mutates_state":true,"read_only":false,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene extension install ./dist/companion-renderer --expected-digest <reviewed-sha256> --json"]
    }]
  }, {
    "path": ["scene", "extension", "list"],
    "summary": "List installed immutable DesktopWorld projection extensions",
    "forms": [{
      "id": "scene-extension-list",
      "usage": "aos scene extension list --json",
      "args": [
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit bounded machine-readable extension metadata"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":false,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene extension list --json"]
    }]
  }, {
    "path": ["scene", "list"],
    "summary": "List bounded DesktopWorld scene resources",
    "forms": [{
      "id": "scene-list",
      "usage": "aos scene list --json",
      "args": [{"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit machine-readable resource summaries"}],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene list --json"]
    }]
  }, {
    "path": ["scene", "inspect"],
    "summary": "Inspect one DesktopWorld scene resource",
    "forms": [{
      "id": "scene-inspect",
      "usage": "aos scene inspect --resource <id> --json",
      "args": [
        {"id":"resource","kind":"flag","token":"--resource","value_type":"string","required":true,"summary":"Owner-scoped scene resource identifier"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit a bounded machine-readable snapshot"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene inspect --resource companion/main --json"]
    }]
  }, {
    "path": ["scene", "monitor"],
    "summary": "Follow bounded DesktopWorld snapshots for one resource",
    "forms": [{
      "id": "scene-monitor",
      "usage": "aos scene monitor --resource <id> --follow --json",
      "args": [
        {"id":"resource","kind":"flag","token":"--resource","value_type":"string","required":true,"summary":"Owner-scoped scene resource identifier"},
        {"id":"follow","kind":"flag","token":"--follow","value_type":"bool","required":true,"summary":"Keep the connection-scoped monitor active"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit NDJSON snapshots"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"ndjson","error_mode":"json_stderr","streaming":true,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":true,"supports_dry_run":false},
      "examples":["aos scene monitor --resource companion/main --follow --json"]
    }]
  }, {
    "path": ["scene", "perf"],
    "summary": "Read DesktopWorld render performance for one resource",
    "forms": [{
      "id": "scene-perf",
      "usage": "aos scene perf --resource <id> --json",
      "args": [
        {"id":"resource","kind":"flag","token":"--resource","value_type":"string","required":true,"summary":"Owner-scoped scene resource identifier"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit machine-readable performance facts"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene perf --resource companion/main --json"]
    }]
  }, {
    "path": ["scene", "replay"],
    "summary": "Replay a deterministic scene event fixture without live input",
    "forms": [{
      "id": "scene-replay",
      "usage": "aos scene replay --events <fixture.ndjson> --json",
      "args": [
        {"id":"events","kind":"flag","token":"--events","value_type":"string","required":true,"summary":"Local NDJSON scene-event fixture"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit a content-free replay summary"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":false,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene replay --events ./fixtures/aim-commit.ndjson --json"]
    }]
  }, {
    "path": ["scene", "devtools", "open"],
    "summary": "Open an AOS-owned detachable DesktopWorld inspector",
    "forms": [{
      "id": "scene-devtools-open",
      "usage": "aos scene devtools open [--resource <id>] --json",
      "args": [
        {"id":"resource","kind":"flag","token":"--resource","value_type":"string","required":false,"summary":"Initial selected scene resource"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit the created session snapshot"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":true,"read_only":false,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene devtools open --resource companion/main --json"]
    }]
  }, {
    "path": ["scene", "devtools", "status"],
    "summary": "Read AOS-owned DesktopWorld inspector sessions",
    "forms": [{
      "id": "scene-devtools-status",
      "usage": "aos scene devtools status [--session <id>] --json",
      "args": [
        {"id":"session","kind":"flag","token":"--session","value_type":"string","required":false,"summary":"Specific DevTools session identifier"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit machine-readable session state"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":false,"read_only":true,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene devtools status --json"]
    }]
  }, {
    "path": ["scene", "devtools", "update"],
    "summary": "Update one revisioned DesktopWorld inspector session",
    "forms": [{
      "id": "scene-devtools-update",
      "usage": "aos scene devtools update --session <id> --expected-revision <n> [view options] --json",
      "args": [
        {"id":"session","kind":"flag","token":"--session","value_type":"string","required":true,"summary":"DevTools session identifier"},
        {"id":"expected-revision","kind":"flag","token":"--expected-revision","value_type":"int","required":true,"summary":"Current session revision"},
        {"id":"resource","kind":"flag","token":"--resource","value_type":"string","required":false,"summary":"Selected scene resource"},
        {"id":"clear-resource","kind":"flag","token":"--clear-resource","value_type":"bool","required":false,"summary":"Clear the selected scene resource"},
        {"id":"tab","kind":"flag","token":"--tab","value_type":"string","required":false,"summary":"World, resources, interactions, performance, or events"},
        {"id":"query","kind":"flag","token":"--query","value_type":"string","required":false,"summary":"Bounded inspector query"},
        {"id":"event-kinds","kind":"flag","token":"--event-kinds","value_type":"string","required":false,"summary":"Comma-separated event-kind filter"},
        {"id":"errors-only","kind":"flag","token":"--errors-only","value_type":"string","required":false,"summary":"Set the error-only filter to on or off"},
        {"id":"recording","kind":"flag","token":"--recording","value_type":"string","required":false,"summary":"Set opt-in telemetry recording to on or off"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit the updated session snapshot"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":true,"read_only":false,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene devtools update --session devtools-example --expected-revision 2 --tab performance --recording on --json"]
    }]
  }, {
    "path": ["scene", "devtools", "transfer"],
    "summary": "Transfer the sole interactive host for a DesktopWorld inspector",
    "forms": [{
      "id": "scene-devtools-transfer",
      "usage": "aos scene devtools transfer --session <id> --expected-revision <n> --host-kind <kind> --host-id <id> --json",
      "args": [
        {"id":"session","kind":"flag","token":"--session","value_type":"string","required":true,"summary":"DevTools session identifier"},
        {"id":"expected-revision","kind":"flag","token":"--expected-revision","value_type":"int","required":true,"summary":"Current session revision"},
        {"id":"host-kind","kind":"flag","token":"--host-kind","value_type":"string","required":true,"summary":"Panel, external, or compatibility host kind"},
        {"id":"host-id","kind":"flag","token":"--host-id","value_type":"string","required":true,"summary":"Canonical AOS canvas host identifier"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit the transferred session snapshot"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":true,"read_only":false,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene devtools transfer --session devtools-example --expected-revision 2 --host-kind external --host-id sigil/companion-studio --json"]
    }]
  }, {
    "path": ["scene", "devtools", "close"],
    "summary": "Close one AOS-owned DesktopWorld inspector session",
    "forms": [{
      "id": "scene-devtools-close",
      "usage": "aos scene devtools close --session <id> --json",
      "args": [
        {"id":"session","kind":"flag","token":"--session","value_type":"string","required":true,"summary":"DevTools session identifier"},
        {"id":"json","kind":"flag","token":"--json","value_type":"bool","required":true,"summary":"Emit machine-readable cleanup state"}
      ],
      "stdin":{"supported":false,"content_type":null,"used_when":"never"},
      "output":{"default_mode":"json","error_mode":"json_stderr","streaming":false,"supports_json_flag":true},
      "execution":{"auto_starts_daemon":true,"interactive":false,"mutates_state":true,"read_only":false,"requires_permissions":false,"streaming":false,"supports_dry_run":false},
      "examples":["aos scene devtools close --session devtools-example --json"]
    }]
  }]
}
