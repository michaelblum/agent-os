              "token": "--radius",
              "value_type": "int"
            },
            {
              "id": "delay",
              "kind": "flag",
              "required": false,
              "summary": "Delay before capture in seconds",
              "token": "--delay",
              "value_type": "float"
            },
            {
              "id": "clipboard",
              "kind": "flag",
              "required": false,
              "summary": "Also copy to clipboard",
              "token": "--clipboard",
              "value_type": "bool"
            },
            {
              "id": "draw-rect",
              "kind": "flag",
              "required": false,
              "summary": "Draw rectangle overlay: x,y,w,h color",
              "token": "--draw-rect",
              "value_type": "string"
            },
            {
              "id": "interactive",
              "kind": "flag",
              "required": false,
              "summary": "Native selection rectangle",
              "token": "--interactive",
              "value_type": "bool"
            },
            {
              "id": "wait-for-click",
              "kind": "flag",
              "required": false,
              "summary": "Wait for click then capture",
              "token": "--wait-for-click",
              "value_type": "bool"
            },
            {
              "id": "save",
              "kind": "flag",
              "required": false,
              "summary": "Persist full perception in a local agent workspace and return compact JSON refs with conformance/proof; saved-ref actions support canvas click/set-value, validated browser click/fill/hover/scroll/drag mutation, and stable native AX press/focus/set-value when producer verdict is actionable",
              "token": "--save",
              "value_type": "bool"
            },
            {
              "id": "workspace",
              "kind": "flag",
              "required": false,
              "summary": "Agent workspace id; overrides AOS_AGENT_WORKSPACE",
              "token": "--workspace",
              "value_type": "string"
            },
            {
              "id": "name",
              "kind": "flag",
              "required": false,
              "summary": "Snapshot id for a saved capture",
              "token": "--name",
              "value_type": "string"
            },
            {
              "default_value": "som",
              "id": "mode",
              "kind": "flag",
              "required": false,
              "summary": "Saved capture mode",
              "token": "--mode",
              "value_type": {
                "enum": [
                  {
                    "summary": "Accessibility or target tree first",
                    "value": "ax"
                  },
                  {
                    "summary": "Image artifact first",
                    "value": "vision"
                  },
                  {
                    "summary": "Set-of-mark style tree plus image pointers",
                    "value": "som"
                  }
                ]
              }
            },
            {
              "id": "query",
              "kind": "flag",
              "required": false,
              "summary": "Filter compact saved refs by text; saved-ref mutation is limited to the documented backend action matrix",
              "token": "--query",
              "value_type": "string"
            }
