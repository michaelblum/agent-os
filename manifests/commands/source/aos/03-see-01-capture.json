            "requires_permissions": true,
            "streaming": false,
            "supports_dry_run": false
          },
          "id": "see-cursor",
          "output": {
            "default_mode": "json",
            "error_mode": "json_stderr",
            "streaming": false,
            "supports_json_flag": false
          },
          "usage": "aos see cursor"
        },
        {
          "args": [
            {
              "default_value": "main",
              "discovery": [
                {
                  "static": [
                    "main",
                    "external",
                    "user_active",
                    "selfie",
                    "mouse",
                    "all"
                  ]
                },
                {
                  "command": {
                    "form_id": "zone-list",
                    "path": [
                      "see",
                      "zone"
                    ]
                  }
                }
              ],
              "id": "target",
              "kind": "positional",
              "required": false,
              "summary": "Capture target; defaults to main when omitted",
              "value_type": "string"
            },
            {
              "default_value": "./screenshot.png",
              "id": "out",
              "kind": "flag",
              "required": false,
              "summary": "Output file path",
              "token": "--out",
              "value_type": "string"
            },
            {
              "id": "base64",
              "kind": "flag",
              "required": false,
              "summary": "Output base64 instead of file",
              "token": "--base64",
              "value_type": "bool"
            },
            {
              "default_value": "png",
              "id": "format",
              "kind": "flag",
              "required": false,
              "summary": "Image format",
              "token": "--format",
              "value_type": {
                "enum": [
                  {
                    "summary": "Lossless PNG (default)",
                    "value": "png"
                  },
                  {
                    "summary": "Lossy JPEG (.jpg)",
                    "value": "jpg"
                  },
                  {
                    "summary": "JPEG alias; output path uses .jpg",
                    "value": "jpeg"
                  },
                  {
                    "summary": "HEIC format",
                    "value": "heic"
                  }
                ]
              }
            },
            {
              "default_value": "high",
              "id": "quality",
              "kind": "flag",
              "required": false,
              "summary": "Image quality",
              "token": "--quality",
              "value_type": {
                "enum": [
                  {
                    "summary": "Full resolution (default)",
                    "value": "high"
                  },
                  {
                    "summary": "Medium resolution",
                    "value": "med"
                  },
                  {
                    "summary": "Low resolution",
                    "value": "low"
                  }
                ]
              }
            },
            {
              "id": "window",
              "kind": "flag",
              "required": false,
              "summary": "Capture window only",
              "token": "--window",
              "value_type": "bool"
            },
            {
              "id": "crop",
              "kind": "flag",
              "required": false,
              "summary": "Crop spec: x,y,w,h or named region (top-half, etc.)",
              "token": "--crop",
              "value_type": "string"
            },
            {
              "id": "region",
              "kind": "flag",
              "required": false,
              "summary": "Global CG region in points: x,y,w,h",
              "token": "--region",
              "value_type": "string"
            },
            {
              "id": "canvas",
              "kind": "flag",
              "required": false,
              "summary": "Capture a canvas by id",
              "token": "--canvas",
              "value_type": "string"
            },
            {
              "id": "channel",
              "kind": "flag",
              "required": false,
              "summary": "Capture a focus channel by id",
              "token": "--channel",
              "value_type": "string"
            },
            {
              "id": "grid",
              "kind": "flag",
              "required": false,
              "summary": "Grid overlay (e.g. 4x3)",
              "token": "--grid",
              "value_type": "string"
            },
            {
              "id": "xray",
              "kind": "flag",
              "required": false,
              "summary": "AX element traversal overlay",
              "token": "--xray",
              "value_type": "bool"
            },
            {
              "id": "browser-dom-point",
              "kind": "flag",
              "required": false,
              "summary": "Browser DOM viewport point hit test for browser:<session> targets: x,y",
