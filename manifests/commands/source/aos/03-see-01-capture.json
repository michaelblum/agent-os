              "token": "--label",
              "value_type": "bool"
            },
            {
              "id": "perception",
              "kind": "flag",
              "required": false,
              "summary": "Include topology + resolved surface geometry for the capture (segments when spanning displays)",
              "token": "--perception",
              "value_type": "bool"
            },
            {
              "id": "show-cursor",
              "kind": "flag",
              "required": false,
              "summary": "Include cursor in capture",
              "token": "--show-cursor",
              "value_type": "bool"
            },
            {
              "id": "highlight-cursor",
              "kind": "flag",
              "required": false,
              "summary": "Highlight cursor position",
              "token": "--highlight-cursor",
              "value_type": "bool"
            },
            {
              "id": "radius",
              "kind": "flag",
              "required": false,
