            "read_only": true,
            "requires_permissions": false,
            "streaming": false,
            "supports_dry_run": false
          },
          "id": "voice-assignments",
          "output": {
            "default_mode": "json",
            "error_mode": "json_stderr",
            "streaming": false,
            "supports_json_flag": false
          },
          "usage": "aos voice assignments"
        },
        {
          "args": [
            {
              "id": "refresh",
              "kind": "positional",
              "required": false,
              "summary": "Re-enumerate voices from all providers",
              "value_type": "string"
            }
          ],
          "examples": [
            "aos voice refresh"
          ],
          "execution": {
            "auto_starts_daemon": true,
            "interactive": false,
            "mutates_state": true,
            "read_only": false,
            "requires_permissions": false,
            "streaming": false,
            "supports_dry_run": false
          },
          "id": "voice-refresh",
          "output": {
            "default_mode": "json",
            "error_mode": "json_stderr",
            "streaming": false,
            "supports_json_flag": false
          },
          "usage": "aos voice refresh"
        },
        {
          "args": [
            {
              "id": "providers",
              "kind": "positional",
              "required": false,
              "summary": "List voice providers with availability and voice counts",
              "value_type": "string"
            }
          ],
          "examples": [
            "aos voice providers"
          ],
          "execution": {
            "auto_starts_daemon": true,
            "interactive": false,
            "mutates_state": false,
            "read_only": true,
            "requires_permissions": false,
            "streaming": false,
            "supports_dry_run": false
          },
          "id": "voice-providers",
          "output": {
            "default_mode": "json",
            "error_mode": "json_stderr",
