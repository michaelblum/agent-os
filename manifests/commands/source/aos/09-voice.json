{
  "schema_version": 1,
  "id": "voice",
  "path_prefix": [
    "voice"
  ],
  "commands": [
    {
      "forms": [
        {
          "args": [
            {
              "id": "list",
              "kind": "positional",
              "required": false,
              "summary": "List discovered voices from the registry",
              "value_type": "string"
            },
            {
              "id": "provider",
              "kind": "flag",
              "required": false,
              "summary": "Filter to one provider name",
              "token": "--provider",
              "value_type": "string"
            },
            {
              "id": "speakable-only",
              "kind": "flag",
              "required": false,
              "summary": "Show only enabled voices that can actually synthesize",
              "token": "--speakable-only",
              "value_type": "bool"
            }
          ],
          "examples": [
            "aos voice list",
            "aos voice list --provider system",
            "aos voice list --speakable-only"
          ],
          "execution": {
            "auto_starts_daemon": true,
            "interactive": false,
            "mutates_state": false,
            "read_only": true,
            "requires_permissions": false,
            "streaming": false,
            "supports_dry_run": false
          },
          "id": "voice-list",
          "output": {
            "default_mode": "json",
            "error_mode": "json_stderr",
            "streaming": false,
            "supports_json_flag": false
          },
          "usage": "aos voice list [--provider <name>] [--speakable-only]"
        },
        {
          "args": [
            {
              "id": "assignments",
              "kind": "positional",
              "required": false,
              "summary": "List session-centric voice assignments",
              "value_type": "string"
            }
          ],
          "examples": [
            "aos voice assignments"
          ],
          "execution": {
            "auto_starts_daemon": true,
            "interactive": false,
