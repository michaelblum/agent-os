{
  "schema_version": 1,
  "id": "ready",
  "path_prefix": [
    "ready"
  ],
  "commands": [
    {
      "forms": [
        {
          "args": [
            {
              "id": "json",
              "kind": "flag",
              "required": false,
              "summary": "Emit machine-readable readiness response",
              "token": "--json",
              "value_type": "bool"
            },
            {
              "id": "repair",
              "kind": "flag",
              "required": false,
              "summary": "Permit readiness to clean, start or restart the runtime, wait for recovery, and produce permission handoffs",
              "token": "--repair",
              "value_type": "bool"
            },
            {
              "id": "post-permission",
              "kind": "flag",
              "required": false,
              "summary": "Read-only bounded verification after the human re-adds permissions; combine with --repair for one guarded managed restart",
              "token": "--post-permission",
              "value_type": "bool"
            }
          ],
          "examples": [
            "aos ready",
            "aos ready --repair",
            "aos ready --post-permission",
            "aos ready --repair --post-permission",
            "aos ready --json"
          ],
          "execution": {
            "auto_starts_daemon": false,
            "auto_starts_daemon_when_flags": [
              "--repair"
            ],
            "interactive": false,
            "mutates_state": false,
            "mutates_when_flags": [
              "--repair"
            ],
            "read_only": true,
            "requires_permissions": false,
            "streaming": false,
            "supports_dry_run": false
          },
          "id": "ready",
          "output": {
            "default_mode": "text",
            "error_mode": "json_stderr",
            "streaming": false,
            "supports_json_flag": true
          },
          "usage": "aos ready [--json] [--repair] [--post-permission]"
        }
      ],
      "path": [
        "ready"
      ],
      "summary": "Check AOS readiness without mutation; use --repair for cleanup, start, restart, and recovery"
    }
  ]
}
