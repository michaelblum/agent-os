{
  "schema_version": 1,
  "id": "see",
  "commands": [
    {
      "path": [
        "see"
      ],
      "summary": "Print see command help when no subcommand is provided.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-help-proxy.mjs",
        "see"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0,
        "child_arg_missing": true
      },
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "see"
      ],
      "summary": "Route legacy see capture shorthand through the external see native command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-see-native.mjs",
        "capture"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0,
        "excluded_values": [
          "capture",
          "observe",
          "cursor",
          "list",
          "selection",
          "snapshots",
          "refs",
          "workspaces",
          "workspace",
          "snapshot",
          "zone"
        ]
      },
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "see",
        "capture"
      ],
      "summary": "Capture screen or browser targets through the external see native command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-see-native.mjs",
        "capture"
      ],
      "cwd": "repo",
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "see",
        "snapshots"
      ],
      "summary": "List saved agent-workspace snapshots through external workspace composition.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-agent-workspace.mjs",
        "snapshots"
      ],
      "cwd": "repo",
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "see",
        "refs"
      ],
      "summary": "List compact saved refs through external agent-workspace composition; saved-ref mutation follows the backend action matrix.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-agent-workspace.mjs",
        "refs"
      ],
      "cwd": "repo",
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "see",
        "workspaces"
      ],
