      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-subcommand-router.mjs",
        "see zone",
        "MISSING_SUBCOMMAND",
        "see zone requires a subcommand. Usage: aos see zone <save|define|list|delete> ...",
        "UNKNOWN_SUBCOMMAND",
        "see zone subcommand"
      ],
      "cwd": "repo"
    },
    {
      "path": [
        "see",
        "zone",
        "list"
