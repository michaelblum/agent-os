      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-see-native.mjs",
        "capture"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0,
        "excluded_values": [
          "capture",
          "observe",
          "cursor",
          "list",
          "selection",
          "snapshots",
          "refs",
          "workspaces",
          "workspace",
          "snapshot",
          "annotation",
