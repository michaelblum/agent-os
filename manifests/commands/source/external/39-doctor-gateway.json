{
  "schema_version": 1,
  "id": "doctor-gateway",
  "commands": [
    {
      "path": [
        "doctor",
        "gateway"
      ],
      "summary": "Run the gateway doctor reporter from the external Node implementation.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "packages/gateway/dist/doctor-cli.js",
        "--mode",
        "$AOS_RUNTIME_MODE",
        "--state-root",
        "$AOS_STATE_ROOT"
      ],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    }
  ]
}
