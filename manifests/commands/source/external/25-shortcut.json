{
  "schema_version": 1,
  "id": "shortcut",
  "commands": [
    {
      "path": [
        "shortcut"
      ],
      "summary": "Run explicitly named Apple Shortcuts through a bounded shell-free adapter.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-shortcut.mjs"
      ],
      "cwd": "repo",
      "stdio": "inherit"
    },
    {
      "path": [
        "shortcut",
        "run"
      ],
      "summary": "Run one exact Apple Shortcut through the bounded adapter.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-shortcut.mjs",
        "run"
      ],
      "cwd": "repo",
      "stdio": "inherit"
    }
  ]
}
