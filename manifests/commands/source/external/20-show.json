{
  "schema_version": 1,
  "id": "show",
  "commands": [
    {
      "path": [
        "show"
      ],
      "summary": "Validate unknown show subcommand routing through the external family router.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-family-router.mjs",
        "show",
        "UNKNOWN_SUBCOMMAND",
        "show subcommand"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0,
        "excluded_values": [
          "render",
          "create",
          "update",
          "remove",
          "remove-all",
          "list",
          "eval",
          "listen",
          "ping",
          "wait",
          "exists",
          "get",
          "to-front",
          "post"
        ]
      }
    },
    {
      "path": [
        "show",
        "listen"
      ],
      "summary": "Listen for canvas events through the external show client.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-show-client.mjs",
        "listen"
      ],
      "cwd": "repo",
      "stdio": "inherit",
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "show",
        "render"
      ],
      "summary": "Render HTML to PNG through the external show render command.",
