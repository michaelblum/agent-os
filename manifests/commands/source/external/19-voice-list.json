{
  "schema_version": 1,
  "id": "voice-list",
  "commands": [
    {
      "path": [
        "voice",
        "list"
      ],
      "summary": "List voice registry entries through the external voice command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-voice.mjs",
        "list"
      ],
      "cwd": "repo",
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "voice",
        "assignments"
      ],
      "summary": "List voice assignments through the external voice command.",
