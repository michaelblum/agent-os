{
  "schema_version": 1,
  "id": "dev",
  "commands": [
    {
      "path": [
        "dev"
      ],
      "summary": "Validate unknown dev subcommand routing through the external family router.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-family-router.mjs",
        "dev",
        "UNKNOWN_SUBCOMMAND",
        "dev subcommand"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0
      }
    },
    {
      "path": [
        "dev",
        "afk-dry-run"
      ],
      "summary": "Run the AFK dry-run command from the external Node prototype.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/afk-dry-run-prototype.mjs"
      ],
      "cwd": "repo"
    },
    {
      "path": [
        "dev",
        "afk-launch-attempt"
      ],
      "summary": "Run the AFK launch-attempt command from the external Node prototype.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/afk-launch-attempt-prototype.mjs"
      ],
      "cwd": "repo"
    },
    {
      "path": [
        "dev",
        "afk-session-trigger"
      ],
      "summary": "Run the AFK session-trigger command from the external Node prototype.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/afk-session-trigger-prototype.mjs"
      ],
      "cwd": "repo"
    },
    {
      "path": [
        "dev",
        "gh"
      ],
      "summary": "Run GitHub workflow helpers through the external dev gh command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-dev-gh.mjs"
      ],
      "help_passthrough": true,
      "cwd": "repo",
      "env": {
        "REPO_ROOT": "$REPO_ROOT"
      }
    },
    {
      "path": [
        "dev",
        "situation"
      ],
      "summary": "Aggregate sourced live orientation facts through the external dev situation command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-dev-situation.mjs"
      ],
      "cwd": "repo",
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "REPO_ROOT": "$REPO_ROOT"
      }
    },
    {
      "path": [
        "dev",
        "drift-lint"
