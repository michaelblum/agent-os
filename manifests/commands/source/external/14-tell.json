{
  "schema_version": 1,
  "id": "tell",
  "commands": [
    {
      "path": [
        "tell"
      ],
      "summary": "Send daemon-routed coordination messages through the external tell command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-tell-listen.mjs",
        "tell"
      ],
      "cwd": "repo",
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    }
  ]
}
