{
  "schema_version": 1,
  "id": "scene",
  "commands": [{
    "path": ["scene"],
    "summary": "Stream bounded declarative scenes to DesktopWorld.",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs"],
    "cwd": "repo",
    "stdio": "inherit",
    "env": {
      "AOS_PATH": "$AOS_PATH",
      "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
      "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
    }
  }, {
    "path": ["scene", "cartridge", "validate"],
    "summary": "Validate a data-only DesktopWorld scene cartridge",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "cartridge", "validate"],
    "cwd": "repo",
    "stdio": "inherit"
  }, {
    "path": ["scene", "list"],
    "summary": "List bounded DesktopWorld scene resources",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "list"],
    "cwd": "repo", "stdio": "inherit"
  }, {
    "path": ["scene", "inspect"],
    "summary": "Inspect one DesktopWorld scene resource",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "inspect"],
    "cwd": "repo", "stdio": "inherit"
  }, {
    "path": ["scene", "monitor"],
    "summary": "Follow bounded DesktopWorld snapshots",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "monitor"],
    "cwd": "repo", "stdio": "inherit"
  }, {
    "path": ["scene", "perf"],
    "summary": "Read DesktopWorld render performance",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "perf"],
    "cwd": "repo", "stdio": "inherit"
  }, {
    "path": ["scene", "replay"],
    "summary": "Replay a deterministic scene event fixture",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "replay"],
    "cwd": "repo", "stdio": "inherit"
  }, {
    "path": ["scene", "devtools", "open"],
    "summary": "Open an AOS-owned DesktopWorld inspector",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "devtools", "open"],
    "cwd": "repo", "stdio": "inherit"
  }, {
    "path": ["scene", "devtools", "status"],
    "summary": "Read DesktopWorld inspector sessions",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "devtools", "status"],
    "cwd": "repo", "stdio": "inherit"
  }, {
    "path": ["scene", "devtools", "close"],
    "summary": "Close a DesktopWorld inspector session",
    "executable": "/usr/bin/env",
    "argv_prefix": ["node", "scripts/aos-scene.mjs", "devtools", "close"],
    "cwd": "repo", "stdio": "inherit"
  }]
}
