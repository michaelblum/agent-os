{
  "schema_version": 1,
  "id": "set",
  "commands": [
    {
      "path": [
        "set"
      ],
      "summary": "Read or write AOS config through the external config shorthand command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-config-command.mjs",
        "set-shorthand"
      ],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    }
  ]
}
