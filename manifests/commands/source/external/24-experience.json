{
  "schema_version": 1,
  "id": "experience",
  "commands": [
    {
      "path": [
        "experience"
      ],
      "summary": "Activate and inspect source-owned AOS experience layers.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-experience.mjs"
      ],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": [
        "experience",
        "status"
      ],
      "summary": "Inspect active or app-owned source-owned AOS experience runtime context.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-experience.mjs",
        "status"
      ],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": [
        "experience",
        "activate"
      ],
      "summary": "Activate a source-owned AOS experience layer.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-experience.mjs",
        "activate"
      ],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": [
        "experience",
        "menu",
        "invoke"
      ],
      "summary": "Invoke a source-owned experience status-item menu action.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-experience.mjs",
        "menu",
        "invoke"
      ],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT",
        "AOS_PATH": "$AOS_PATH"
      }
    },
    {
      "path": [
        "experience",
        "deactivate"
      ],
      "summary": "Deactivate the active AOS experience layer.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-experience.mjs",
        "deactivate"
      ],
      "cwd": "repo",
      "env": {
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT",
        "AOS_PATH": "$AOS_PATH"
      }
    }
  ]
}
