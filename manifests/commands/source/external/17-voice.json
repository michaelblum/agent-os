{
  "schema_version": 1,
  "id": "voice",
  "commands": [
    {
      "path": [
        "voice"
      ],
      "summary": "Validate voice command routing through the external family router.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-family-router.mjs",
        "voice",
        "UNKNOWN_COMMAND",
        "voice command"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0
      }
    },
    {
      "path": [
        "voice",
        "_internal-id-roundtrip"
      ],
      "summary": "Round-trip voice IDs through the external voice test helper.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-voice-internal.mjs",
        "_internal-id-roundtrip"
      ],
      "cwd": "repo"
    },
    {
      "path": [
        "voice",
        "_internal-canonicalize"
      ],
      "summary": "Canonicalize voice IDs through the external voice test helper.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-voice-internal.mjs",
        "_internal-canonicalize"
      ],
      "cwd": "repo"
    },
    {
      "path": [
        "voice",
        "_internal-registry-snapshot"
      ],
      "summary": "Emit the voice registry snapshot through the external voice test helper.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-voice-internal.mjs",
        "_internal-registry-snapshot"
      ],
      "cwd": "repo"
    }
  ]
}
