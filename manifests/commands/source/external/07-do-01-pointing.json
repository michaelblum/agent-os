{
  "schema_version": 1,
  "id": "do-01-pointing",
  "commands": [
    {
      "path": [
        "do",
        "click"
      ],
      "summary": "Resolve saved click ref targets through the agent workspace action dispatcher.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-do-ref.mjs",
        "click"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0,
        "prefix": "ref:"
      },
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_INVOCATION_DISPLAY_NAME": "$AOS_INVOCATION_DISPLAY_NAME",
        "AOS_RUNTIME_MODE": "$AOS_RUNTIME_MODE",
        "AOS_STATE_ROOT": "$AOS_STATE_ROOT"
      }
    },
    {
      "path": [
        "do",
        "click"
      ],
      "summary": "Click browser targets through the external do browser command.",
      "executable": "/usr/bin/env",
      "argv_prefix": [
        "node",
        "scripts/aos-do-browser.mjs",
        "click"
      ],
      "cwd": "repo",
      "when": {
        "child_arg_index": 0,
        "prefix": "browser:"
      },
      "env": {
        "AOS_PATH": "$AOS_PATH",
        "AOS_INVOCATION_DISPLAY_NAME": "$AOS_INVOCATION_DISPLAY_NAME",
