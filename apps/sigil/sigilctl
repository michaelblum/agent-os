#!/bin/bash
set -euo pipefail

cd "$(dirname "$0")"
REPO_ROOT="$(cd ../.. && pwd)"
HOME_DIR="${HOME}"
LAUNCH_DOMAIN="gui/$(id -u)"
LABEL="com.agent-os.sigil"
PLIST_PATH="$HOME_DIR/Library/LaunchAgents/$LABEL.plist"
LOG_DIR="$HOME_DIR/.config/aos"
STDOUT_LOG="$LOG_DIR/sigil.stdout.log"
STDERR_LOG="$LOG_DIR/sigil.log"
INSTALLED_AOS_APP="$HOME_DIR/Applications/AOS.app"
INSTALLED_AOS_BIN="$INSTALLED_AOS_APP/Contents/MacOS/aos"
INSTALLED_SIGIL_BINARY="$INSTALLED_AOS_APP/Contents/MacOS/avatar-sub"
INSTALLED_SIGIL_WORKDIR="$INSTALLED_AOS_APP/Contents/Resources/agent-os/apps/sigil"
if [[ -n "${AOS_BIN:-}" ]]; then
  AOS_BIN="$AOS_BIN"
elif [[ -x "$INSTALLED_AOS_BIN" ]]; then
  AOS_BIN="$INSTALLED_AOS_BIN"
else
  AOS_BIN="$REPO_ROOT/aos"
fi

if [[ -n "${SIGIL_BINARY_PATH:-}" ]]; then
  BINARY_PATH="$SIGIL_BINARY_PATH"
elif [[ -x "$INSTALLED_SIGIL_BINARY" ]]; then
  BINARY_PATH="$INSTALLED_SIGIL_BINARY"
else
  BINARY_PATH="$REPO_ROOT/apps/sigil/build/avatar-sub"
fi

if [[ -n "${SIGIL_WORKDIR:-}" ]]; then
  WORKING_DIRECTORY="$SIGIL_WORKDIR"
elif [[ "$BINARY_PATH" == "$INSTALLED_SIGIL_BINARY" && -d "$INSTALLED_SIGIL_WORKDIR" ]]; then
  WORKING_DIRECTORY="$INSTALLED_SIGIL_WORKDIR"
else
  WORKING_DIRECTORY="$REPO_ROOT/apps/sigil"
fi

json_escape() {
  /usr/bin/python3 - <<'PY' "$1"
import json, sys
print(json.dumps(sys.argv[1]))
PY
}

service_pid() {
  /bin/launchctl print "$LAUNCH_DOMAIN/$LABEL" 2>/dev/null | awk -F'= ' '/^[[:space:]]*pid = / {print $2; exit}'
}

service_loaded() {
  /bin/launchctl print "$LAUNCH_DOMAIN/$LABEL" >/dev/null 2>&1
}

plist_program_path() {
  /usr/libexec/PlistBuddy -c 'Print :ProgramArguments:0' "$PLIST_PATH" 2>/dev/null || true
}

plist_working_directory() {
  /usr/libexec/PlistBuddy -c 'Print :WorkingDirectory' "$PLIST_PATH" 2>/dev/null || true
}

notes_to_json() {
  if (($# == 0)); then
    echo "[]"
    return
  fi
  printf '%s\n' "$@" | /usr/bin/python3 -c 'import json, sys; print(json.dumps([line.rstrip("\n") for line in sys.stdin if line.strip()]))'
}

avatar_canvas_exists() {
  [[ -x "$AOS_BIN" ]] || return 1
  local exists
  exists="$("$AOS_BIN" show exists --id avatar --json 2>/dev/null | /usr/bin/python3 -c 'import json, sys
try:
    print("true" if json.load(sys.stdin).get("exists") else "false")
except Exception:
    print("false")')"
  [[ "$exists" == "true" ]]
}

status_json() {
  local installed=false running=false pid="null" status="ok" notes=()
  local actual_binary_path="$BINARY_PATH"
  local actual_working_directory="$WORKING_DIRECTORY"

  [[ -f "$PLIST_PATH" ]] && installed=true
  if local_pid="$(service_pid)"; [[ -n "${local_pid:-}" ]]; then
    running=true
    pid="$local_pid"
  fi
  if [[ "$installed" == true ]]; then
    local plist_binary_path plist_workdir
    plist_binary_path="$(plist_program_path)"
    plist_workdir="$(plist_working_directory)"
    [[ -n "$plist_binary_path" ]] && actual_binary_path="$plist_binary_path"
    [[ -n "$plist_workdir" ]] && actual_working_directory="$plist_workdir"
  fi

  if [[ "$installed" != true ]]; then
    status="degraded"
    notes+=("Launch agent plist is not installed.")
  fi
  if [[ "$installed" == true ]] && ! service_loaded; then
    status="degraded"
    notes+=("Launch agent is installed but not loaded in launchd.")
  fi
  if [[ "$installed" == true && "$running" != true ]]; then
    status="degraded"
    notes+=("Sigil service is not running.")
  fi
  if [[ "$actual_binary_path" != "$BINARY_PATH" ]]; then
    status="degraded"
    notes+=("Installed launch agent target differs from the preferred Sigil binary.")
  fi

  local notes_json="[]"
  if ((${#notes[@]})); then
    notes_json="$(notes_to_json "${notes[@]}")"
  fi

  cat <<JSON
{
  "status": $(json_escape "$status"),
  "installed": $installed,
  "running": $running,
  "pid": $pid,
  "launchd_label": $(json_escape "$LABEL"),
  "binary_path": $(json_escape "$actual_binary_path"),
  "preferred_binary_path": $(json_escape "$BINARY_PATH"),
  "working_directory": $(json_escape "$actual_working_directory"),
  "plist_path": $(json_escape "$PLIST_PATH"),
  "log_path": $(json_escape "$STDERR_LOG"),
  "notes": $notes_json
}
JSON
}

install_service() {
  mkdir -p "$HOME_DIR/Library/LaunchAgents" "$LOG_DIR"
  [[ -x "$BINARY_PATH" ]] || { echo "avatar-sub binary not found at $BINARY_PATH; run bash apps/sigil/build-avatar.sh first" >&2; exit 1; }

  cat >"$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$BINARY_PATH</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>$WORKING_DIRECTORY</string>
  <key>StandardOutPath</key>
  <string>$STDOUT_LOG</string>
  <key>StandardErrorPath</key>
  <string>$STDERR_LOG</string>
</dict>
</plist>
PLIST

  if ! service_loaded; then
    /bin/launchctl bootstrap "$LAUNCH_DOMAIN" "$PLIST_PATH"
  fi
  /bin/launchctl kickstart -k "$LAUNCH_DOMAIN/$LABEL"
}

start_service() {
  if [[ ! -f "$PLIST_PATH" ]]; then
    install_service
    return
  fi
  if ! service_loaded; then
    /bin/launchctl bootstrap "$LAUNCH_DOMAIN" "$PLIST_PATH"
  fi
  /bin/launchctl kickstart -k "$LAUNCH_DOMAIN/$LABEL"
}

stop_service() {
  if [[ -f "$PLIST_PATH" ]]; then
    /bin/launchctl bootout "$LAUNCH_DOMAIN" "$PLIST_PATH" >/dev/null 2>&1 || true
  fi
}

logs_service() {
  local tail_count="${1:-200}"
  [[ -f "$STDERR_LOG" ]] || { echo "No log found at $STDERR_LOG" >&2; exit 1; }
  tail -n "$tail_count" "$STDERR_LOG"
}

state_json() {
  local service_json canvas_json canvas_exists=false x="null" y="null" size="null" status="ok" notes=()
  service_json="$(status_json)"

  if [[ -x "$AOS_BIN" ]]; then
    canvas_json="$("$AOS_BIN" show get --id avatar --json 2>/dev/null || true)"
    if [[ -n "$canvas_json" ]]; then
      read -r canvas_exists x y size < <(/usr/bin/python3 - <<'PY' "$canvas_json"
import json, sys
try:
    obj = json.loads(sys.argv[1])
except Exception:
    print("false null null null")
    raise SystemExit
canvas = obj.get("canvas") or {}
at = canvas.get("at") or []
exists = "true" if obj.get("exists") else "false"
x = at[0] if len(at) > 0 else "null"
y = at[1] if len(at) > 1 else "null"
size = at[2] if len(at) > 2 else "null"
print(exists, x, y, size)
PY
)
    fi
  else
    notes+=("aos binary not found at $AOS_BIN")
  fi

  if [[ "$canvas_exists" != true ]]; then
    status="degraded"
    notes+=("Avatar canvas is not present.")
  fi

  local notes_json="[]"
  if ((${#notes[@]})); then
    notes_json="$(notes_to_json "${notes[@]}")"
  fi

  /usr/bin/python3 - <<'PY' "$service_json" "$status" "$canvas_exists" "$x" "$y" "$size" "$notes_json"
import json, sys
service = json.loads(sys.argv[1])
status = sys.argv[2]
canvas_exists = sys.argv[3] == "true"
x = None if sys.argv[4] == "null" else float(sys.argv[4])
y = None if sys.argv[5] == "null" else float(sys.argv[5])
size = None if sys.argv[6] == "null" else float(sys.argv[6])
notes = json.loads(sys.argv[7])
print(json.dumps({
  "status": status,
  "process": {
    "installed": service["installed"],
    "running": service["running"],
    "pid": service["pid"]
  },
  "avatar": {
    "canvas_exists": canvas_exists,
    "x": x,
    "y": y,
    "size": size
  },
  "log_path": service["log_path"],
  "notes": service["notes"] + notes
}, indent=2))
PY
}

ensure_avatar() {
  if ! service_loaded || [[ -z "$(service_pid)" ]]; then
    start_service
    sleep 1
  fi

  if avatar_canvas_exists; then
    echo '{"status":"ok","ensured":true,"action":"none"}'
    return
  fi

  stop_service
  start_service
  sleep 1
  if avatar_canvas_exists; then
    echo '{"status":"ok","ensured":true,"action":"restart"}'
    return
  fi

  echo '{"status":"degraded","ensured":false,"action":"restart","notes":["Avatar canvas still missing after service restart."]}'
  exit 1
}

CMD="${1:-}"
shift || true

case "$CMD" in
  install) install_service; if [[ "${1:-}" == "--json" ]]; then status_json; else echo "installed"; fi ;;
  start) start_service; if [[ "${1:-}" == "--json" ]]; then status_json; else echo "started"; fi ;;
  stop) stop_service; if [[ "${1:-}" == "--json" ]]; then status_json; else echo "stopped"; fi ;;
  restart) stop_service; start_service; if [[ "${1:-}" == "--json" ]]; then status_json; else echo "restarted"; fi ;;
  status) status_json ;;
  logs) logs_service "${1:-200}" ;;
  state) state_json ;;
  ensure-avatar) ensure_avatar ;;
  *)
    echo "Usage: apps/sigil/sigilctl <install|start|stop|restart|status|logs|state|ensure-avatar>" >&2
    exit 1
    ;;
esac
