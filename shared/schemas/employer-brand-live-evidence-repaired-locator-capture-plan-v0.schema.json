{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-repaired-locator-capture-plan-v0.schema.json",
  "title": "Employer Brand Live Evidence Repaired Locator Capture Plan v0",
  "description": "Derived pre-capture plan for retrying only Operator-approved repaired live-evidence locator slots while preserving unavailable sources and prior non-executable context.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "status",
    "source_refs",
    "summary",
    "capture_ordering",
    "repaired_capture_slots",
    "unavailable_source_slots",
    "non_executable_context",
    "planned_output_manifest",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_repaired_locator_capture_plan"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-capture-repair-promotion-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "const": "pre_capture_plan_ready_with_source_unavailable_context"
    },
    "source_refs": {
      "type": "object"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "capture_ordering": {
      "type": "object",
      "required": [
        "strategy",
        "order_is_deterministic",
        "executable_slot_ids",
        "stop_after_each_slot_for_human_review"
      ],
      "properties": {
        "strategy": {
          "const": "preserve_repair_patch_slot_order"
        },
        "order_is_deterministic": {
          "const": true
        },
        "executable_slot_ids": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "stop_after_each_slot_for_human_review": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "repaired_capture_slots": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/repaired_slot"
      }
    },
    "unavailable_source_slots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "$ref": "#/$defs/unavailable_slot"
      }
    },
    "non_executable_context": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {
        "type": "object",
        "required": [
          "executable",
          "read_only_context",
          "full_page_grab"
        ],
        "properties": {
          "executable": {
            "const": false
          },
          "read_only_context": {
            "const": true
          },
          "full_page_grab": {
            "const": false
          }
        },
        "additionalProperties": true
      }
    },
    "planned_output_manifest": {
      "$ref": "#/$defs/planned_output_manifest"
    },
    "controls": {
      "type": "object",
      "additionalProperties": {
        "const": false
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "deterministic_from_filled_repair_patch",
        "no_urls_opened",
        "no_locator_resolution_run",
        "no_capture_assets_produced",
        "planned_outputs_only",
        "read_only",
        "planning_metadata_only"
      ],
      "properties": {
        "deterministic_from_filled_repair_patch": {
          "const": true
        },
        "no_urls_opened": {
          "const": true
        },
        "no_locator_resolution_run": {
          "const": true
        },
        "no_capture_assets_produced": {
          "const": true
        },
        "planned_outputs_only": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "repaired_executable_slot_count",
        "unavailable_source_slot_count",
        "previous_failed_executable_slot_count",
        "read_only_context_entry_count",
        "accepted_capture_count",
        "promoted_capture_count",
        "actual_capture_file_count",
        "planned_output_slot_count",
        "full_page_grab_count"
      ],
      "properties": {
        "repaired_executable_slot_count": {
          "const": 4
        },
        "unavailable_source_slot_count": {
          "const": 1
        },
        "previous_failed_executable_slot_count": {
          "const": 5
        },
        "read_only_context_entry_count": {
          "const": 14
        },
        "accepted_capture_count": {
          "const": 0
        },
        "promoted_capture_count": {
          "const": 0
        },
        "actual_capture_file_count": {
          "const": 0
        },
        "planned_output_slot_count": {
          "const": 4
        },
        "full_page_grab_count": {
          "const": 0
        }
      },
      "additionalProperties": false
    },
    "locator": {
      "type": "object",
      "required": [
        "selector",
        "xpath",
        "playwright_locator"
      ],
      "properties": {
        "selector": {
          "$ref": "#/$defs/nullable_string"
        },
        "xpath": {
          "$ref": "#/$defs/nullable_string"
        },
        "playwright_locator": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "planned_output": {
      "type": "object",
      "required": [
        "slot_id",
        "clip_path",
        "text_extract_path",
        "full_page_grab"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "clip_path": {
          "const": null
        },
        "text_extract_path": {
          "const": null
        },
        "full_page_grab": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "repaired_slot": {
      "type": "object",
      "required": [
        "slot_id",
        "failure_id",
        "target_id",
        "work_unit_id",
        "executable",
        "status",
        "company",
        "source_category",
        "original_url",
        "final_url",
        "natural_language_target",
        "evidence_goal",
        "kilos_relevance",
        "expected_clip_count",
        "original_failed_locator",
        "repaired_locator",
        "failure_provenance",
        "planned_outputs",
        "full_page_grab"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "failure_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "executable": {
          "const": true
        },
        "status": {
          "const": "repaired_locator_ready_for_capture_attempt"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "original_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "natural_language_target": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_goal": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kilos_relevance": {
          "type": "array"
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 1
        },
        "original_failed_locator": {
          "type": "object"
        },
        "repaired_locator": {
          "$ref": "#/$defs/locator"
        },
        "failure_provenance": {
          "type": "object"
        },
        "planned_outputs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "$ref": "#/$defs/planned_output"
          }
        },
        "full_page_grab": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "unavailable_slot": {
      "type": "object",
      "required": [
        "slot_id",
        "failure_id",
        "target_id",
        "work_unit_id",
        "executable",
        "status",
        "source_unavailable_reason",
        "repaired_locator",
        "planned_outputs",
        "full_page_grab"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "failure_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "executable": {
          "const": false
        },
        "status": {
          "const": "source_unavailable"
        },
        "source_unavailable_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "repaired_locator": {
          "$ref": "#/$defs/locator"
        },
        "planned_outputs": {
          "type": "array",
          "maxItems": 0
        },
        "full_page_grab": {
          "const": false
        }
      },
      "additionalProperties": true
    },
    "planned_output_manifest": {
      "type": "object",
      "required": [
        "status",
        "expected_clip_count",
        "expected_text_extract_count",
        "slots",
        "contains_actual_captures"
      ],
      "properties": {
        "status": {
          "const": "planned_only_empty"
        },
        "expected_clip_count": {
          "const": 4
        },
        "expected_text_extract_count": {
          "const": 4
        },
        "slots": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/planned_output"
          }
        },
        "contains_actual_captures": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  }
}
