{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-reviewed-locator-capture-plan-v0.schema.json",
  "title": "Employer Brand Reviewed Locator Capture Plan v0",
  "description": "Pre-capture plan for live evidence targets with human-approved locators. V0 creates executable capture units only for reviewed locator_ready targets, preserves unresolved, blocked, and rejected targets as non-executable context, defines planned output slots, and does not open URLs, resolve locators, execute codegen, capture screenshots, create clips, extract text, render reports, export files, run workflows, grab full pages, crawl, or bypass controls.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "capture_ordering",
    "retry_policy",
    "executable_units",
    "non_executable_context",
    "planned_output_manifest",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_reviewed_locator_capture_plan"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-reviewed-locator-capture-plan-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "const": "pre_capture_plan_ready_with_non_executable_context"
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "capture_ordering": {
      "$ref": "#/$defs/capture_ordering"
    },
    "retry_policy": {
      "$ref": "#/$defs/retry_policy"
    },
    "executable_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/executable_unit"
      }
    },
    "non_executable_context": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_executable_context"
      }
    },
    "planned_output_manifest": {
      "$ref": "#/$defs/planned_output_manifest"
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "kilos_relevance": {
      "type": "array",
      "items": {
        "enum": [
          "kinship",
          "impact",
          "lifestyle",
          "opportunity",
          "status"
        ]
      },
      "uniqueItems": true
    },
    "source_refs": {
      "type": "object",
      "required": [
        "reviewed_locator_readiness_id",
        "reviewed_locator_readiness_path",
        "reviewed_locator_readiness_schema",
        "human_locator_approval_patch_id",
        "human_locator_approval_patch_path",
        "human_locator_approval_patch_schema",
        "human_locator_review_pack_id",
        "human_locator_review_pack_path",
        "url_open_run_id",
        "url_open_run_path",
        "reviewed_target_plan_id",
        "reviewed_target_plan_path",
        "data_bundle_id",
        "data_bundle_path"
      ],
      "properties": {
        "reviewed_locator_readiness_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewed_locator_readiness_path": {
          "const": "live-evidence-locator-readiness.reviewed.json"
        },
        "reviewed_locator_readiness_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-locator-readiness-v0.schema.json"
        },
        "human_locator_approval_patch_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "human_locator_approval_patch_path": {
          "const": "live-evidence-human-locator-approval-patch.json"
        },
        "human_locator_approval_patch_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-human-locator-approval-patch-v0.schema.json"
        },
        "human_locator_review_pack_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "human_locator_review_pack_path": {
          "const": "live-evidence-human-locator-review-pack.json"
        },
        "url_open_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "url_open_run_path": {
          "const": "live-evidence-url-open-run.json"
        },
        "reviewed_target_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewed_target_plan_path": {
          "const": "live-evidence-target-plan.reviewed.json"
        },
        "data_bundle_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "data_bundle_path": {
          "const": "data-bundle.json"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "reviewed_readiness_target_count",
        "executable_unit_count",
        "expected_ready_clip_count",
        "planned_output_slot_count",
        "non_executable_context_count",
        "needs_locator_count",
        "needs_human_locator_review_count",
        "blocked_count",
        "rejected_count",
        "grouped_by_company",
        "grouped_non_executable_by_category"
      ],
      "properties": {
        "reviewed_readiness_target_count": {
          "type": "integer",
          "minimum": 1
        },
        "executable_unit_count": {
          "const": 4
        },
        "expected_ready_clip_count": {
          "const": 5
        },
        "planned_output_slot_count": {
          "const": 5
        },
        "non_executable_context_count": {
          "const": 14
        },
        "needs_locator_count": {
          "const": 11
        },
        "needs_human_locator_review_count": {
          "const": 1
        },
        "blocked_count": {
          "const": 1
        },
        "rejected_count": {
          "const": 1
        },
        "grouped_by_company": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "grouped_non_executable_by_category": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    },
    "capture_ordering": {
      "type": "object",
      "required": [
        "strategy",
        "order_is_deterministic",
        "executable_work_unit_ids",
        "stop_after_each_unit_for_human_review"
      ],
      "properties": {
        "strategy": {
          "$ref": "#/$defs/non_empty_string"
        },
        "order_is_deterministic": {
          "const": true
        },
        "executable_work_unit_ids": {
          "$ref": "#/$defs/string_array"
        },
        "stop_after_each_unit_for_human_review": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "retry_policy": {
      "type": "object",
      "required": [
        "automatic_retries_authorized",
        "max_manual_retry_attempts_per_unit",
        "retry_requires_human_reapproval",
        "retryable_conditions",
        "stop_conditions"
      ],
      "properties": {
        "automatic_retries_authorized": {
          "const": false
        },
        "max_manual_retry_attempts_per_unit": {
          "type": "integer",
          "minimum": 0
        },
        "retry_requires_human_reapproval": {
          "const": true
        },
        "retryable_conditions": {
          "$ref": "#/$defs/string_array"
        },
        "stop_conditions": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "reviewed_locator": {
      "type": "object",
      "required": [
        "selector",
        "xpath",
        "playwright_locator"
      ],
      "properties": {
        "selector": {
          "$ref": "#/$defs/nullable_string"
        },
        "xpath": {
          "$ref": "#/$defs/nullable_string"
        },
        "playwright_locator": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "planned_output_slot": {
      "type": "object",
      "required": [
        "slot_id",
        "target_id",
        "work_unit_id",
        "ordinal",
        "planned_clip_id",
        "planned_text_extract_id",
        "clip_path",
        "text_extract_path",
        "acceptance_status"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 1
        },
        "planned_clip_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "planned_text_extract_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "clip_path": {
          "const": null
        },
        "text_extract_path": {
          "const": null
        },
        "acceptance_status": {
          "const": "not_run"
        }
      },
      "additionalProperties": false
    },
    "executable_unit": {
      "type": "object",
      "required": [
        "target_id",
        "work_unit_id",
        "execution_order",
        "executable",
        "company",
        "company_role",
        "source_category",
        "original_url",
        "final_url",
        "reviewed_locator",
        "locator_review",
        "capture_type",
        "expected_clip_count",
        "kilos_relevance",
        "citation_source_metadata",
        "acceptance_criteria",
        "output_manifest_slot_ids",
        "planned_outputs",
        "safety_gates",
        "stop_conditions",
        "provenance"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "execution_order": {
          "type": "integer",
          "minimum": 1
        },
        "executable": {
          "const": true
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "original_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewed_locator": {
          "$ref": "#/$defs/reviewed_locator"
        },
        "locator_review": {
          "type": "object"
        },
        "capture_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 1
        },
        "kilos_relevance": {
          "$ref": "#/$defs/kilos_relevance"
        },
        "citation_source_metadata": {
          "type": "object"
        },
        "acceptance_criteria": {
          "$ref": "#/$defs/string_array"
        },
        "output_manifest_slot_ids": {
          "$ref": "#/$defs/string_array"
        },
        "planned_outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/planned_output_slot"
          }
        },
        "safety_gates": {
          "$ref": "#/$defs/string_array"
        },
        "stop_conditions": {
          "$ref": "#/$defs/string_array"
        },
        "provenance": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "non_executable_context": {
      "type": "object",
      "required": [
        "context_id",
        "target_id",
        "work_unit_id",
        "executable",
        "category",
        "readiness_state",
        "approval_decision",
        "human_locator_decision",
        "company",
        "company_role",
        "source_category",
        "original_url",
        "final_url",
        "capture_type",
        "expected_clip_count",
        "blockers",
        "required_next_action",
        "output_manifest_slot_ids",
        "provenance"
      ],
      "properties": {
        "context_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "executable": {
          "const": false
        },
        "category": {
          "enum": [
            "needs_locator",
            "needs_human_locator_review",
            "blocked",
            "rejected"
          ]
        },
        "readiness_state": {
          "$ref": "#/$defs/non_empty_string"
        },
        "approval_decision": {
          "$ref": "#/$defs/nullable_string"
        },
        "human_locator_decision": {
          "$ref": "#/$defs/nullable_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "original_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "final_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "capture_type": {
          "$ref": "#/$defs/nullable_string"
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "blockers": {
          "$ref": "#/$defs/string_array"
        },
        "required_next_action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "output_manifest_slot_ids": {
          "type": "array",
          "maxItems": 0
        },
        "provenance": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "planned_output_manifest": {
      "type": "object",
      "required": [
        "status",
        "expected_clip_count",
        "expected_text_extract_count",
        "slots",
        "contains_actual_captures"
      ],
      "properties": {
        "status": {
          "const": "planned_only_empty"
        },
        "expected_clip_count": {
          "const": 5
        },
        "expected_text_extract_count": {
          "const": 5
        },
        "slots": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/planned_output_slot"
          }
        },
        "contains_actual_captures": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "pre_capture_plan_only",
        "human_approved_locators_required",
        "url_opening_authorized",
        "locator_resolution_authorized",
        "codegen_execution_authorized",
        "screenshot_capture_authorized",
        "element_clip_generation_authorized",
        "text_extraction_authorized",
        "capture_execution_authorized",
        "full_page_grabs_authorized",
        "autonomous_crawl_authorized",
        "report_renderer_authorized",
        "export_execution_authorized",
        "workflow_engine_authorized"
      ],
      "properties": {
        "pre_capture_plan_only": {
          "const": true
        },
        "human_approved_locators_required": {
          "const": true
        },
        "url_opening_authorized": {
          "const": false
        },
        "locator_resolution_authorized": {
          "const": false
        },
        "codegen_execution_authorized": {
          "const": false
        },
        "screenshot_capture_authorized": {
          "const": false
        },
        "element_clip_generation_authorized": {
          "const": false
        },
        "text_extraction_authorized": {
          "const": false
        },
        "capture_execution_authorized": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        },
        "autonomous_crawl_authorized": {
          "const": false
        },
        "report_renderer_authorized": {
          "const": false
        },
        "export_execution_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "reviewed_locator_readiness_is_input_source",
        "executable_only_for_locator_ready_targets",
        "unresolved_targets_preserved_as_non_executable_context",
        "rejected_targets_preserved_as_non_executable_context",
        "planned_outputs_only",
        "no_capture_assets_produced",
        "planning_metadata_only",
        "read_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "reviewed_locator_readiness_is_input_source": {
          "const": true
        },
        "executable_only_for_locator_ready_targets": {
          "const": true
        },
        "unresolved_targets_preserved_as_non_executable_context": {
          "const": true
        },
        "rejected_targets_preserved_as_non_executable_context": {
          "const": true
        },
        "planned_outputs_only": {
          "const": true
        },
        "no_capture_assets_produced": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
