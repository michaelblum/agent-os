{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-locator-resolution-result-v0.schema.json",
  "title": "Employer Brand Live Evidence Locator Resolution Result v0",
  "description": "Supervised, gated locator resolution result for approved live evidence URL-open targets. It records deterministic locator candidates only for reachable same-domain targets and forbids screenshots, element clips, report rendering, exports, workflow execution, full-page grabs, crawling, and blocker bypass.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "results",
    "rejected_exclusions",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_locator_resolution_result"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-locator-resolution-result-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "not_run_fixture",
        "completed",
        "completed_with_blockers"
      ]
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "rejected_exclusions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rejected_exclusion"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_refs": {
      "type": "object",
      "required": [
        "supervised_locator_plan_id",
        "supervised_locator_plan_path",
        "supervised_locator_plan_schema",
        "url_open_run_id",
        "url_open_run_path",
        "url_open_run_schema"
      ],
      "properties": {
        "supervised_locator_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supervised_locator_plan_path": {
          "const": "live-evidence-supervised-locator-plan.json"
        },
        "supervised_locator_plan_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-supervised-locator-plan-v0.schema.json"
        },
        "url_open_run_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "url_open_run_path": {
          "const": "live-evidence-url-open-run.json"
        },
        "url_open_run_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-url-open-run-v0.schema.json"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "result_count",
        "attempted_count",
        "resolved_count",
        "ambiguous_count",
        "not_found_count",
        "blocked_count",
        "not_run_count",
        "locator_ready_count",
        "needs_human_locator_review_count",
        "eligible_target_count",
        "rejected_exclusion_count",
        "confidence_threshold"
      ],
      "properties": {
        "result_count": {
          "type": "integer",
          "minimum": 1
        },
        "attempted_count": {
          "type": "integer",
          "minimum": 0
        },
        "resolved_count": {
          "type": "integer",
          "minimum": 0
        },
        "ambiguous_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_found_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_run_count": {
          "type": "integer",
          "minimum": 0
        },
        "locator_ready_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_human_locator_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "eligible_target_count": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_exclusion_count": {
          "type": "integer",
          "minimum": 0
        },
        "confidence_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": [
        "result_id",
        "target_id",
        "work_unit_id",
        "company",
        "source_category",
        "original_url",
        "final_url",
        "url_open_status",
        "same_domain",
        "attempted",
        "resolution_status",
        "selector_candidates",
        "preferred_selector",
        "playwright_locator_candidate",
        "confidence",
        "blocker_reason",
        "reviewed_by",
        "operator_notes",
        "resolved_at",
        "locator_provenance",
        "provenance"
      ],
      "properties": {
        "result_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "original_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "url_open_status": {
          "$ref": "#/$defs/non_empty_string"
        },
        "same_domain": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "attempted": {
          "type": "boolean"
        },
        "resolution_status": {
          "enum": [
            "resolved",
            "ambiguous",
            "not_found",
            "blocked",
            "not_run"
          ]
        },
        "selector_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/selector_candidate"
          }
        },
        "preferred_selector": {
          "$ref": "#/$defs/nullable_string"
        },
        "playwright_locator_candidate": {
          "$ref": "#/$defs/nullable_string"
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "blocker_reason": {
          "$ref": "#/$defs/nullable_string"
        },
        "reviewed_by": {
          "$ref": "#/$defs/nullable_string"
        },
        "operator_notes": {
          "$ref": "#/$defs/nullable_string"
        },
        "resolved_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "locator_provenance": {
          "$ref": "#/$defs/non_empty_string"
        },
        "provenance": {
          "$ref": "#/$defs/result_provenance"
        }
      },
      "additionalProperties": false
    },
    "selector_candidate": {
      "type": "object",
      "required": [
        "selector",
        "playwright_locator",
        "selector_type",
        "confidence",
        "rationale",
        "provenance"
      ],
      "properties": {
        "selector": {
          "$ref": "#/$defs/nullable_string"
        },
        "playwright_locator": {
          "$ref": "#/$defs/nullable_string"
        },
        "selector_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "$ref": "#/$defs/nullable_string"
        },
        "provenance": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "rejected_exclusion": {
      "type": "object",
      "required": [
        "target_id",
        "decision",
        "reason",
        "source_approval_patch_path",
        "resolution_status",
        "blocker_reason"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "const": "reject"
        },
        "reason": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_approval_patch_path": {
          "const": "live-evidence-target-approval-patch.json"
        },
        "resolution_status": {
          "const": "not_run"
        },
        "blocker_reason": {
          "const": "rejected_target_excluded_before_url_open"
        }
      },
      "additionalProperties": false
    },
    "result_provenance": {
      "type": "object",
      "required": [
        "source_supervised_locator_plan_work_unit_id",
        "source_url_open_result_id",
        "locator_metadata_only",
        "no_screenshots",
        "no_element_clips",
        "no_report_or_export",
        "no_workflow_execution",
        "no_full_page_grabs"
      ],
      "properties": {
        "source_supervised_locator_plan_work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_url_open_result_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "locator_metadata_only": {
          "const": true
        },
        "no_screenshots": {
          "const": true
        },
        "no_element_clips": {
          "const": true
        },
        "no_report_or_export": {
          "const": true
        },
        "no_workflow_execution": {
          "const": true
        },
        "no_full_page_grabs": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "explicit_execution_gate_required",
        "locator_resolution_authorized",
        "locator_resolution_executed",
        "screenshots_authorized",
        "element_clips_authorized",
        "text_extraction_authorized",
        "report_renderer_authorized",
        "export_execution_authorized",
        "workflow_engine_authorized",
        "full_page_grabs_authorized",
        "autonomous_crawl_authorized",
        "login_bypass_authorized",
        "paywall_bypass_authorized",
        "captcha_bypass_authorized",
        "consent_bypass_authorized"
      ],
      "properties": {
        "explicit_execution_gate_required": {
          "const": true
        },
        "locator_resolution_authorized": {
          "type": "boolean"
        },
        "locator_resolution_executed": {
          "type": "boolean"
        },
        "screenshots_authorized": {
          "const": false
        },
        "element_clips_authorized": {
          "const": false
        },
        "text_extraction_authorized": {
          "const": false
        },
        "report_renderer_authorized": {
          "const": false
        },
        "export_execution_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        },
        "autonomous_crawl_authorized": {
          "const": false
        },
        "login_bypass_authorized": {
          "const": false
        },
        "paywall_bypass_authorized": {
          "const": false
        },
        "captcha_bypass_authorized": {
          "const": false
        },
        "consent_bypass_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "url_open_run_is_input_source",
        "supervised_locator_plan_is_input_source",
        "injectable_resolver_used",
        "read_only_planning_evidence",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "url_open_run_is_input_source": {
          "const": true
        },
        "supervised_locator_plan_is_input_source": {
          "const": true
        },
        "injectable_resolver_used": {
          "type": "boolean"
        },
        "read_only_planning_evidence": {
          "const": true
        },
        "non_goals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
