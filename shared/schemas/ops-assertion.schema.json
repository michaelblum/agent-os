{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/ops-assertion.schema.json",
  "title": "AOS Ops Structured Assertion",
  "description": "Small in-tree matcher for ops recipes. This is intentionally not JSONPath or jq.",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    { "required": ["path"] },
    { "required": ["select"] }
  ],
  "properties": {
    "path": { "$ref": "#/$defs/Path" },
    "select": {
      "type": "object",
      "required": ["path", "where"],
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/Path" },
        "where": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/Scalar" }
        }
      }
    },
    "field": { "$ref": "#/$defs/Path" },
    "exists": { "type": "boolean" },
    "not_exists": { "type": "boolean" },
    "equals": { "$ref": "#/$defs/JSONValue" },
    "contains": { "$ref": "#/$defs/JSONValue" },
    "allow_many": { "type": "boolean", "default": false }
  },
  "allOf": [
    {
      "oneOf": [
        { "required": ["exists"] },
        { "required": ["not_exists"] },
        { "required": ["equals"] },
        { "required": ["contains"] }
      ]
    },
    {
      "not": {
        "anyOf": [
          { "required": ["exists", "not_exists"] },
          { "required": ["exists", "equals"] },
          { "required": ["exists", "contains"] },
          { "required": ["not_exists", "equals"] },
          { "required": ["not_exists", "contains"] },
          { "required": ["equals", "contains"] }
        ]
      }
    }
  ],
  "$defs": {
    "Path": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "Scalar": {
      "type": ["string", "number", "integer", "boolean", "null"]
    },
    "JSONValue": {
      "anyOf": [
        { "type": "string" },
        { "type": "integer" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/JSONValue" } },
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/JSONValue" } }
      ]
    }
  }
}
