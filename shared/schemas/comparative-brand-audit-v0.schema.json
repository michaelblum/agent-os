{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/comparative-brand-audit-v0.schema.json",
  "title": "Comparative Brand Audit v0",
  "description": "Pilot schema for a local-fixture Comparative Employer Brand Audit through the KILOS lens. V0 composes existing Company Brand Audit fixtures and Browser Evidence request IDs.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "audit_id",
    "scope",
    "companies",
    "source_company_audits",
    "comparative_synthesis",
    "shared_themes",
    "key_differentiators",
    "whitespace_opportunities",
    "kilos_positioning_matrix",
    "review_site_comparison",
    "standout_engagement_examples",
    "implications_for_client",
    "evidence_backed_claims",
    "caveats",
    "citations",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.comparative_brand_audit"
    },
    "schema_version": {
      "const": "2026-05-comparative-brand-audit-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "audit_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "companies": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/company_reference"
      }
    },
    "source_company_audits": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/source_company_audit"
      }
    },
    "comparative_synthesis": {
      "$ref": "#/$defs/synthesis"
    },
    "shared_themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/shared_theme"
      }
    },
    "key_differentiators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/company_note"
      }
    },
    "whitespace_opportunities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/whitespace_opportunity"
      }
    },
    "kilos_positioning_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/kilos_matrix_entry"
      }
    },
    "review_site_comparison": {
      "$ref": "#/$defs/review_site_comparison"
    },
    "standout_engagement_examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/engagement_example"
      }
    },
    "implications_for_client": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/client_implication"
      }
    },
    "evidence_backed_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_backed_claim"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "default": []
    },
    "citations": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/citation"
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "default": []
    },
    "company_audit_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "request_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true,
      "default": []
    },
    "required_request_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "company_role": {
      "enum": [
        "client",
        "competitor"
      ]
    },
    "kilos_dimension": {
      "enum": [
        "kinship",
        "impact",
        "lifestyle",
        "opportunity",
        "status"
      ]
    },
    "scope": {
      "type": "object",
      "required": [
        "framework",
        "evidence_scope",
        "company_audit_scope",
        "registry_path",
        "local_fixture_evidence_only",
        "live_websites",
        "report_generation"
      ],
      "properties": {
        "framework": {
          "const": "KILOS"
        },
        "evidence_scope": {
          "const": "local_fixture_company_brand_audits"
        },
        "company_audit_scope": {
          "const": "local_fixture_browser_evidence"
        },
        "registry_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "local_fixture_evidence_only": {
          "const": true
        },
        "live_websites": {
          "const": false
        },
        "report_generation": {
          "const": false
        },
        "notes": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "company_reference": {
      "type": "object",
      "required": [
        "name",
        "role",
        "company_audit_id"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "$ref": "#/$defs/company_role"
        },
        "company_audit_id": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "source_company_audit": {
      "type": "object",
      "required": [
        "id",
        "company",
        "role",
        "path",
        "request_ids"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "$ref": "#/$defs/company_role"
        },
        "path": {
          "type": "string",
          "pattern": "^company-audits/.+\\.json$"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "synthesis": {
      "type": "object",
      "required": [
        "summary",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "shared_theme": {
      "type": "object",
      "required": [
        "theme",
        "summary",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "theme": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "company_note": {
      "type": "object",
      "required": [
        "company",
        "summary",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "whitespace_opportunity": {
      "type": "object",
      "required": [
        "opportunity",
        "rationale",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "opportunity": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rationale": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "kilos_matrix_entry": {
      "type": "object",
      "required": [
        "dimension",
        "client_read",
        "competitor_reads",
        "synthesis",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/kilos_dimension"
        },
        "client_read": {
          "$ref": "#/$defs/non_empty_string"
        },
        "competitor_reads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/competitor_read"
          },
          "default": []
        },
        "synthesis": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        }
      },
      "additionalProperties": false
    },
    "competitor_read": {
      "type": "object",
      "required": [
        "company",
        "read",
        "company_audit_id",
        "request_ids"
      ],
      "properties": {
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "read": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        }
      },
      "additionalProperties": false
    },
    "review_site_comparison": {
      "type": "object",
      "required": [
        "coverage_status",
        "summary",
        "company_audit_ids",
        "request_ids",
        "caveat"
      ],
      "properties": {
        "coverage_status": {
          "enum": [
            "sufficient",
            "weak",
            "unavailable",
            "blocked",
            "not_applicable"
          ]
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        },
        "caveat": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "engagement_example": {
      "type": "object",
      "required": [
        "company",
        "example",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "example": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "client_implication": {
      "type": "object",
      "required": [
        "implication",
        "summary",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "implication": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "evidence_backed_claim": {
      "type": "object",
      "required": [
        "id",
        "claim",
        "company_audit_ids",
        "request_ids"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "citation": {
      "type": "object",
      "required": [
        "company_audit_id",
        "company",
        "role",
        "request_ids"
      ],
      "properties": {
        "company_audit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "$ref": "#/$defs/company_role"
        },
        "request_ids": {
          "$ref": "#/$defs/required_request_ids"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "derived_from_company_audit_ids",
        "derived_from_company_audit_paths",
        "derived_from_registry",
        "browser_evidence_request_ids",
        "local_fixture_evidence_only",
        "live_websites",
        "report_generation",
        "provenance_only",
        "read_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/date_time"
        },
        "derived_from_company_audit_ids": {
          "$ref": "#/$defs/company_audit_ids"
        },
        "derived_from_company_audit_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^company-audits/.+\\.json$"
          },
          "uniqueItems": true
        },
        "derived_from_registry": {
          "$ref": "#/$defs/non_empty_string"
        },
        "browser_evidence_request_ids": {
          "$ref": "#/$defs/required_request_ids"
        },
        "local_fixture_evidence_only": {
          "const": true
        },
        "live_websites": {
          "const": false
        },
        "report_generation": {
          "const": false
        },
        "provenance_only": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
