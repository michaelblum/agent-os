{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/dev-test-proof-registry.schema.json",
  "title": "AOS Dev Test Proof Registry",
  "description": "Maintainer registry for proof-worth routing of touched executable tests, helpers, fixtures, and proof assets.",
  "type": "object",
  "required": ["schema_version", "summary", "entries"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "id",
        "path_patterns",
        "owner",
        "harness_level",
        "proof_kind",
        "contract",
        "worth",
        "command",
        "replaces",
        "guard",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "fixture_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "harness_level": {
          "enum": [
            "model_unit",
            "schema",
            "shell_router",
            "isolated_daemon",
            "shared_repo_daemon",
            "visual_harness",
            "status_item_owner_click",
            "guarded_live",
            "real_input",
            "manual",
            "proof_report"
          ]
        },
        "proof_kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "contract": {
          "type": "string",
          "minLength": 1
        },
        "worth": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "replaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "guard": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["active", "manual_only", "quarantined", "retired"]
        }
      }
    }
  }
}
