{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/company-brand-audit-v0.schema.json",
  "title": "Company Brand Audit v0",
  "description": "Pilot schema for a local-fixture Company Employer Brand Audit through the KILOS lens. V0 is scoped to browser evidence already present in an artifact bundle registry.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "audit_id",
    "company",
    "scope",
    "source_coverage_summary",
    "employer_value_proposition",
    "main_promise",
    "kilos_analysis",
    "messaging_themes",
    "brand_voice_and_tone",
    "visual_identity_notes",
    "employee_sentiment_and_review_sites",
    "differentiators",
    "generic_messaging_or_weak_spots",
    "evidence_backed_claims",
    "caveats",
    "cited_evidence",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.company_brand_audit"
    },
    "schema_version": {
      "const": "2026-05-company-brand-audit-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "audit_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "company": {
      "$ref": "#/$defs/company"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "source_coverage_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_coverage"
      }
    },
    "employer_value_proposition": {
      "$ref": "#/$defs/non_empty_string"
    },
    "main_promise": {
      "$ref": "#/$defs/non_empty_string"
    },
    "kilos_analysis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/kilos_analysis"
      }
    },
    "messaging_themes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/theme"
      },
      "default": []
    },
    "brand_voice_and_tone": {
      "$ref": "#/$defs/voice_tone"
    },
    "visual_identity_notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysis_note"
      },
      "default": []
    },
    "employee_sentiment_and_review_sites": {
      "$ref": "#/$defs/review_summary"
    },
    "differentiators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysis_note"
      },
      "default": []
    },
    "generic_messaging_or_weak_spots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysis_note"
      },
      "default": []
    },
    "evidence_backed_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_backed_claim"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "default": []
    },
    "cited_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_citation"
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "default": []
    },
    "request_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "uniqueItems": true,
      "default": []
    },
    "kilos_dimension": {
      "enum": [
        "kinship",
        "impact",
        "lifestyle",
        "opportunity",
        "status"
      ]
    },
    "company": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "enum": [
            "client",
            "competitor"
          ]
        },
        "notes": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": [
        "framework",
        "evidence_scope",
        "registry_path",
        "local_fixture_evidence_only",
        "live_websites",
        "report_generation"
      ],
      "properties": {
        "framework": {
          "const": "KILOS"
        },
        "evidence_scope": {
          "const": "local_fixture_browser_evidence"
        },
        "registry_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "local_fixture_evidence_only": {
          "const": true
        },
        "live_websites": {
          "const": false
        },
        "report_generation": {
          "const": false
        },
        "notes": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "source_coverage": {
      "type": "object",
      "required": [
        "source_category",
        "coverage_status",
        "request_ids",
        "summary"
      ],
      "properties": {
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "coverage_status": {
          "enum": [
            "captured_from_local_fixture",
            "not_collected_in_fixture",
            "sufficient",
            "weak",
            "unavailable",
            "blocked",
            "not_applicable"
          ]
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "analysis_note": {
      "type": "object",
      "required": [
        "summary",
        "request_ids"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        }
      },
      "additionalProperties": false
    },
    "kilos_analysis": {
      "type": "object",
      "required": [
        "dimension",
        "factors",
        "interpretation",
        "request_ids"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/kilos_dimension"
        },
        "factors": {
          "$ref": "#/$defs/string_array"
        },
        "interpretation": {
          "$ref": "#/$defs/non_empty_string"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        }
      },
      "additionalProperties": false
    },
    "theme": {
      "type": "object",
      "required": [
        "theme",
        "summary",
        "request_ids"
      ],
      "properties": {
        "theme": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        }
      },
      "additionalProperties": false
    },
    "voice_tone": {
      "type": "object",
      "required": [
        "summary",
        "descriptors",
        "request_ids"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "descriptors": {
          "$ref": "#/$defs/string_array"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        }
      },
      "additionalProperties": false
    },
    "review_summary": {
      "type": "object",
      "required": [
        "coverage_status",
        "summary",
        "request_ids",
        "caveat"
      ],
      "properties": {
        "coverage_status": {
          "enum": [
            "sufficient",
            "weak",
            "unavailable",
            "blocked",
            "not_applicable"
          ]
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "request_ids": {
          "$ref": "#/$defs/request_ids"
        },
        "caveat": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "evidence_backed_claim": {
      "type": "object",
      "required": [
        "id",
        "claim",
        "request_ids"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim": {
          "$ref": "#/$defs/non_empty_string"
        },
        "request_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "evidence_citation": {
      "type": "object",
      "required": [
        "request_id",
        "company",
        "source_category",
        "source_url",
        "screenshot_path",
        "status",
        "captured_at",
        "extracted_text_excerpt"
      ],
      "properties": {
        "request_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "screenshot_path": {
          "type": "string",
          "pattern": "^screenshots/.+\\.png$"
        },
        "status": {
          "const": "captured"
        },
        "captured_at": {
          "$ref": "#/$defs/date_time"
        },
        "extracted_text_excerpt": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "derived_from_registry",
        "browser_evidence_request_ids",
        "screenshot_paths",
        "local_fixture_pages_only",
        "live_websites",
        "provenance_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/date_time"
        },
        "derived_from_registry": {
          "$ref": "#/$defs/non_empty_string"
        },
        "browser_evidence_request_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        },
        "screenshot_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^screenshots/.+\\.png$"
          },
          "uniqueItems": true
        },
        "local_fixture_pages_only": {
          "const": true
        },
        "live_websites": {
          "const": false
        },
        "provenance_only": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
