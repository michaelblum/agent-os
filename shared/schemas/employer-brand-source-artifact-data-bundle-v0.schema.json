{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-source-artifact-data-bundle-v0.schema.json",
  "title": "Employer Brand Source Artifact Data Bundle v0",
  "description": "Read-only data bundle that groups source artifacts with a hand-authored source artifact target plan before any Employer Brand report renderer or export artifact exists.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_artifacts",
    "target_plan",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_source_artifact_data_bundle"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-source-artifact-data-bundle-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "data_bundle_ready",
        "reviewed",
        "archived"
      ]
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_artifact"
      },
      "uniqueItems": true
    },
    "target_plan": {
      "$ref": "#/$defs/target_plan_ref"
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      },
      "default": []
    },
    "source_artifact": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "path",
        "role",
        "capture_input",
        "metadata"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "enum": [
            "pptx",
            "pdf",
            "html_spa"
          ]
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capture_input": {
          "type": "boolean"
        },
        "metadata": {
          "type": "object",
          "required": [
            "description",
            "local_only",
            "read_only"
          ],
          "properties": {
            "description": {
              "$ref": "#/$defs/non_empty_string"
            },
            "page_count": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "slide_count": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "entry_title": {
              "$ref": "#/$defs/nullable_string"
            },
            "local_only": {
              "const": true
            },
            "read_only": {
              "const": true
            },
            "notes": {
              "$ref": "#/$defs/nullable_string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "target_plan_ref": {
      "type": "object",
      "required": [
        "id",
        "path",
        "schema",
        "target_count",
        "expected_clip_count",
        "full_page_grabs",
        "selectors_ready",
        "xpath_ready",
        "playwright_ready",
        "codegen_ready"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "schema": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 1
        },
        "full_page_grabs": {
          "const": false
        },
        "selectors_ready": {
          "const": false
        },
        "xpath_ready": {
          "const": false
        },
        "playwright_ready": {
          "const": false
        },
        "codegen_ready": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "report_renderer_authorized",
        "report_artifact_authorized",
        "export_execution_authorized",
        "remote_web_collection_authorized",
        "workflow_engine_authorized"
      ],
      "properties": {
        "report_renderer_authorized": {
          "const": false
        },
        "report_artifact_authorized": {
          "const": false
        },
        "export_execution_authorized": {
          "const": false
        },
        "remote_web_collection_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "read_only",
        "provenance_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "read_only": {
          "const": true
        },
        "provenance_only": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
