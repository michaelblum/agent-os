{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-element-clip-acceptance-report-v0.schema.json",
  "title": "Employer Brand Element Clip Acceptance Report v0",
  "description": "Read-only verifier report for local SPv5 element clip acceptance. V0 validates metadata and checked-in files only; it does not perform capture, rendering, export, workflow execution, PDF/PPTX capture, live browser collection, or full-page grabs.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "inputs",
    "summary",
    "controls",
    "non_goal_flags",
    "manifest_count_checks",
    "results",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_element_clip_acceptance_report"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-element-clip-acceptance-report-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "accepted_with_blockers",
        "not_accepted"
      ]
    },
    "inputs": {
      "type": "object",
      "required": [
        "planning_bundle_path",
        "planning_bundle_schema",
        "clip_manifest_path",
        "clip_manifest_schema",
        "planned_clip_manifest_path",
        "comparative_audit_data_bundle_path",
        "comparative_audit_data_bundle_id"
      ],
      "properties": {
        "planning_bundle_path": {
          "const": "source-artifacts/element-capture-planning-bundle.json"
        },
        "planning_bundle_schema": {
          "const": "shared/schemas/employer-brand-element-capture-planning-bundle-v0.schema.json"
        },
        "clip_manifest_path": {
          "const": "source-artifacts/element-clip-manifest.json"
        },
        "clip_manifest_schema": {
          "const": "shared/schemas/employer-brand-element-clip-manifest-v0.schema.json"
        },
        "planned_clip_manifest_path": {
          "const": "source-artifacts/element-clip-manifest.planned.json"
        },
        "comparative_audit_data_bundle_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "comparative_audit_data_bundle_id": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "target_count",
        "work_unit_count",
        "expected_clip_count",
        "captured_count",
        "blocked_count",
        "failed_count",
        "not_run_count",
        "total_result_count",
        "accepted",
        "manifest_count_checks_passed"
      ],
      "properties": {
        "target_count": {
          "type": "integer",
          "minimum": 1
        },
        "work_unit_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 1
        },
        "captured_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_run_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_result_count": {
          "type": "integer",
          "minimum": 1
        },
        "accepted": {
          "type": "boolean"
        },
        "manifest_count_checks_passed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "non_goal_flags": {
      "$ref": "#/$defs/string_array"
    },
    "manifest_count_checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/work_unit_result"
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "json_object": {
      "type": "object"
    },
    "controls": {
      "type": "object",
      "required": [
        "read_only",
        "verifier_only",
        "capture_execution_authorized",
        "live_browser_collection_authorized",
        "remote_web_collection_authorized",
        "pdf_capture_execution_authorized",
        "pptx_capture_execution_authorized",
        "report_renderer_authorized",
        "export_execution_authorized",
        "workflow_engine_authorized",
        "full_page_grabs_authorized"
      ],
      "properties": {
        "read_only": {
          "const": true
        },
        "verifier_only": {
          "const": true
        },
        "capture_execution_authorized": {
          "const": false
        },
        "live_browser_collection_authorized": {
          "const": false
        },
        "remote_web_collection_authorized": {
          "const": false
        },
        "pdf_capture_execution_authorized": {
          "const": false
        },
        "pptx_capture_execution_authorized": {
          "const": false
        },
        "report_renderer_authorized": {
          "const": false
        },
        "export_execution_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "check": {
      "type": "object",
      "required": [
        "name",
        "status",
        "message",
        "evidence"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "not_applicable"
          ]
        },
        "message": {
          "$ref": "#/$defs/nullable_string"
        },
        "evidence": {
          "$ref": "#/$defs/json_object"
        }
      },
      "additionalProperties": false
    },
    "work_unit_result": {
      "type": "object",
      "required": [
        "work_unit_id",
        "target_id",
        "source_artifact_id",
        "source_artifact_kind",
        "company_ref_id",
        "capture_type",
        "readiness_state",
        "status",
        "clip_path",
        "text_extract_path",
        "blockers",
        "kilos_relevance",
        "acceptance_criteria",
        "checks"
      ],
      "properties": {
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_artifact_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_artifact_kind": {
          "$ref": "#/$defs/nullable_string"
        },
        "company_ref_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "capture_type": {
          "enum": [
            "element_clip",
            "element_text_extract",
            "element_clip_and_text_extract"
          ]
        },
        "readiness_state": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "enum": [
            "captured",
            "blocked",
            "failed",
            "not_run"
          ]
        },
        "clip_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "text_extract_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "blockers": {
          "$ref": "#/$defs/string_array"
        },
        "kilos_relevance": {
          "$ref": "#/$defs/string_array"
        },
        "acceptance_criteria": {
          "$ref": "#/$defs/string_array"
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "verifier",
        "read_only",
        "local_fixture_evidence_only",
        "no_capture_performed",
        "no_report_rendering_performed",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "verifier": {
          "$ref": "#/$defs/non_empty_string"
        },
        "read_only": {
          "const": true
        },
        "local_fixture_evidence_only": {
          "const": true
        },
        "no_capture_performed": {
          "const": true
        },
        "no_report_rendering_performed": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
