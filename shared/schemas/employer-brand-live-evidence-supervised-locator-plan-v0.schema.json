{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-supervised-locator-plan-v0.schema.json",
  "title": "Employer Brand Live Evidence Supervised Locator Plan v0",
  "description": "Operator-ready, planning-only supervised locator work plan for reviewed live evidence targets. It creates executable locator work units only for approved needs_locator targets, preserves draft or human-review targets as blocked entries, keeps output slots null, and does not perform URL checks, browsing, codegen, screenshots, live capture, clips, rendering, export, workflows, or full-page grabs.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "work_units",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_supervised_locator_plan"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-supervised-locator-plan-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "operator_plan_ready",
        "operator_plan_ready_with_blocked_entries"
      ]
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "work_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/work_unit"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "kilos_dimension": {
      "enum": [
        "kinship",
        "impact",
        "lifestyle",
        "opportunity",
        "status"
      ]
    },
    "source_refs": {
      "type": "object",
      "required": [
        "locator_readiness_id",
        "locator_readiness_path",
        "locator_readiness_schema",
        "reviewed_target_plan_id",
        "reviewed_target_plan_path",
        "reviewed_target_plan_schema",
        "approval_patch_id",
        "approval_patch_path",
        "data_bundle_id",
        "data_bundle_path"
      ],
      "properties": {
        "locator_readiness_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "locator_readiness_path": {
          "const": "live-evidence-locator-readiness.json"
        },
        "locator_readiness_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-locator-readiness-v0.schema.json"
        },
        "reviewed_target_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewed_target_plan_path": {
          "enum": [
            "live-evidence-target-plan.reviewed.json",
            "live-evidence-reviewed-target-plan.json"
          ]
        },
        "reviewed_target_plan_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-target-plan-v0.schema.json"
        },
        "approval_patch_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "approval_patch_path": {
          "const": "live-evidence-target-approval-patch.json"
        },
        "data_bundle_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "data_bundle_path": {
          "enum": [
            "data-bundle.json",
            null
          ]
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "readiness_input_count",
        "executable_locator_unit_count",
        "blocked_non_executable_count",
        "needs_human_target_review_count",
        "expected_clip_count_for_executable_units",
        "locator_ready_count",
        "url_checks_performed",
        "grouped_by_company",
        "executable_grouped_by_company"
      ],
      "properties": {
        "readiness_input_count": {
          "type": "integer",
          "minimum": 1
        },
        "executable_locator_unit_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_non_executable_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_human_target_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "expected_clip_count_for_executable_units": {
          "type": "integer",
          "minimum": 0
        },
        "locator_ready_count": {
          "const": 0
        },
        "url_checks_performed": {
          "const": false
        },
        "grouped_by_company": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "executable_grouped_by_company": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    },
    "work_unit": {
      "type": "object",
      "required": [
        "work_unit_id",
        "target_id",
        "executable",
        "blocked",
        "blockers",
        "company",
        "company_role",
        "source_category",
        "page_name",
        "url",
        "desired_element",
        "evidence_goal",
        "kilos_relevance",
        "capture_type",
        "expected_clip_count",
        "acceptance_criteria",
        "current_locator_placeholders",
        "required_operator_action",
        "allowed_outputs",
        "safety_gates",
        "stop_conditions",
        "provenance"
      ],
      "properties": {
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "executable": {
          "type": "boolean"
        },
        "blocked": {
          "type": "boolean"
        },
        "blockers": {
          "$ref": "#/$defs/string_array"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "page_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "desired_element": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_goal": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kilos_relevance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kilos_dimension"
          },
          "uniqueItems": true
        },
        "capture_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "acceptance_criteria": {
          "$ref": "#/$defs/string_array"
        },
        "current_locator_placeholders": {
          "$ref": "#/$defs/null_locator_placeholders"
        },
        "required_operator_action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "allowed_outputs": {
          "$ref": "#/$defs/null_allowed_outputs"
        },
        "safety_gates": {
          "$ref": "#/$defs/string_array"
        },
        "stop_conditions": {
          "$ref": "#/$defs/string_array"
        },
        "provenance": {
          "$ref": "#/$defs/work_unit_provenance"
        }
      },
      "additionalProperties": false
    },
    "null_locator_placeholders": {
      "type": "object",
      "required": [
        "selector",
        "xpath",
        "playwright_locator",
        "codegen_hint",
        "crawl_discovery_notes",
        "capture_script_slot"
      ],
      "properties": {
        "selector": {
          "const": null
        },
        "xpath": {
          "const": null
        },
        "playwright_locator": {
          "const": null
        },
        "codegen_hint": {
          "const": null
        },
        "crawl_discovery_notes": {
          "const": null
        },
        "capture_script_slot": {
          "const": null
        }
      },
      "additionalProperties": false
    },
    "null_allowed_outputs": {
      "type": "object",
      "required": [
        "selector",
        "xpath",
        "playwright_locator",
        "codegen_trace_path",
        "locator_notes",
        "confidence",
        "reviewer_metadata",
        "operator_metadata"
      ],
      "properties": {
        "selector": {
          "const": null
        },
        "xpath": {
          "const": null
        },
        "playwright_locator": {
          "const": null
        },
        "codegen_trace_path": {
          "const": null
        },
        "locator_notes": {
          "const": null
        },
        "confidence": {
          "const": null
        },
        "reviewer_metadata": {
          "const": null
        },
        "operator_metadata": {
          "const": null
        }
      },
      "additionalProperties": false
    },
    "work_unit_provenance": {
      "type": "object",
      "required": [
        "source_locator_readiness_path",
        "source_locator_readiness_target_id",
        "source_reviewed_target_plan_path",
        "source_approval_patch_path",
        "source_data_bundle_path",
        "source_index",
        "planning_metadata_only",
        "read_only"
      ],
      "properties": {
        "source_locator_readiness_path": {
          "const": "live-evidence-locator-readiness.json"
        },
        "source_locator_readiness_target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_reviewed_target_plan_path": {
          "enum": [
            "live-evidence-target-plan.reviewed.json",
            "live-evidence-reviewed-target-plan.json"
          ]
        },
        "source_approval_patch_path": {
          "const": "live-evidence-target-approval-patch.json"
        },
        "source_data_bundle_path": {
          "enum": [
            "data-bundle.json",
            null
          ]
        },
        "source_index": {
          "type": "integer",
          "minimum": 0
        },
        "planning_metadata_only": {
          "const": true
        },
        "read_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "human_approval_required",
        "url_checks_performed",
        "autonomous_crawl_authorized",
        "autonomous_browsing_authorized",
        "live_capture_authorized",
        "locator_codegen_executed",
        "screenshot_capture_authorized",
        "full_page_screenshots_authorized",
        "full_page_grabs_authorized",
        "clip_generation_authorized",
        "report_renderer_authorized",
        "html_css_polish_authorized",
        "pdf_docx_export_authorized",
        "workflow_engine_authorized"
      ],
      "properties": {
        "human_approval_required": {
          "const": true
        },
        "url_checks_performed": {
          "const": false
        },
        "autonomous_crawl_authorized": {
          "const": false
        },
        "autonomous_browsing_authorized": {
          "const": false
        },
        "live_capture_authorized": {
          "const": false
        },
        "locator_codegen_executed": {
          "const": false
        },
        "screenshot_capture_authorized": {
          "const": false
        },
        "full_page_screenshots_authorized": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        },
        "clip_generation_authorized": {
          "const": false
        },
        "report_renderer_authorized": {
          "const": false
        },
        "html_css_polish_authorized": {
          "const": false
        },
        "pdf_docx_export_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "readiness_bundle_is_input_source",
        "executable_only_for_approved_needs_locator",
        "draft_targets_preserved_as_blocked",
        "rejected_targets_excluded",
        "allowed_outputs_unfilled",
        "arbitrary_n_company_grouping",
        "planning_metadata_only",
        "read_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "readiness_bundle_is_input_source": {
          "const": true
        },
        "executable_only_for_approved_needs_locator": {
          "const": true
        },
        "draft_targets_preserved_as_blocked": {
          "const": true
        },
        "rejected_targets_excluded": {
          "const": true
        },
        "allowed_outputs_unfilled": {
          "const": true
        },
        "arbitrary_n_company_grouping": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
