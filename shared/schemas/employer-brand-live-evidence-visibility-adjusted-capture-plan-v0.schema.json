{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aos.local/schemas/employer-brand-live-evidence-visibility-adjusted-capture-plan-v0.schema.json",
  "title": "Employer Brand Live Evidence Visibility-Adjusted Capture Plan V0",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "status",
    "source_refs",
    "summary",
    "repaired_capture_slots",
    "unavailable_source_slots",
    "non_executable_context",
    "read_only_visibility_context",
    "planned_output_manifest",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_visibility_adjusted_capture_plan"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-visibility-adjusted-capture-plan-v0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "status": {
      "const": "visibility_adjusted_pre_capture_plan_ready"
    },
    "source_refs": {
      "type": "object",
      "required": [
        "visibility_repair_patch_path",
        "visibility_review_pack_path",
        "repaired_locator_capture_plan_path",
        "element_clip_manifest_path",
        "repaired_capture_runtime_diagnostics_path",
        "reviewed_target_plan_path",
        "data_bundle_path",
        "read_only"
      ],
      "properties": {
        "visibility_repair_patch_path": {
          "const": "live-evidence-repaired-capture-visibility-repair-patch.json"
        },
        "visibility_review_pack_path": {
          "const": "live-evidence-repaired-capture-visibility-review-pack.json"
        },
        "repaired_locator_capture_plan_path": {
          "const": "live-evidence-repaired-locator-capture-plan.json"
        },
        "element_clip_manifest_path": {
          "const": "source-artifacts/live-evidence-element-clip-manifest.json"
        },
        "repaired_capture_runtime_diagnostics_path": {
          "const": "live-evidence-repaired-capture-runtime-diagnostics.json"
        },
        "reviewed_target_plan_path": {
          "const": "live-evidence-target-plan.reviewed.json"
        },
        "data_bundle_path": {
          "const": "data-bundle.json"
        },
        "read_only": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "visibility_adjusted_executable_slot_count",
        "accepted_capture_count",
        "actual_clip_asset_count",
        "actual_text_asset_count",
        "planned_output_slot_count",
        "scroll_strategy_count",
        "wait_condition_count",
        "viewport_hint_count",
        "full_page_grab_count"
      ],
      "properties": {
        "visibility_adjusted_executable_slot_count": {
          "const": 4
        },
        "accepted_capture_count": {
          "const": 0
        },
        "promoted_capture_count": {
          "const": 0
        },
        "actual_clip_asset_count": {
          "const": 0
        },
        "actual_text_asset_count": {
          "const": 0
        },
        "planned_output_slot_count": {
          "const": 4
        },
        "scroll_strategy_count": {
          "const": 1
        },
        "wait_condition_count": {
          "const": 3
        },
        "viewport_hint_count": {
          "const": 0
        },
        "full_page_grab_count": {
          "const": 0
        }
      },
      "additionalProperties": true
    },
    "repaired_capture_slots": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "slot_id",
          "target_id",
          "work_unit_id",
          "company",
          "source_category",
          "final_url",
          "natural_language_target",
          "evidence_goal",
          "kilos_relevance",
          "expected_clip_count",
          "repaired_locator",
          "planned_outputs",
          "visibility_precondition",
          "visibility_failure_provenance",
          "full_page_grab"
        ],
        "properties": {
          "executable": {
            "const": true
          },
          "status": {
            "const": "visibility_adjusted_ready_for_capture_attempt"
          },
          "full_page_grab": {
            "const": false
          },
          "visibility_precondition": {
            "type": "object",
            "required": [
              "visibility_repair_decision",
              "capture_precondition",
              "scroll_strategy",
              "wait_condition",
              "viewport_hint",
              "operator_repair_notes",
              "reviewed_by",
              "reviewed_at",
              "read_only"
            ],
            "properties": {
              "visibility_repair_decision": {
                "enum": [
                  "add_scroll_strategy",
                  "add_wait_condition",
                  "adjust_viewport",
                  "edit_locator"
                ]
              },
              "capture_precondition": {
                "type": "string",
                "minLength": 1
              },
              "operator_repair_notes": {
                "type": "string",
                "minLength": 1
              },
              "read_only": {
                "const": true
              }
            },
            "additionalProperties": true
          },
          "planned_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "slot_id",
                "clip_path",
                "text_extract_path",
                "full_page_grab"
              ],
              "properties": {
                "clip_path": {
                  "type": "null"
                },
                "text_extract_path": {
                  "type": "null"
                },
                "full_page_grab": {
                  "const": false
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "unavailable_source_slots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1
    },
    "non_executable_context": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14
    },
    "read_only_visibility_context": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15
    },
    "planned_output_manifest": {
      "type": "object",
      "required": [
        "contains_actual_captures",
        "slots"
      ],
      "properties": {
        "contains_actual_captures": {
          "const": false
        },
        "slots": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4
        }
      },
      "additionalProperties": true
    },
    "controls": {
      "type": "object",
      "additionalProperties": {
        "const": false
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "no_urls_opened",
        "no_browser_capture_run",
        "no_locator_resolution_or_codegen",
        "no_capture_assets_produced",
        "no_full_page_grabs"
      ],
      "properties": {
        "no_urls_opened": {
          "const": true
        },
        "no_browser_capture_run": {
          "const": true
        },
        "no_locator_resolution_or_codegen": {
          "const": true
        },
        "no_capture_assets_produced": {
          "const": true
        },
        "no_full_page_grabs": {
          "const": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
