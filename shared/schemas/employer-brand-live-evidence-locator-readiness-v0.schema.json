{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-locator-readiness-v0.schema.json",
  "title": "Employer Brand Live Evidence Locator Readiness v0",
  "description": "Planning-only locator readiness bundle for reviewed live evidence targets. It excludes rejected targets, preserves null locator placeholders, and does not perform URL checks, browsing, codegen, screenshots, clips, rendering, export, workflows, or full-page grabs.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "targets",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_locator_readiness"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-locator-readiness-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "needs_locator",
        "needs_human_target_review",
        "locator_ready",
        "not_checked"
      ]
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/target"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "kilos_dimension": {
      "enum": [
        "kinship",
        "impact",
        "lifestyle",
        "opportunity",
        "status"
      ]
    },
    "source_refs": {
      "type": "object",
      "required": [
        "reviewed_target_plan_id",
        "reviewed_target_plan_path",
        "reviewed_target_plan_schema",
        "approval_patch_id",
        "approval_patch_path",
        "review_pack_id",
        "review_pack_path",
        "data_bundle_id",
        "data_bundle_path",
        "url_reachability_check_id",
        "url_reachability_check_path",
        "url_reachability_check_schema"
      ],
      "properties": {
        "reviewed_target_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewed_target_plan_path": {
          "enum": [
            "live-evidence-target-plan.reviewed.json",
            "live-evidence-reviewed-target-plan.json"
          ]
        },
        "reviewed_target_plan_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-target-plan-v0.schema.json"
        },
        "approval_patch_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "approval_patch_path": {
          "const": "live-evidence-target-approval-patch.json"
        },
        "review_pack_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "review_pack_path": {
          "enum": [
            "live-evidence-target-review-pack.json",
            null
          ]
        },
        "data_bundle_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "data_bundle_path": {
          "enum": [
            "data-bundle.json",
            null
          ]
        },
        "url_reachability_check_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "url_reachability_check_path": {
          "enum": [
            "live-evidence-url-reachability-check.json",
            null
          ]
        },
        "url_reachability_check_schema": {
          "enum": [
            "shared/schemas/employer-brand-live-evidence-url-reachability-check-v0.schema.json",
            null
          ]
        },
        "human_locator_review_pack_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "human_locator_review_pack_path": {
          "enum": [
            "live-evidence-human-locator-review-pack.json",
            null
          ]
        },
        "human_locator_approval_patch_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "human_locator_approval_patch_path": {
          "enum": [
            "live-evidence-human-locator-approval-patch.json",
            null
          ]
        },
        "human_locator_approval_patch_schema": {
          "enum": [
            "shared/schemas/employer-brand-live-evidence-human-locator-approval-patch-v0.schema.json",
            null
          ]
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "source_target_count",
        "excluded_rejected_count",
        "approved_count",
        "draft_count",
        "locator_ready_count",
        "needs_locator_count",
        "needs_human_target_review_count",
        "url_not_checked_count",
        "expected_clip_count_for_included_targets",
        "grouped_by_company",
        "grouped_by_source_category"
      ],
      "properties": {
        "source_target_count": {
          "type": "integer",
          "minimum": 1
        },
        "excluded_rejected_count": {
          "type": "integer",
          "minimum": 0
        },
        "approved_count": {
          "type": "integer",
          "minimum": 0
        },
        "draft_count": {
          "type": "integer",
          "minimum": 0
        },
        "locator_ready_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_locator_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_human_target_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_human_locator_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_count": {
          "type": "integer",
          "minimum": 0
        },
        "url_not_checked_count": {
          "type": "integer",
          "minimum": 0
        },
        "expected_clip_count_for_included_targets": {
          "type": "integer",
          "minimum": 0
        },
        "expected_ready_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "grouped_by_company": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "grouped_by_source_category": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": [
        "target_id",
        "company",
        "source_category",
        "url",
        "review_status",
        "approval_decision",
        "desired_element_summary",
        "capture_type",
        "expected_clip_count",
        "kilos_relevance",
        "locator_placeholders",
        "url_reachability",
        "readiness_state",
        "blockers",
        "required_next_action",
        "provenance"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "review_status": {
          "enum": [
            "approved",
            "draft",
            "human_review_required"
          ]
        },
        "approval_decision": {
          "enum": [
            "approve",
            "keep_draft",
            "not_checked"
          ]
        },
        "desired_element_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capture_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "kilos_relevance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kilos_dimension"
          },
          "uniqueItems": true
        },
        "locator_placeholders": {
          "$ref": "#/$defs/locator_placeholders"
        },
        "url_reachability": {
          "enum": [
            "not_checked",
            "reachable",
            "blocked",
            "redirected",
            "login_required",
            "paywall",
            "captcha",
            "consent_required",
            "network_error",
            "safety_gate_blocked"
          ]
        },
        "readiness_state": {
          "enum": [
            "locator_ready",
            "needs_locator",
            "needs_human_target_review",
            "rejected_excluded",
            "not_checked"
          ]
        },
        "blockers": {
          "$ref": "#/$defs/string_array"
        },
        "required_next_action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "provenance": {
          "$ref": "#/$defs/target_provenance"
        },
        "human_locator_review": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "locator_placeholders": {
      "type": "object",
      "required": [
        "selector",
        "xpath",
        "playwright_locator",
        "codegen_hint",
        "crawl_discovery_notes",
        "capture_script_slot"
      ],
      "properties": {
        "selector": {
          "$ref": "#/$defs/nullable_string"
        },
        "xpath": {
          "$ref": "#/$defs/nullable_string"
        },
        "playwright_locator": {
          "$ref": "#/$defs/nullable_string"
        },
        "codegen_hint": {
          "const": null
        },
        "crawl_discovery_notes": {
          "const": null
        },
        "capture_script_slot": {
          "const": null
        }
      },
      "additionalProperties": false
    },
    "target_provenance": {
      "type": "object",
      "required": [
        "source_reviewed_target_plan_path",
        "source_approval_patch_path",
        "source_review_pack_path",
        "source_data_bundle_path",
        "source_url_reachability_check_path",
        "source_url_reachability_result_id",
        "planning_metadata_only",
        "read_only"
      ],
      "properties": {
        "source_reviewed_target_plan_path": {
          "enum": [
            "live-evidence-target-plan.reviewed.json",
            "live-evidence-reviewed-target-plan.json"
          ]
        },
        "source_approval_patch_path": {
          "const": "live-evidence-target-approval-patch.json"
        },
        "source_review_pack_path": {
          "enum": [
            "live-evidence-target-review-pack.json",
            null
          ]
        },
        "source_data_bundle_path": {
          "enum": [
            "data-bundle.json",
            null
          ]
        },
        "source_url_reachability_check_path": {
          "const": "live-evidence-url-reachability-check.json"
        },
        "source_url_reachability_result_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_human_locator_review_pack_path": {
          "enum": [
            "live-evidence-human-locator-review-pack.json",
            null
          ]
        },
        "source_human_locator_approval_patch_path": {
          "enum": [
            "live-evidence-human-locator-approval-patch.json",
            null
          ]
        },
        "source_human_locator_approval_patch_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "human_locator_decision": {
          "enum": [
            "approve_selector",
            "edit_selector",
            "provide_xpath",
            "provide_playwright_locator",
            "refine_natural_language_target",
            "mark_blocked",
            "keep_draft",
            "reject_target",
            null
          ]
        },
        "human_locator_review_item_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "human_locator_work_unit_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "planning_metadata_only": {
          "const": true
        },
        "read_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "live_browser_collection_authorized",
        "url_reachability_checks_authorized",
        "locator_codegen_execution_authorized",
        "screenshot_capture_authorized",
        "clip_generation_authorized",
        "report_renderer_authorized",
        "html_css_polish_authorized",
        "pdf_docx_export_authorized",
        "workflow_engine_authorized",
        "full_page_grabs_authorized"
      ],
      "properties": {
        "live_browser_collection_authorized": {
          "const": false
        },
        "url_reachability_checks_authorized": {
          "const": false
        },
        "locator_codegen_execution_authorized": {
          "const": false
        },
        "screenshot_capture_authorized": {
          "const": false
        },
        "clip_generation_authorized": {
          "const": false
        },
        "report_renderer_authorized": {
          "const": false
        },
        "html_css_polish_authorized": {
          "const": false
        },
        "pdf_docx_export_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "reviewed_plan_is_input_source",
        "rejected_targets_excluded",
        "url_reachability_default",
        "locators_preserved_from_reviewed_plan",
        "url_reachability_check_path",
        "url_reachability_check_schema",
        "url_reachability_check_read_only_planning_evidence",
        "url_reachability_check_is_input_source",
        "url_reachability_checked_count",
        "arbitrary_n_company_grouping",
        "planning_metadata_only",
        "read_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "reviewed_plan_is_input_source": {
          "const": true
        },
        "rejected_targets_excluded": {
          "const": true
        },
        "url_reachability_default": {
          "const": "not_checked"
        },
        "locators_preserved_from_reviewed_plan": {
          "const": true
        },
        "url_reachability_check_path": {
          "const": "live-evidence-url-reachability-check.json"
        },
        "url_reachability_check_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-url-reachability-check-v0.schema.json"
        },
        "url_reachability_check_read_only_planning_evidence": {
          "const": true
        },
        "url_reachability_check_is_input_source": {
          "type": "boolean"
        },
        "url_reachability_checked_count": {
          "type": "integer",
          "minimum": 0
        },
        "arbitrary_n_company_grouping": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        },
        "source_locator_readiness_path": {
          "enum": [
            "live-evidence-locator-readiness.json",
            null
          ]
        },
        "source_human_locator_review_pack_path": {
          "enum": [
            "live-evidence-human-locator-review-pack.json",
            null
          ]
        },
        "source_human_locator_approval_patch_path": {
          "enum": [
            "live-evidence-human-locator-approval-patch.json",
            null
          ]
        },
        "only_human_approved_locators_become_ready": {
          "type": "boolean"
        },
        "unconfirmed_machine_candidates_do_not_promote": {
          "type": "boolean"
        },
        "no_locator_execution": {
          "type": "boolean"
        },
        "no_codegen_execution": {
          "type": "boolean"
        },
        "no_url_opening": {
          "type": "boolean"
        },
        "no_screenshots": {
          "type": "boolean"
        },
        "no_element_clips": {
          "type": "boolean"
        },
        "no_capture_execution": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
