{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/ops-recipe.schema.json",
  "title": "AOS Ops Recipe",
  "description": "Source-backed operator recipe manifest for aos ops.",
  "type": "object",
  "required": ["id", "version", "summary", "scope", "mutates", "steps"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(/[a-z][a-z0-9-]*)+$"
    },
    "version": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "scope": { "enum": ["source"] },
    "mutates": { "type": "boolean" },
    "requires": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "docs": { "type": "string" },
    "resources": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Step" }
    }
  },
  "$defs": {
    "Step": {
      "type": "object",
      "required": ["id", "command"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "command": {
          "type": "object",
          "required": ["path", "form_id"],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "form_id": { "type": "string", "minLength": 1 }
          }
        },
        "argv": {
          "type": "array",
          "items": { "type": "string" }
        },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "mutates": { "type": "boolean" },
        "finally": { "type": "boolean" },
        "assertions": {
          "type": "array",
          "items": { "$ref": "#/$defs/Assertion" }
        }
      }
    },
    "Assertion": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["path"] },
        { "required": ["select"] }
      ],
      "properties": {
        "path": { "$ref": "#/$defs/Path" },
        "select": {
          "type": "object",
          "required": ["path", "where"],
          "additionalProperties": false,
          "properties": {
            "path": { "$ref": "#/$defs/Path" },
            "where": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": { "$ref": "#/$defs/Scalar" }
            }
          }
        },
        "field": { "$ref": "#/$defs/Path" },
        "exists": { "type": "boolean" },
        "not_exists": { "type": "boolean" },
        "equals": { "$ref": "#/$defs/JSONValue" },
        "contains": { "$ref": "#/$defs/JSONValue" },
        "allow_many": { "type": "boolean", "default": false }
      },
      "allOf": [
        {
          "oneOf": [
            { "required": ["exists"] },
            { "required": ["not_exists"] },
            { "required": ["equals"] },
            { "required": ["contains"] }
          ]
        },
        {
          "not": {
            "anyOf": [
              { "required": ["exists", "not_exists"] },
              { "required": ["exists", "equals"] },
              { "required": ["exists", "contains"] },
              { "required": ["not_exists", "equals"] },
              { "required": ["not_exists", "contains"] },
              { "required": ["equals", "contains"] }
            ]
          }
        }
      ]
    },
    "Path": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "Scalar": {
      "type": ["string", "number", "integer", "boolean", "null"]
    },
    "JSONValue": {
      "anyOf": [
        { "type": "string" },
        { "type": "integer" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/JSONValue" } },
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/JSONValue" } }
      ]
    }
  }
}
