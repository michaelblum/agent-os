{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-element-clip-manifest-v0.schema.json",
  "title": "Employer Brand Element Clip Manifest v0",
  "description": "Element clip manifest shape for Employer Brand source-artifact capture. V0 supports a planned-only skeleton and local-only SPv5 element captures while preserving blocked slots for PDF, PPTX, and unresolved selector work.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "planning_bundle",
    "expected",
    "clips",
    "planned_slots",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_element_clip_manifest"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-element-clip-manifest-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "planned_only_empty",
        "captured",
        "captured_with_blockers"
      ]
    },
    "planning_bundle": {
      "type": "object",
      "required": [
        "id",
        "path",
        "schema"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "path": {
          "const": "source-artifacts/element-capture-planning-bundle.json"
        },
        "schema": {
          "const": "shared/schemas/employer-brand-element-capture-planning-bundle-v0.schema.json"
        }
      },
      "additionalProperties": false
    },
    "expected": {
      "type": "object",
      "required": [
        "target_count",
        "work_unit_count",
        "expected_clip_count"
      ],
      "properties": {
        "target_count": {
          "type": "integer",
          "minimum": 1
        },
        "work_unit_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 1
        },
        "locator_ready_spv5_work_unit_count": {
          "type": "integer",
          "minimum": 0
        },
        "captured_work_unit_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_work_unit_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "clips": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clip_slot"
      }
    },
    "planned_slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clip_slot"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "json_object": {
      "type": "object"
    },
    "kilos_relevance": {
      "type": "array",
      "items": {
        "enum": [
          "kinship",
          "impact",
          "lifestyle",
          "opportunity",
          "status"
        ]
      },
      "uniqueItems": true
    },
    "acceptance_result": {
      "type": "object",
      "required": [
        "status",
        "criteria",
        "notes"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_run",
            "captured"
          ]
        },
        "criteria": {
          "$ref": "#/$defs/string_array"
        },
        "notes": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "clip_slot": {
      "type": "object",
      "required": [
        "target_id",
        "work_unit_id",
        "company",
        "source_artifact",
        "capture_type",
        "clip_path",
        "text_extract_path",
        "text_extract_content",
        "citation_refs",
        "kilos_relevance",
        "acceptance_result",
        "provenance"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "anyOf": [
            {
              "$ref": "#/$defs/json_object"
            },
            {
              "type": "null"
            }
          ]
        },
        "source_artifact": {
          "$ref": "#/$defs/json_object"
        },
        "capture_type": {
          "enum": [
            "element_clip",
            "element_text_extract",
            "element_clip_and_text_extract"
          ]
        },
        "clip_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "text_extract_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "text_extract_content": {
          "$ref": "#/$defs/nullable_string"
        },
        "citation_refs": {
          "$ref": "#/$defs/string_array"
        },
        "kilos_relevance": {
          "$ref": "#/$defs/kilos_relevance"
        },
        "acceptance_result": {
          "$ref": "#/$defs/acceptance_result"
        },
        "capture_metadata": {
          "type": "object"
        },
        "provenance": {
          "type": "object",
          "required": [
            "planned_only",
            "read_only",
            "non_goal_flags"
          ],
          "properties": {
            "planned_only": {
              "type": "boolean"
            },
            "read_only": {
              "const": true
            },
            "non_goal_flags": {
              "$ref": "#/$defs/string_array"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "contains_actual_captures",
        "local_spv5_html_only",
        "live_browser_collection_authorized",
        "remote_web_collection_authorized",
        "pdf_capture_execution_authorized",
        "pptx_capture_execution_authorized",
        "screenshot_generation_authorized",
        "element_clip_generation_authorized",
        "report_renderer_authorized",
        "export_execution_authorized",
        "workflow_engine_authorized",
        "full_page_grabs_authorized"
      ],
      "properties": {
        "contains_actual_captures": {
          "type": "boolean"
        },
        "local_spv5_html_only": {
          "type": "boolean"
        },
        "live_browser_collection_authorized": {
          "const": false
        },
        "remote_web_collection_authorized": {
          "const": false
        },
        "pdf_capture_execution_authorized": {
          "const": false
        },
        "pptx_capture_execution_authorized": {
          "const": false
        },
        "screenshot_generation_authorized": {
          "const": false
        },
        "element_clip_generation_authorized": {
          "type": "boolean"
        },
        "report_renderer_authorized": {
          "const": false
        },
        "export_execution_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "planning_bundle_id",
        "planning_bundle_path",
        "manifest_path",
        "source_spv5_html_path",
        "source_spv5_html_url",
        "executor",
        "read_only",
        "planned_only",
        "local_fixture_evidence_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "planning_bundle_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "planning_bundle_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "manifest_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_spv5_html_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_spv5_html_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "executor": {
          "$ref": "#/$defs/nullable_string"
        },
        "read_only": {
          "const": true
        },
        "planned_only": {
          "type": "boolean"
        },
        "local_fixture_evidence_only": {
          "type": "boolean"
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
