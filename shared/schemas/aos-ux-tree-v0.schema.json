{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/aos-ux-tree-v0.schema.json",
  "title": "AOS UX Tree V0",
  "description": "Inspectable, declarative UX affordance tree for nodes, mode-scoped bindings, allowlisted commands, and plain JSON settings.",
  "type": "object",
  "required": [
    "schema",
    "version",
    "id",
    "label",
    "owner",
    "source_refs",
    "modes",
    "nodes",
    "commands",
    "bindings",
    "relations",
    "settings",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "aos_ux_tree" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/SourceRef" }
    },
    "modes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Mode" },
      "minItems": 1
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/Node" },
      "minItems": 1
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "#/$defs/Command" },
      "minItems": 1
    },
    "bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/Binding" }
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/Relation" }
    },
    "settings": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "JsonScalar": {
      "type": ["string", "number", "integer", "boolean", "null"]
    },
    "JsonValue": {
      "anyOf": [
        { "$ref": "#/$defs/JsonScalar" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/JsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/JsonValue" }
        }
      ]
    },
    "SourceRef": {
      "type": "object",
      "required": ["id", "kind", "ref"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "ref": {
          "type": "string",
          "minLength": 1,
          "not": { "pattern": "^\\s*(?:[dD][aA][tT][aA]|[bB][lL][oO][bB]):" }
        },
        "description": { "type": "string" }
      }
    },
    "Mode": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "source_metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Node": {
      "type": "object",
      "required": ["id", "label", "role", "node_type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "parent_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "node_type": { "type": "string", "minLength": 1 },
        "hit": {
          "type": "object",
          "additionalProperties": true
        },
        "hit_source": {
          "type": "object",
          "additionalProperties": true
        },
        "settings_ref": { "type": "string", "minLength": 1 },
        "resource_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceRef" }
        },
        "children": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source_metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "oneOf": [
        { "required": ["hit"] },
        { "required": ["hit_source"] },
        {
          "not": {
            "anyOf": [
              { "required": ["hit"] },
              { "required": ["hit_source"] }
            ]
          }
        }
      ]
    },
    "Command": {
      "type": "object",
      "required": ["id", "label", "description", "handler_ref", "parameters", "safety"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "handler_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "description": "Declarative allowlisted handler reference. User-authored code is not accepted."
        },
        "parameters": { "$ref": "#/$defs/JsonValue" },
        "safety": {
          "type": "object",
          "required": ["execution"],
          "additionalProperties": true,
          "properties": {
            "execution": { "const": "allowlisted" },
            "side_effect": {
              "enum": ["none", "existing_runtime_path", "opens_surface", "captures_snapshot", "updates_context"]
            }
          }
        },
        "source_metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Binding": {
      "type": "object",
      "required": [
        "id",
        "node_id",
        "mode",
        "gesture",
        "command_id",
        "enabled",
        "priority",
        "consume_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node_id": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "gesture": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "pointer.left.double_click",
            "pointer.right.click",
            "pointer.left.drag_threshold",
            "key.escape",
            "key.enter",
            "key.tab",
            "key.arrow_down"
          ]
        },
        "command_id": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "priority": { "type": "number" },
        "consume_policy": {
          "enum": ["observe", "route", "consume", "capture"]
        },
        "parameters": { "$ref": "#/$defs/JsonValue" },
        "source_metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Relation": {
      "type": "object",
      "required": ["id", "relation_type", "from_node_id", "to_node_id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "relation_type": {
          "enum": ["triggers", "opens", "anchors", "targets", "owns"]
        },
        "from_node_id": { "type": "string", "minLength": 1 },
        "to_node_id": { "type": "string", "minLength": 1 },
        "source_metadata": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/JsonValue" }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/JsonValue" }
        }
      }
    }
  }
}
