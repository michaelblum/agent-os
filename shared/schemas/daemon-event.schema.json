{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/daemon-event.schema.json",
  "title": "Daemon Event Envelope",
  "description": "Standard envelope for all events pushed by agent-os daemons to subscribers. Newline-delimited JSON (ndjson) over Unix socket.",
  "type": "object",
  "required": ["v", "service", "event", "ts", "data"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "required": ["service"],
        "properties": {
          "service": { "const": "voice" }
        }
      },
      "then": {
        "properties": {
          "event": {
            "enum": [
              "wake_detected",
              "dictation_opened",
              "dictation_closed_send",
              "dictation_closed_cancel",
              "capture_started",
              "capture_completed",
              "capture_canceled",
              "capture_failed",
              "audio_frame",
              "speech_started",
              "speech_finished",
              "speech_canceled",
              "speech_failed"
            ]
          }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "wake_detected" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceSourceData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "dictation_opened" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceSourceData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "dictation_closed_send" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceDictationClosedData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "dictation_closed_cancel" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceDictationClosedData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "capture_started" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceCaptureStartedData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "capture_completed" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceCaptureCompletedData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "capture_canceled" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceCaptureCanceledData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "enum": ["capture_failed", "speech_failed"] }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceFailureData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "audio_frame" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceAudioFrameData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "speech_started" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceSpeechStartedData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "speech_finished" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceSpeechFinishedData" }
        }
      }
    },
    {
      "if": {
        "required": ["service", "event"],
        "properties": {
          "service": { "const": "voice" },
          "event": { "const": "speech_canceled" }
        }
      },
      "then": {
        "properties": {
          "data": { "$ref": "#/$defs/VoiceSpeechCanceledData" }
        }
      }
    }
  ],
  "properties": {
    "v": {
      "const": 1,
      "description": "Envelope version. Integer, not semver. Bump only on breaking wire changes."
    },
    "service": {
      "type": "string",
      "enum": ["perceive", "display", "act", "voice"],
      "description": "Which aos subsystem emitted this event."
    },
    "event": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Event name. Snake_case, service-specific. Examples: cursor_moved, canvas_message, channel_post."
    },
    "ts": {
      "type": "number",
      "description": "Unix timestamp with millisecond precision (e.g. 1712345678.123)."
    },
    "data": {
      "type": "object",
      "description": "Event-specific payload. Structure depends on service + event name. Always an object, never null."
    },
    "ref": {
      "type": "string",
      "description": "Optional correlation ID. Links an event to a prior request (e.g. a perception channel open)."
    }
  },
  "$defs": {
    "Bounds": {
      "$ref": "annotation.schema.json#/$defs/Bounds",
      "description": "Reuse shared Bounds type (x, y, width, height)."
    },
    "VoiceSource": {
      "type": "string",
      "enum": ["hotkey", "phrase"],
      "description": "Trigger source for generic voice events."
    },
    "VoiceDictationCloseReason": {
      "type": "string",
      "enum": ["key_release", "phrase", "explicit_trigger", "timeout"],
      "description": "Reason a dictation session closed."
    },
    "VoiceSourceData": {
      "type": "object",
      "required": ["source"],
      "additionalProperties": false,
      "properties": {
        "source": { "$ref": "#/$defs/VoiceSource" }
      }
    },
    "VoiceDictationClosedData": {
      "type": "object",
      "required": ["reason"],
      "additionalProperties": false,
      "properties": {
        "reason": { "$ref": "#/$defs/VoiceDictationCloseReason" }
      }
    },
    "VoiceCaptureStartedData": {
      "type": "object",
      "required": ["sample_rate", "channels", "max_duration_ms"],
      "additionalProperties": false,
      "properties": {
        "sample_rate": { "const": 16000 },
        "channels": { "const": 1 },
        "max_duration_ms": { "type": "integer", "minimum": 1, "maximum": 120000 }
      }
    },
    "VoiceCaptureCompletedData": {
      "type": "object",
      "required": ["reason", "duration_ms", "bytes"],
      "additionalProperties": false,
      "properties": {
        "reason": { "type": "string", "enum": ["explicit_stop", "max_duration"] },
        "duration_ms": { "type": "integer", "minimum": 0, "maximum": 120000 },
        "bytes": { "type": "integer", "minimum": 0, "maximum": 4194304 }
      }
    },
    "VoiceCaptureCanceledData": {
      "type": "object",
      "required": ["reason"],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "enum": ["canceled", "owner_disconnect", "daemon_shutdown", "superseded"]
        }
      }
    },
    "VoiceFailureData": {
      "type": "object",
      "required": ["code"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" }
      }
    },
    "VoiceAudioFrameData": {
      "type": "object",
      "required": ["stream", "rms", "peak", "sequence"],
      "additionalProperties": false,
      "properties": {
        "stream": { "type": "string", "enum": ["capture", "speech"] },
        "rms": { "type": "number", "minimum": 0, "maximum": 1 },
        "peak": { "type": "number", "minimum": 0, "maximum": 1 },
        "sequence": { "type": "integer", "minimum": 1 }
      }
    },
    "VoiceSpeechStartedData": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rate_wpm": { "type": "number", "minimum": 80, "maximum": 450 }
      }
    },
    "VoiceSpeechFinishedData": {
      "type": "object",
      "required": ["reason"],
      "additionalProperties": false,
      "properties": {
        "reason": { "const": "completed" }
      }
    },
    "VoiceSpeechCanceledData": {
      "type": "object",
      "required": ["reason"],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "enum": ["canceled", "owner_disconnect", "daemon_shutdown", "barge_in"]
        }
      }
    }
  }
}
