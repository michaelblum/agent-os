{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-target-review-pack-v0.schema.json",
  "title": "Employer Brand Live Evidence Target Review Pack v0",
  "description": "Data-only review checklist for human-authored live website evidence targets before locator/codegen/readiness, reachability checks, browsing, collection, capture, rendering, export, or workflow execution.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "target_plan_ref",
    "project_ref",
    "summary",
    "groups",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_target_review_pack"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-target-review-pack-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "draft",
        "human_review_required",
        "approved",
        "archived"
      ]
    },
    "target_plan_ref": {
      "$ref": "#/$defs/target_plan_ref"
    },
    "project_ref": {
      "$ref": "#/$defs/project_ref"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/company_group"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "kilos_dimension": {
      "enum": [
        "kinship",
        "impact",
        "lifestyle",
        "opportunity",
        "status"
      ]
    },
    "kilos_relevance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/kilos_dimension"
      },
      "uniqueItems": true
    },
    "target_plan_ref": {
      "type": "object",
      "required": [
        "target_plan_id",
        "target_plan_path",
        "target_plan_schema",
        "target_plan_status",
        "read_only",
        "planning_metadata_only"
      ],
      "properties": {
        "target_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_plan_path": {
          "const": "live-evidence-target-plan.json"
        },
        "target_plan_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-target-plan-v0.schema.json"
        },
        "target_plan_status": {
          "enum": [
            "draft",
            "human_review_required",
            "approved",
            "archived"
          ]
        },
        "read_only": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "project_ref": {
      "type": "object",
      "required": [
        "project_id",
        "project_path",
        "framework",
        "read_only",
        "planning_metadata_only"
      ],
      "properties": {
        "project_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "project_path": {
          "const": "intake/project.json"
        },
        "framework": {
          "const": "KILOS"
        },
        "read_only": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "company_count",
        "source_category_count",
        "page_count",
        "target_count",
        "expected_clip_count",
        "locator_ready_count",
        "review_status_counts",
        "approval_decision_counts",
        "kilos_dimensions"
      ],
      "properties": {
        "company_count": {
          "type": "integer",
          "minimum": 1
        },
        "source_category_count": {
          "type": "integer",
          "minimum": 1
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        },
        "target_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "locator_ready_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_status_counts": {
          "type": "object"
        },
        "approval_decision_counts": {
          "type": "object"
        },
        "kilos_dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "dimension",
              "target_count"
            ],
            "properties": {
              "dimension": {
                "$ref": "#/$defs/kilos_dimension"
              },
              "target_count": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "company_group": {
      "type": "object",
      "required": [
        "company_id",
        "company",
        "company_role",
        "target_count",
        "expected_clip_count",
        "locator_ready_count",
        "source_categories"
      ],
      "properties": {
        "company_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "locator_ready_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source_category_group"
          }
        }
      },
      "additionalProperties": false
    },
    "source_category_group": {
      "type": "object",
      "required": [
        "source_category",
        "target_count",
        "expected_clip_count",
        "locator_ready_count",
        "review_items"
      ],
      "properties": {
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "locator_ready_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/review_item"
          }
        }
      },
      "additionalProperties": false
    },
    "review_item": {
      "type": "object",
      "required": [
        "target_id",
        "company_id",
        "company",
        "company_role",
        "source_category",
        "page_name",
        "url",
        "desired_element",
        "evidence_goal",
        "kilos_relevance",
        "capture_type",
        "expected_clip_count",
        "acceptance_criteria",
        "review_status",
        "approval_status",
        "locator_readiness",
        "locator_readiness_summary",
        "notes",
        "non_goal_flags",
        "reviewer_notes",
        "suggested_target_edits",
        "approval_decision",
        "decision_timestamp"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "page_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "desired_element": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_goal": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kilos_relevance": {
          "$ref": "#/$defs/kilos_relevance"
        },
        "capture_type": {
          "enum": [
            "element_clip",
            "element_text_extract",
            "element_clip_and_text_extract"
          ]
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "review_status": {
          "enum": [
            "draft",
            "human_review_required",
            "approved",
            "rejected"
          ]
        },
        "approval_status": {
          "enum": [
            "not_reviewed",
            "reviewed"
          ]
        },
        "locator_readiness": {
          "$ref": "#/$defs/locator_readiness"
        },
        "locator_readiness_summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "notes": {
          "$ref": "#/$defs/nullable_string"
        },
        "non_goal_flags": {
          "$ref": "#/$defs/non_goal_flags"
        },
        "reviewer_notes": {
          "$ref": "#/$defs/nullable_string"
        },
        "suggested_target_edits": {
          "$ref": "#/$defs/nullable_string"
        },
        "approval_decision": {
          "enum": [
            "approved",
            "approved_with_edits",
            "rejected",
            "needs_revision",
            null
          ]
        },
        "decision_timestamp": {
          "$ref": "#/$defs/nullable_string"
        }
      },
      "additionalProperties": false
    },
    "locator_readiness": {
      "type": "object",
      "required": [
        "locator_ready",
        "selector_ready",
        "xpath_ready",
        "playwright_ready",
        "codegen_ready",
        "locator_placeholders",
        "summary"
      ],
      "properties": {
        "locator_ready": {
          "type": "boolean"
        },
        "selector_ready": {
          "type": "boolean"
        },
        "xpath_ready": {
          "type": "boolean"
        },
        "playwright_ready": {
          "type": "boolean"
        },
        "codegen_ready": {
          "type": "boolean"
        },
        "locator_placeholders": {
          "$ref": "#/$defs/locator_placeholders"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "locator_placeholders": {
      "type": "object",
      "required": [
        "selector",
        "xpath",
        "playwright_locator",
        "codegen_hint",
        "crawl_discovery_notes",
        "capture_script_slot"
      ],
      "properties": {
        "selector": {
          "type": "null"
        },
        "xpath": {
          "type": "null"
        },
        "playwright_locator": {
          "type": "null"
        },
        "codegen_hint": {
          "type": "null"
        },
        "crawl_discovery_notes": {
          "type": "null"
        },
        "capture_script_slot": {
          "type": "null"
        }
      },
      "additionalProperties": false
    },
    "non_goal_flags": {
      "type": "object",
      "required": [
        "full_page_grab",
        "live_browser_collection",
        "url_reachability_check",
        "locator_codegen",
        "screenshot_capture",
        "clip_generation",
        "report_rendering",
        "html_css_polish",
        "pdf_docx_export",
        "workflow_execution"
      ],
      "properties": {
        "full_page_grab": {
          "const": false
        },
        "live_browser_collection": {
          "const": false
        },
        "url_reachability_check": {
          "const": false
        },
        "locator_codegen": {
          "const": false
        },
        "screenshot_capture": {
          "const": false
        },
        "clip_generation": {
          "const": false
        },
        "report_rendering": {
          "const": false
        },
        "html_css_polish": {
          "const": false
        },
        "pdf_docx_export": {
          "const": false
        },
        "workflow_execution": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "full_page_grabs",
        "autonomous_browsing_authorized",
        "live_collection_authorized",
        "report_renderer_authorized",
        "export_execution_authorized",
        "workflow_engine_authorized",
        "url_reachability_checks_authorized",
        "locator_codegen_authorized",
        "screenshot_capture_authorized",
        "clip_generation_authorized",
        "html_css_polish_authorized"
      ],
      "properties": {
        "full_page_grabs": {
          "const": false
        },
        "autonomous_browsing_authorized": {
          "const": false
        },
        "live_collection_authorized": {
          "const": false
        },
        "report_renderer_authorized": {
          "const": false
        },
        "export_execution_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        },
        "url_reachability_checks_authorized": {
          "const": false
        },
        "locator_codegen_authorized": {
          "const": false
        },
        "screenshot_capture_authorized": {
          "const": false
        },
        "clip_generation_authorized": {
          "const": false
        },
        "html_css_polish_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "source_target_plan_path",
        "source_project_path",
        "human_review_affordances_empty",
        "planning_metadata_only",
        "read_only",
        "live_evidence_collected",
        "url_reachability_checked",
        "locators_resolved",
        "locator_codegen_executed",
        "screenshots_captured",
        "clips_generated",
        "report_rendered",
        "exports_generated",
        "workflow_executed",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "source_target_plan_path": {
          "const": "live-evidence-target-plan.json"
        },
        "source_project_path": {
          "const": "intake/project.json"
        },
        "human_review_affordances_empty": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "live_evidence_collected": {
          "const": false
        },
        "url_reachability_checked": {
          "const": false
        },
        "locators_resolved": {
          "const": false
        },
        "locator_codegen_executed": {
          "const": false
        },
        "screenshots_captured": {
          "const": false
        },
        "clips_generated": {
          "const": false
        },
        "report_rendered": {
          "const": false
        },
        "exports_generated": {
          "const": false
        },
        "workflow_executed": {
          "const": false
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
