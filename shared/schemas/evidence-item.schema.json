{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/evidence-item.schema.json",
  "title": "AOS Steerable Collection Evidence Item",
  "description": "Minimal V0 source-pack evidence records derived from human marks and agent actions.",
  "type": "object",
  "required": ["evidence_id", "session_id", "mark_ids", "action_ids", "source_url", "captured_at"],
  "additionalProperties": false,
  "properties": {
    "evidence_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "mark_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "action_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_url": { "type": "string", "minLength": 1 },
    "quote": { "type": "string" },
    "crop_path": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "format": "date-time" }
  }
}
