{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-human-locator-review-pack-v0.schema.json",
  "title": "Employer Brand Human Locator Review Pack v0",
  "description": "Data-only human review queue for ambiguous live evidence locator attempts and targets that still need human target review.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "groups",
    "excluded_context",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_human_locator_review_pack"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-human-locator-review-pack-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "const": "human_locator_review_required"
    },
    "source_refs": {
      "type": "object",
      "required": [
        "locator_resolution_result_path",
        "locator_readiness_path",
        "supervised_locator_plan_path",
        "reviewed_target_plan_path",
        "url_open_run_path",
        "read_only_planning_evidence"
      ],
      "properties": {
        "locator_resolution_result_path": {
          "const": "live-evidence-locator-resolution-result.json"
        },
        "locator_readiness_path": {
          "const": "live-evidence-locator-readiness.json"
        },
        "supervised_locator_plan_path": {
          "const": "live-evidence-supervised-locator-plan.json"
        },
        "reviewed_target_plan_path": {
          "const": "live-evidence-target-plan.reviewed.json"
        },
        "url_open_run_path": {
          "const": "live-evidence-url-open-run.json"
        },
        "read_only_planning_evidence": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "review_item_count",
        "ambiguous_locator_attempt_count",
        "needs_human_target_review_count",
        "locator_ready_count",
        "expected_clip_count",
        "source_counts",
        "decision_status_counts",
        "unconfirmed_candidate_count"
      ],
      "properties": {
        "review_item_count": {
          "type": "integer",
          "minimum": 1
        },
        "ambiguous_locator_attempt_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_human_target_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "locator_ready_count": {
          "const": 0
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_counts": {
          "type": "object"
        },
        "decision_status_counts": {
          "type": "object"
        },
        "unconfirmed_candidate_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/company_group"
      }
    },
    "excluded_context": {
      "type": "object"
    },
    "controls": {
      "$ref": "#/$defs/non_goal_flags"
    },
    "provenance": {
      "type": "object",
      "required": [
        "read_only",
        "planning_metadata_only",
        "no_locator_execution",
        "no_codegen_execution",
        "no_url_opening",
        "no_screenshots",
        "no_element_clips",
        "no_capture_execution",
        "no_report_renderer",
        "no_export_work",
        "no_workflow_engine",
        "no_full_page_grabs",
        "no_autonomous_crawling_or_bypasses",
        "only_human_approved_locators_become_ready"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "read_only": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        },
        "no_locator_execution": {
          "const": true
        },
        "no_codegen_execution": {
          "const": true
        },
        "no_url_opening": {
          "const": true
        },
        "no_screenshots": {
          "const": true
        },
        "no_element_clips": {
          "const": true
        },
        "no_capture_execution": {
          "const": true
        },
        "no_report_renderer": {
          "const": true
        },
        "no_export_work": {
          "const": true
        },
        "no_workflow_engine": {
          "const": true
        },
        "no_full_page_grabs": {
          "const": true
        },
        "no_autonomous_crawling_or_bypasses": {
          "const": true
        },
        "only_human_approved_locators_become_ready": {
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "kilos_dimension": {
      "enum": [
        "kinship",
        "impact",
        "lifestyle",
        "opportunity",
        "status"
      ]
    },
    "human_decision": {
      "enum": [
        "approve_selector",
        "edit_selector",
        "provide_xpath",
        "provide_playwright_locator",
        "refine_natural_language_target",
        "mark_blocked",
        "keep_draft",
        "reject_target"
      ]
    },
    "company_group": {
      "type": "object",
      "required": [
        "company",
        "company_role",
        "review_item_count",
        "expected_clip_count",
        "source_categories"
      ],
      "properties": {
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "review_item_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source_group"
          }
        }
      },
      "additionalProperties": false
    },
    "source_group": {
      "type": "object",
      "required": [
        "source_category",
        "review_item_count",
        "expected_clip_count",
        "review_items"
      ],
      "properties": {
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "review_item_count": {
          "type": "integer",
          "minimum": 1
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/review_item"
          }
        }
      },
      "additionalProperties": false
    },
    "review_item": {
      "type": "object",
      "required": [
        "review_item_id",
        "target_id",
        "work_unit_id",
        "company",
        "company_role",
        "source_category",
        "url",
        "final_url",
        "page_name",
        "desired_element",
        "evidence_goal",
        "kilos_relevance",
        "capture_type",
        "expected_clip_count",
        "acceptance_criteria",
        "review_source",
        "ambiguity_or_blocker_reason",
        "unconfirmed_selector_candidates",
        "human_locator",
        "locator_ready",
        "required_human_decision",
        "non_goal_flags",
        "provenance"
      ],
      "properties": {
        "review_item_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "page_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "desired_element": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_goal": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kilos_relevance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kilos_dimension"
          },
          "uniqueItems": true
        },
        "capture_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "review_source": {
          "enum": [
            "ambiguous_locator_attempt",
            "needs_human_target_review"
          ]
        },
        "resolution_status": {
          "$ref": "#/$defs/nullable_string"
        },
        "readiness_state": {
          "$ref": "#/$defs/nullable_string"
        },
        "url_open_status": {
          "$ref": "#/$defs/nullable_string"
        },
        "ambiguity_or_blocker_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "unconfirmed_selector_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unconfirmed_candidate"
          }
        },
        "human_locator": {
          "type": "object",
          "required": [
            "selector",
            "xpath",
            "playwright_locator"
          ],
          "properties": {
            "selector": {
              "const": null
            },
            "xpath": {
              "const": null
            },
            "playwright_locator": {
              "const": null
            }
          },
          "additionalProperties": false
        },
        "locator_ready": {
          "const": false
        },
        "required_human_decision": {
          "type": "object",
          "required": [
            "status",
            "allowed_decisions",
            "selected_decision",
            "human_notes"
          ],
          "properties": {
            "status": {
              "const": "pending"
            },
            "allowed_decisions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/human_decision"
              },
              "uniqueItems": true
            },
            "selected_decision": {
              "const": null
            },
            "human_notes": {
              "const": null
            }
          },
          "additionalProperties": false
        },
        "non_goal_flags": {
          "$ref": "#/$defs/non_goal_flags"
        },
        "provenance": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "unconfirmed_candidate": {
      "type": "object",
      "required": [
        "selector",
        "xpath",
        "playwright_locator",
        "selector_type",
        "confidence",
        "rationale",
        "provenance",
        "metadata_only"
      ],
      "properties": {
        "selector": {
          "type": [
            "string",
            "null"
          ]
        },
        "xpath": {
          "type": [
            "string",
            "null"
          ]
        },
        "playwright_locator": {
          "type": [
            "string",
            "null"
          ]
        },
        "selector_type": {
          "const": "unconfirmed_metadata_only"
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ]
        },
        "rationale": {
          "$ref": "#/$defs/nullable_string"
        },
        "provenance": {
          "$ref": "#/$defs/nullable_string"
        },
        "metadata_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "non_goal_flags": {
      "type": "object",
      "required": [
        "locator_execution",
        "codegen_execution",
        "url_opening",
        "screenshot_capture",
        "element_clip_generation",
        "capture_execution",
        "report_rendering",
        "export_execution",
        "workflow_engine",
        "full_page_grabs",
        "autonomous_crawling",
        "bypasses"
      ],
      "properties": {
        "locator_execution": {
          "const": false
        },
        "codegen_execution": {
          "const": false
        },
        "url_opening": {
          "const": false
        },
        "screenshot_capture": {
          "const": false
        },
        "element_clip_generation": {
          "const": false
        },
        "capture_execution": {
          "const": false
        },
        "report_rendering": {
          "const": false
        },
        "export_execution": {
          "const": false
        },
        "workflow_engine": {
          "const": false
        },
        "full_page_grabs": {
          "const": false
        },
        "autonomous_crawling": {
          "const": false
        },
        "bypasses": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  }
}
