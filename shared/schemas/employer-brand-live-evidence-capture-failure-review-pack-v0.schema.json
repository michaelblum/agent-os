{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-capture-failure-review-pack-v0.schema.json",
  "title": "Employer Brand Live Evidence Capture Failure Review Pack v0",
  "description": "Read-only deterministic triage and repair-queue metadata for failed reviewed live evidence element captures.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "repair_queue",
    "non_executable_context",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_capture_failure_review_pack"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-capture-failure-review-pack-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "const": "repair_queue_ready"
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "repair_queue": {
      "$ref": "#/$defs/repair_queue"
    },
    "non_executable_context": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context_item"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "json_object": {
      "type": "object"
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "source_refs": {
      "type": "object",
      "required": [
        "manifest_path",
        "reviewed_locator_capture_plan_path",
        "reviewed_locator_readiness_path",
        "human_locator_approval_patch_path",
        "url_open_run_path",
        "reviewed_target_plan_path",
        "data_bundle_path",
        "read_only"
      ],
      "properties": {
        "manifest_path": {
          "const": "source-artifacts/live-evidence-element-clip-manifest.json"
        },
        "reviewed_locator_capture_plan_path": {
          "const": "live-evidence-reviewed-locator-capture-plan.json"
        },
        "reviewed_locator_readiness_path": {
          "const": "live-evidence-locator-readiness.reviewed.json"
        },
        "human_locator_approval_patch_path": {
          "const": "live-evidence-human-locator-approval-patch.json"
        },
        "url_open_run_path": {
          "const": "live-evidence-url-open-run.json"
        },
        "reviewed_target_plan_path": {
          "const": "live-evidence-target-plan.reviewed.json"
        },
        "data_bundle_path": {
          "const": "data-bundle.json"
        },
        "read_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "executable_unit_count",
        "planned_output_slot_count",
        "accepted_capture_count",
        "failed_executable_slot_count",
        "non_executable_context_count",
        "full_page_grab_count",
        "zero_match_locator_failure_count",
        "login_or_sign_in_blocker_count",
        "blocker_reason_counts",
        "blocker_class_counts",
        "recommended_next_action_counts"
      ],
      "properties": {
        "executable_unit_count": {
          "const": 4
        },
        "planned_output_slot_count": {
          "const": 5
        },
        "accepted_capture_count": {
          "const": 0
        },
        "failed_executable_slot_count": {
          "const": 5
        },
        "non_executable_context_count": {
          "const": 14
        },
        "full_page_grab_count": {
          "const": 0
        },
        "zero_match_locator_failure_count": {
          "const": 4
        },
        "login_or_sign_in_blocker_count": {
          "const": 1
        },
        "blocker_reason_counts": {
          "$ref": "#/$defs/json_object"
        },
        "blocker_class_counts": {
          "$ref": "#/$defs/json_object"
        },
        "recommended_next_action_counts": {
          "$ref": "#/$defs/json_object"
        }
      },
      "additionalProperties": false
    },
    "repair_queue": {
      "type": "object",
      "required": [
        "actionable_failure_count",
        "groups"
      ],
      "properties": {
        "actionable_failure_count": {
          "const": 5
        },
        "groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/failure_group"
          }
        }
      },
      "additionalProperties": false
    },
    "failure_group": {
      "type": "object",
      "required": [
        "work_unit_id",
        "target_id",
        "company",
        "company_role",
        "source_category",
        "failure_count",
        "slot_ids",
        "blocker_classes",
        "failures"
      ],
      "properties": {
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "failure_count": {
          "type": "integer",
          "minimum": 1
        },
        "slot_ids": {
          "$ref": "#/$defs/string_array"
        },
        "blocker_classes": {
          "$ref": "#/$defs/string_array"
        },
        "failures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/failure_item"
          }
        }
      },
      "additionalProperties": false
    },
    "failure_item": {
      "type": "object",
      "required": [
        "failure_id",
        "slot_id",
        "target_id",
        "work_unit_id",
        "company",
        "company_role",
        "source_category",
        "original_url",
        "final_url",
        "status",
        "blocker_reason",
        "blocker_class",
        "recommended_next_action",
        "operator_outcome_notes",
        "target_context",
        "reviewed_locator",
        "locator_provenance",
        "url_open_provenance",
        "citation_source_metadata",
        "capture_metadata",
        "acceptance_checks",
        "full_page_grab",
        "repair",
        "provenance"
      ],
      "properties": {
        "failure_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "slot_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "original_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "const": "failed"
        },
        "blocker_reason": {
          "enum": [
            "reviewed_locator_matches_zero_elements",
            "login_required"
          ]
        },
        "blocker_class": {
          "enum": [
            "zero_match_locator_failure",
            "login_or_sign_in_blocker"
          ]
        },
        "recommended_next_action": {
          "enum": [
            "needs_operator_locator_repair",
            "needs_human_source_decision"
          ]
        },
        "operator_outcome_notes": {
          "$ref": "#/$defs/json_object"
        },
        "target_context": {
          "$ref": "#/$defs/json_object"
        },
        "reviewed_locator": {
          "$ref": "#/$defs/json_object"
        },
        "locator_provenance": {
          "$ref": "#/$defs/json_object"
        },
        "url_open_provenance": {
          "$ref": "#/$defs/json_object"
        },
        "citation_source_metadata": {
          "$ref": "#/$defs/json_object"
        },
        "capture_metadata": {
          "$ref": "#/$defs/json_object"
        },
        "acceptance_checks": {
          "type": "array"
        },
        "full_page_grab": {
          "const": false
        },
        "repair": {
          "$ref": "#/$defs/repair_fields"
        },
        "provenance": {
          "$ref": "#/$defs/json_object"
        }
      },
      "additionalProperties": false
    },
    "repair_fields": {
      "type": "object",
      "required": [
        "proposed_selector",
        "proposed_xpath",
        "proposed_playwright_locator",
        "refined_natural_language_target",
        "replacement_url",
        "repair_decision",
        "repair_notes",
        "reviewed_by"
      ],
      "properties": {
        "proposed_selector": {
          "type": "null"
        },
        "proposed_xpath": {
          "type": "null"
        },
        "proposed_playwright_locator": {
          "type": "null"
        },
        "refined_natural_language_target": {
          "type": "null"
        },
        "replacement_url": {
          "type": "null"
        },
        "repair_decision": {
          "type": "null"
        },
        "repair_notes": {
          "type": "null"
        },
        "reviewed_by": {
          "type": "null"
        }
      },
      "additionalProperties": false
    },
    "context_item": {
      "type": "object",
      "required": [
        "target_id",
        "work_unit_id",
        "company",
        "company_role",
        "source_category",
        "original_url",
        "final_url",
        "status",
        "blocker_reason",
        "required_next_action",
        "full_page_grab",
        "actionable_repair_item",
        "provenance"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company_role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "original_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "status": {
          "const": "blocked_not_run"
        },
        "blocker_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required_next_action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "full_page_grab": {
          "const": false
        },
        "actionable_repair_item": {
          "const": false
        },
        "provenance": {
          "$ref": "#/$defs/json_object"
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "properties": {
        "full_page_grab": {
          "const": false
        },
        "open_urls": {
          "const": false
        },
        "run_browser_codegen": {
          "const": false
        },
        "run_locator_resolution": {
          "const": false
        },
        "invent_repair_locators": {
          "const": false
        },
        "bypass_login_or_access_controls": {
          "const": false
        },
        "render_reports": {
          "const": false
        },
        "export_documents": {
          "const": false
        },
        "execute_workflow": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "deterministic_from_local_inputs",
        "repair_fields_initialized_null",
        "read_only",
        "no_urls_opened",
        "no_browser_codegen_run",
        "no_locator_resolution_run",
        "no_selectors_invented",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "deterministic_from_local_inputs": {
          "const": true
        },
        "repair_fields_initialized_null": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "no_urls_opened": {
          "const": true
        },
        "no_browser_codegen_run": {
          "const": true
        },
        "no_locator_resolution_run": {
          "const": true
        },
        "no_selectors_invented": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
