{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aos.local/schemas/employer-brand-repaired-capture-visibility-review-pack-v0.schema.json",
  "title": "Employer Brand Repaired Capture Visibility Review Pack V0",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "status",
    "source_refs",
    "summary",
    "visibility_failures",
    "non_actionable_context",
    "invariants",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_repaired_capture_visibility_review_pack"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-repaired-capture-visibility-review-pack-v0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string"
    },
    "status": {
      "const": "visibility_repair_review_required"
    },
    "source_refs": {
      "type": "object",
      "required": [
        "manifest_path",
        "repaired_locator_capture_plan_path",
        "capture_repair_promotion_path",
        "capture_repair_patch_path",
        "repaired_capture_runtime_diagnostics_path",
        "reviewed_target_plan_path",
        "data_bundle_path",
        "read_only"
      ],
      "properties": {
        "manifest_path": {
          "const": "source-artifacts/live-evidence-element-clip-manifest.json"
        },
        "repaired_locator_capture_plan_path": {
          "const": "live-evidence-repaired-locator-capture-plan.json"
        },
        "capture_repair_promotion_path": {
          "const": "live-evidence-capture-repair-promotion.json"
        },
        "capture_repair_patch_path": {
          "const": "live-evidence-capture-repair-patch.json"
        },
        "repaired_capture_runtime_diagnostics_path": {
          "const": "live-evidence-repaired-capture-runtime-diagnostics.json"
        },
        "reviewed_target_plan_path": {
          "const": "live-evidence-target-plan.reviewed.json"
        },
        "data_bundle_path": {
          "const": "data-bundle.json"
        },
        "read_only": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "attempted_repaired_slot_count",
        "actionable_visibility_failure_count",
        "accepted_capture_count",
        "actual_clip_asset_count",
        "actual_text_asset_count",
        "linked_in_source_unavailable_count",
        "non_executable_context_count",
        "full_page_grab_count"
      ],
      "properties": {
        "attempted_repaired_slot_count": {
          "const": 4
        },
        "actionable_visibility_failure_count": {
          "const": 4
        },
        "accepted_capture_count": {
          "const": 0
        },
        "actual_clip_asset_count": {
          "const": 0
        },
        "actual_text_asset_count": {
          "const": 0
        },
        "linked_in_source_unavailable_count": {
          "const": 1
        },
        "non_executable_context_count": {
          "const": 14
        },
        "full_page_grab_count": {
          "const": 0
        }
      },
      "additionalProperties": true
    },
    "visibility_failures": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "failure_id",
          "slot_id",
          "target_id",
          "work_unit_id",
          "company",
          "source_category",
          "original_url",
          "blocker_reason",
          "failed_phase",
          "runner_type",
          "match_count",
          "target_context",
          "repaired_locator",
          "operator_outcome_notes",
          "prior_repair_provenance",
          "full_page_grab"
        ],
        "properties": {
          "blocker_reason": {
            "const": "reviewed_locator_element_not_visible"
          },
          "failed_phase": {
            "const": "element_visibility_check"
          },
          "runner_type": {
            "const": "playwright_node_api"
          },
          "match_count": {
            "const": 1
          },
          "clip_path": {
            "type": "null"
          },
          "text_extract_path": {
            "type": "null"
          },
          "text_extract_content": {
            "type": "null"
          },
          "full_page_grab": {
            "const": false
          }
        },
        "additionalProperties": true
      }
    },
    "non_actionable_context": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": [
          "actionable_visibility_failure",
          "full_page_grab"
        ],
        "properties": {
          "actionable_visibility_failure": {
            "const": false
          },
          "full_page_grab": {
            "const": false
          }
        },
        "additionalProperties": true
      }
    },
    "invariants": {
      "type": "object",
      "additionalProperties": {
        "const": true
      }
    },
    "controls": {
      "type": "object",
      "properties": {
        "read_only_review_pack": {
          "const": true
        }
      },
      "additionalProperties": {
        "const": false
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "read_only": {
          "const": true
        },
        "no_live_pages_inspected": {
          "const": true
        },
        "no_capture_run": {
          "const": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
