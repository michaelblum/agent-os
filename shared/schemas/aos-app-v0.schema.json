{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/aos-app-v0.schema.json",
  "title": "AOS App Manifest v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "version", "default_entry", "content_roots", "entries"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 0 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "default_entry": { "type": "string", "minLength": 1 },
    "content_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "path": { "type": "string", "minLength": 1 },
          "branch_scoped": { "type": "boolean" }
        }
      }
    },
    "status_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "toggle_entry"],
      "properties": {
        "enabled": { "type": "boolean" },
        "toggle_entry": { "type": "string", "minLength": 1 },
        "toggle_track": { "type": "string", "minLength": 1 }
      }
    },
    "entries": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["summary", "surfaces"],
        "properties": {
          "summary": { "type": "string" },
          "remove_surfaces": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "requires_entries": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "hooks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["phase", "script"],
              "properties": {
                "phase": { "enum": ["before_surfaces", "after_surfaces"] },
                "script": { "type": "string", "minLength": 1 },
                "argv": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "surfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "url"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "url": { "type": "string", "minLength": 1 },
                "track": { "type": "string", "minLength": 1 },
                "interactive": { "type": "boolean" },
                "focus": { "type": "boolean" },
                "frame": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind"],
                  "properties": {
                    "kind": { "enum": ["workbench", "agent_terminal"] }
                  }
                },
                "create_if_missing": { "type": "boolean" },
                "wait_js": { "type": "string" },
                "wait_timeout": { "type": "string" }
              }
            }
          },
          "post_launch": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": { "enum": ["show_eval", "show_post"] },
                "surface": { "type": "string" },
                "js": { "type": "string" },
                "success_match": { "type": "string" },
                "retries": { "type": "integer", "minimum": 1 },
                "retry_delay_ms": { "type": "integer", "minimum": 0 },
                "event": {}
              }
            }
          },
          "verify_surfaces": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
