{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/aos-experience-v1.schema.json",
  "title": "AOS Experience Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "version", "exclusive", "vanilla_fallback", "content_roots", "branding", "menu", "surfaces"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "exclusive": { "const": true },
    "vanilla_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools"],
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "content_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "path": { "type": "string", "minLength": 1 },
          "branch_scoped": { "type": "boolean" }
        }
      }
    },
    "branding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "surface_title_prefix", "theme_ref", "about"],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "surface_title_prefix": { "type": "string", "minLength": 1 },
        "theme_ref": { "type": "string", "minLength": 1 },
        "about": { "type": "string", "minLength": 1 }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preserve_canvas_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "menu": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "kind"],
        "allOf": [
          {
            "if": {
              "properties": { "kind": { "const": "operator_annotation" } },
              "required": ["kind"]
            },
            "then": {
              "required": ["surface"]
            }
          }
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["toggle_surface", "launch_tool", "future_tool", "operator_annotation"] },
          "entry": { "type": "string", "minLength": 1 },
          "tool": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "action_id": { "type": "string", "minLength": 1 },
          "message_type": { "type": "string", "minLength": 1 },
          "mode": { "enum": ["selection_annotation"] },
          "create_pending_annotation": { "type": "boolean" }
        }
      }
    },
    "surfaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["summary"],
        "properties": {
          "summary": { "type": "string", "minLength": 1 },
          "legacy": { "type": "boolean" }
        }
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase", "script"],
        "properties": {
          "phase": { "enum": ["before_activate", "after_activate", "before_deactivate", "after_deactivate"] },
          "script": { "type": "string", "minLength": 1 },
          "argv": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
