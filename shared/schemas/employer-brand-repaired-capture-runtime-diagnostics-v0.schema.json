{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-repaired-capture-runtime-diagnostics-v0.schema.json",
  "title": "Employer Brand Repaired Capture Runtime Diagnostics v0",
  "description": "Read-only diagnostics for a repaired live evidence capture attempt that failed before useful capture evidence was produced. The artifact distinguishes capture invocation/tooling failures from locator failures and content/access blockers, and does not authorize another browser run.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "runtime_invocation",
    "repaired_slots",
    "non_executable_context",
    "invariants",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_repaired_capture_runtime_diagnostics"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-repaired-capture-runtime-diagnostics-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "runtime_repair_required",
        "non_runtime_capture_blockers_detected",
        "no_runtime_failure_detected"
      ]
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "runtime_invocation": {
      "$ref": "#/$defs/runtime_invocation"
    },
    "repaired_slots": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/repaired_slot"
      }
    },
    "non_executable_context": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "$ref": "#/$defs/context_entry"
      }
    },
    "invariants": {
      "$ref": "#/$defs/invariants"
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "source_refs": {
      "type": "object",
      "required": [
        "manifest_id",
        "manifest_path",
        "manifest_schema",
        "repaired_locator_capture_plan_id",
        "repaired_locator_capture_plan_path",
        "repaired_locator_capture_plan_schema",
        "capture_script_path"
      ],
      "properties": {
        "manifest_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "manifest_path": {
          "const": "source-artifacts/live-evidence-element-clip-manifest.json"
        },
        "manifest_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-element-clip-manifest-v0.schema.json"
        },
        "repaired_locator_capture_plan_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "repaired_locator_capture_plan_path": {
          "const": "live-evidence-repaired-locator-capture-plan.json"
        },
        "repaired_locator_capture_plan_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-repaired-locator-capture-plan-v0.schema.json"
        },
        "capture_script_path": {
          "const": "scripts/employer-brand-repaired-live-element-capture.mjs"
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "repaired_executable_slot_count",
        "attempted_repaired_slot_count",
        "accepted_capture_count",
        "failed_slot_count",
        "runtime_capture_invocation_failure_count",
        "locator_failure_count",
        "content_failure_count",
        "linked_in_source_unavailable_count",
        "non_executable_context_count",
        "actual_capture_file_count",
        "clip_output_path_null_count",
        "text_output_path_null_count",
        "full_page_grab_count"
      ],
      "properties": {
        "repaired_executable_slot_count": {
          "const": 4
        },
        "attempted_repaired_slot_count": {
          "const": 4
        },
        "accepted_capture_count": {
          "const": 0
        },
        "failed_slot_count": {
          "const": 4
        },
        "runtime_capture_invocation_failure_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "locator_failure_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "content_failure_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "linked_in_source_unavailable_count": {
          "const": 1
        },
        "non_executable_context_count": {
          "const": 14
        },
        "actual_capture_file_count": {
          "const": 0
        },
        "clip_output_path_null_count": {
          "const": 4
        },
        "text_output_path_null_count": {
          "const": 4
        },
        "full_page_grab_count": {
          "const": 0
        }
      },
      "additionalProperties": false
    },
    "runtime_invocation": {
      "type": "object",
      "required": [
        "capture_script_path",
        "command_surfaces",
        "execution_phases",
        "runner_types",
        "failed_phases",
        "backend_commands",
        "tool_paths",
        "timeout_ms_values",
        "working_directories",
        "environment_assumptions"
      ],
      "properties": {
        "capture_script_path": {
          "const": "scripts/employer-brand-repaired-live-element-capture.mjs"
        },
        "command_surfaces": {
          "$ref": "#/$defs/string_array"
        },
        "execution_phases": {
          "$ref": "#/$defs/string_array"
        },
        "runner_types": {
          "$ref": "#/$defs/string_array"
        },
        "failed_phases": {
          "$ref": "#/$defs/string_array"
        },
        "backend_commands": {
          "$ref": "#/$defs/string_array"
        },
        "tool_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "timeout_ms_values": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "working_directories": {
          "$ref": "#/$defs/string_array"
        },
        "environment_assumptions": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "repaired_slot": {
      "type": "object",
      "required": [
        "slot_id",
        "target_id",
        "work_unit_id",
        "company",
        "source_category",
        "original_url",
        "final_url",
        "reviewed_locator",
        "locator_provenance",
        "status",
        "failure_classification",
        "locator_failure",
        "content_failure",
        "runtime_capture_invocation_failure",
        "blocker_reason",
        "required_next_action",
        "retry_eligibility",
        "clip_path",
        "text_extract_path",
        "text_extract_content",
        "planned_clip_path",
        "planned_text_extract_path",
        "full_page_grab",
        "runtime"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "original_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewed_locator": {
          "type": "object"
        },
        "locator_provenance": {
          "type": "object"
        },
        "status": {
          "const": "failed"
        },
        "failure_classification": {
          "enum": [
            "runtime_capture_invocation_failure",
            "locator_failure",
            "content_or_access_blocker"
          ]
        },
        "locator_failure": {
          "type": "boolean"
        },
        "content_failure": {
          "type": "boolean"
        },
        "runtime_capture_invocation_failure": {
          "type": "boolean"
        },
        "blocker_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required_next_action": {
          "$ref": "#/$defs/non_empty_string"
        },
        "retry_eligibility": {
          "enum": [
            "retry_after_runtime_repair",
            "requires_non_runtime_review"
          ]
        },
        "clip_path": {
          "type": "null"
        },
        "text_extract_path": {
          "type": "null"
        },
        "text_extract_content": {
          "type": "null"
        },
        "planned_clip_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "planned_text_extract_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "full_page_grab": {
          "const": false
        },
        "runtime": {
          "$ref": "#/$defs/runtime_failure"
        }
      },
      "additionalProperties": false
    },
    "runtime_failure": {
      "type": "object",
      "required": [
        "reason",
        "kind",
        "runner_type",
        "command",
        "failed_command_surface",
        "execution_phase",
        "failed_phase",
        "started_phases",
        "completed_phases",
        "phase_timings_ms",
        "phase_timeout_ms",
        "tool_path",
        "timeout_ms",
        "timed_out",
        "exit_status",
        "exit_signal",
        "error_code",
        "stdout_snippet",
        "stderr_snippet",
        "working_directory",
        "retry_recommendation",
        "environment_assumptions"
      ],
      "properties": {
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "enum": [
            "runtime_capture_invocation_failure",
            "locator_failure",
            "content_or_access_blocker",
            "unknown_failure"
          ]
        },
        "runner_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "command": {
          "$ref": "#/$defs/non_empty_string"
        },
        "failed_command_surface": {
          "$ref": "#/$defs/non_empty_string"
        },
        "execution_phase": {
          "$ref": "#/$defs/nullable_string"
        },
        "failed_phase": {
          "$ref": "#/$defs/nullable_string"
        },
        "started_phases": {
          "$ref": "#/$defs/string_array"
        },
        "completed_phases": {
          "$ref": "#/$defs/string_array"
        },
        "phase_timings_ms": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "phase_timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "tool_path": {
          "$ref": "#/$defs/nullable_string"
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "timed_out": {
          "type": "boolean"
        },
        "exit_status": {
          "type": [
            "integer",
            "null"
          ]
        },
        "exit_signal": {
          "$ref": "#/$defs/nullable_string"
        },
        "error_code": {
          "$ref": "#/$defs/nullable_string"
        },
        "stdout_snippet": {
          "$ref": "#/$defs/nullable_string"
        },
        "stderr_snippet": {
          "$ref": "#/$defs/nullable_string"
        },
        "working_directory": {
          "$ref": "#/$defs/nullable_string"
        },
        "retry_recommendation": {
          "$ref": "#/$defs/non_empty_string"
        },
        "environment_assumptions": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "context_entry": {
      "type": "object",
      "required": [
        "slot_id",
        "target_id",
        "work_unit_id",
        "company",
        "source_category",
        "status",
        "blocker_reason",
        "required_next_action",
        "clip_path",
        "text_extract_path",
        "full_page_grab",
        "context_kind"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "company": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_category": {
          "$ref": "#/$defs/non_empty_string"
        },
        "status": {
          "const": "blocked_not_run"
        },
        "blocker_reason": {
          "$ref": "#/$defs/non_empty_string"
        },
        "required_next_action": {
          "$ref": "#/$defs/nullable_string"
        },
        "clip_path": {
          "type": "null"
        },
        "text_extract_path": {
          "type": "null"
        },
        "full_page_grab": {
          "const": false
        },
        "context_kind": {
          "enum": [
            "source_unavailable",
            "non_executable_context"
          ]
        }
      },
      "additionalProperties": false
    },
    "invariants": {
      "type": "object",
      "additionalProperties": {
        "const": true
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "properties": {
        "read_only_diagnostics": {
          "const": true
        },
        "live_capture_attempted": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        }
      },
      "required": [
        "read_only_diagnostics",
        "live_capture_attempted",
        "full_page_grabs_authorized"
      ]
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "diagnostics_path",
        "read_only",
        "derived_from_manifest_path",
        "derived_from_repaired_capture_plan_path",
        "no_capture_assets_produced",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "diagnostics_path": {
          "const": "live-evidence-repaired-capture-runtime-diagnostics.json"
        },
        "read_only": {
          "const": true
        },
        "derived_from_manifest_path": {
          "const": "source-artifacts/live-evidence-element-clip-manifest.json"
        },
        "derived_from_repaired_capture_plan_path": {
          "const": "live-evidence-repaired-locator-capture-plan.json"
        },
        "no_capture_assets_produced": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
