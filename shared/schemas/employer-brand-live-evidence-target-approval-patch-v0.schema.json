{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-target-approval-patch-v0.schema.json",
  "title": "Employer Brand Live Evidence Target Approval Patch v0",
  "description": "Data-only human approval decisions for an Employer Brand Live Evidence Target Review Pack. V0 can approve, reject, keep draft, or edit target planning fields, and it does not authorize browsing, URL checks, locator/codegen execution, screenshots, clip generation, rendering, exports, workflows, or full-page grabs.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "target_plan_ref",
    "review_pack_ref",
    "reviewer",
    "reviewed_at",
    "decisions",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_target_approval_patch"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-target-approval-patch-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "const": "approved"
    },
    "target_plan_ref": {
      "$ref": "#/$defs/target_plan_ref"
    },
    "review_pack_ref": {
      "$ref": "#/$defs/review_pack_ref"
    },
    "reviewer": {
      "$ref": "#/$defs/reviewer"
    },
    "reviewed_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "kilos_relevance": {
      "type": "array",
      "items": {
        "enum": [
          "kinship",
          "impact",
          "lifestyle",
          "opportunity",
          "status"
        ]
      },
      "uniqueItems": true
    },
    "target_plan_ref": {
      "type": "object",
      "required": [
        "target_plan_id",
        "target_plan_path",
        "target_plan_schema",
        "read_only",
        "planning_metadata_only"
      ],
      "properties": {
        "target_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_plan_path": {
          "const": "live-evidence-target-plan.json"
        },
        "target_plan_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-target-plan-v0.schema.json"
        },
        "read_only": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "review_pack_ref": {
      "type": "object",
      "required": [
        "review_pack_id",
        "review_pack_path",
        "review_pack_schema",
        "read_only",
        "planning_metadata_only"
      ],
      "properties": {
        "review_pack_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "review_pack_path": {
          "const": "live-evidence-target-review-pack.json"
        },
        "review_pack_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-target-review-pack-v0.schema.json"
        },
        "read_only": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "reviewer": {
      "type": "object",
      "required": [
        "reviewer_id",
        "reviewer_name",
        "reviewer_role"
      ],
      "properties": {
        "reviewer_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewer_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewer_role": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": [
        "target_id",
        "decision",
        "reviewer_notes",
        "edits"
      ],
      "properties": {
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "decision": {
          "enum": [
            "approve",
            "reject",
            "keep_draft"
          ]
        },
        "reviewer_notes": {
          "$ref": "#/$defs/nullable_string"
        },
        "edits": {
          "$ref": "#/$defs/edits"
        }
      },
      "additionalProperties": false
    },
    "edits": {
      "type": "object",
      "properties": {
        "desired_element": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_element": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_goal": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kilos_relevance": {
          "$ref": "#/$defs/kilos_relevance"
        },
        "expected_clip_count": {
          "type": "integer",
          "minimum": 0
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "notes": {
          "$ref": "#/$defs/nullable_string"
        },
        "review_status": {
          "enum": [
            "draft",
            "approved",
            "rejected",
            "human_review_required"
          ]
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "live_browser_collection",
        "url_reachability_check",
        "locator_codegen",
        "screenshot_capture",
        "clip_generation",
        "report_rendering",
        "html_css_polish",
        "pdf_docx_export",
        "workflow_execution",
        "full_page_grabs"
      ],
      "properties": {
        "live_browser_collection": {
          "const": false
        },
        "url_reachability_check": {
          "const": false
        },
        "locator_codegen": {
          "const": false
        },
        "screenshot_capture": {
          "const": false
        },
        "clip_generation": {
          "const": false
        },
        "report_rendering": {
          "const": false
        },
        "html_css_polish": {
          "const": false
        },
        "pdf_docx_export": {
          "const": false
        },
        "workflow_execution": {
          "const": false
        },
        "full_page_grabs": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "human_decision_layer",
        "planning_metadata_only",
        "read_only",
        "live_evidence_collected",
        "url_reachability_checked",
        "locators_resolved",
        "locator_codegen_executed",
        "screenshots_captured",
        "clips_generated",
        "report_rendered",
        "exports_generated",
        "workflow_executed",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/non_empty_string"
        },
        "human_decision_layer": {
          "const": true
        },
        "planning_metadata_only": {
          "const": true
        },
        "read_only": {
          "const": true
        },
        "live_evidence_collected": {
          "const": false
        },
        "url_reachability_checked": {
          "const": false
        },
        "locators_resolved": {
          "const": false
        },
        "locator_codegen_executed": {
          "const": false
        },
        "screenshots_captured": {
          "const": false
        },
        "clips_generated": {
          "const": false
        },
        "report_rendered": {
          "const": false
        },
        "exports_generated": {
          "const": false
        },
        "workflow_executed": {
          "const": false
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
  }
}
