{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/aos-experience-v0.schema.json",
  "title": "AOS Experience Manifest v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "version", "exclusive", "default_activation", "vanilla_fallback", "content_roots", "status_item", "branding", "menu", "surfaces"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 0 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "exclusive": { "const": true },
    "default_activation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "status_item_first", "primary_entry"],
      "properties": {
        "kind": { "enum": ["status_item"] },
        "status_item_first": { "const": true },
        "primary_entry": { "type": "string", "minLength": 1 }
      }
    },
    "vanilla_fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status_item", "tools"],
      "properties": {
        "status_item": { "type": "boolean" },
        "tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "content_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "path": { "type": "string", "minLength": 1 },
          "branch_scoped": { "type": "boolean" }
        }
      }
    },
    "status_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "label", "icon", "toggle_surface"],
      "properties": {
        "enabled": { "type": "boolean" },
        "label": { "type": "string", "minLength": 1 },
        "icon": { "type": "string", "minLength": 1 },
        "toggle_surface": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "url", "track"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "minLength": 1 },
            "track": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "branding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "surface_title_prefix", "theme_ref", "about"],
      "properties": {
        "display_name": { "type": "string", "minLength": 1 },
        "surface_title_prefix": { "type": "string", "minLength": 1 },
        "theme_ref": { "type": "string", "minLength": 1 },
        "about": { "type": "string", "minLength": 1 }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preserve_canvas_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "menu": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "kind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["toggle_surface", "launch_tool", "future_tool"] },
          "entry": { "type": "string", "minLength": 1 },
          "tool": { "type": "string", "minLength": 1 }
        }
      }
    },
    "surfaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["summary"],
        "properties": {
          "summary": { "type": "string", "minLength": 1 },
          "legacy": { "type": "boolean" }
        }
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase", "script"],
        "properties": {
          "phase": { "enum": ["before_activate", "after_activate", "before_deactivate", "after_deactivate"] },
          "script": { "type": "string", "minLength": 1 },
          "argv": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
