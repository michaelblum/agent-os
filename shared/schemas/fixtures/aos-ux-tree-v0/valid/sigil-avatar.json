      "id": "sigil-main",
      "kind": "source",
      "ref": "apps/sigil/renderer/live-modules/main.js"
    },
    {
      "id": "sigil-radial-menu",
      "kind": "resource",
      "ref": "apps/sigil/renderer/radial-menu/sigil-radial-menu.json"
    }
  ],
  "modes": [
    { "id": "global", "label": "Global" },
    { "id": "idle", "label": "Idle" },
    { "id": "goto", "label": "GOTO" },
    { "id": "press", "label": "Press" },
    { "id": "radial", "label": "Radial" },
    { "id": "selection_mode", "label": "Selection Mode" }
  ],
  "nodes": [
