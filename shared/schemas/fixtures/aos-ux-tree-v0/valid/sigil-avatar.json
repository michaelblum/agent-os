      "id": "sigil.avatar",
      "label": "Sigil Avatar",
      "role": "root",
      "node_type": "avatar",
      "hit_source": { "kind": "sigil.avatar.hit_target" },
      "settings_ref": "settings.avatar",
      "children": [
        "sigil.avatar.body",
        "sigil.avatar.radial_menu",
        "sigil.avatar.context_menu",
        "sigil.avatar.selection_mode",
        "sigil.avatar.annotation_reticle",
        "sigil.avatar.annotation_camera"
      ],
      "resource_refs": [],
      "source_metadata": { "source": "main.js" }
    },
    {
      "id": "sigil.avatar.body",
      "parent_id": "sigil.avatar",
      "label": "Avatar Body",
      "role": "button",
      "node_type": "hit_target",
      "hit_source": { "kind": "input_region", "id": "sigil-avatar-main-input-region" },
      "resource_refs": [],
      "source_metadata": {}
    },
    {
      "id": "sigil.avatar.radial_menu",
      "parent_id": "sigil.avatar",
