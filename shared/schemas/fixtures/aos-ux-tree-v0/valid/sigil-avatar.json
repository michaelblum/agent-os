  "commands": [
    {
      "id": "sigil.context_menu.open",
      "label": "Open context menu",
      "description": "Open the existing Sigil context menu through current runtime code.",
      "handler_ref": "sigil.context_menu.open",
      "parameters": {},
      "safety": { "execution": "allowlisted", "side_effect": "existing_runtime_path" },
      "source_metadata": {}
    },
    {
      "id": "sigil.radial.release_item",
      "label": "Release radial item",
      "description": "Invoke the current radial item release path.",
      "handler_ref": "sigil.radial.release_item",
      "parameters": {},
      "safety": { "execution": "allowlisted", "side_effect": "existing_runtime_path" },
      "source_metadata": {}
    },
    {
      "id": "sigil.selection_mode.enter",
      "label": "Enter Selection Mode",
      "description": "Enter Selection Mode through the existing double-click path.",
      "handler_ref": "sigil.selection_mode.enter",
      "parameters": {},
      "safety": { "execution": "allowlisted", "side_effect": "existing_runtime_path" },
      "source_metadata": {}
    },
    {
      "id": "sigil.selection_mode.cancel",
      "label": "Cancel Selection Mode",
      "description": "Cancel active Selection Mode.",
      "handler_ref": "sigil.selection_mode.cancel",
      "parameters": {},
      "safety": { "execution": "allowlisted", "side_effect": "existing_runtime_path" },
      "source_metadata": {}
    }
  ],
  "bindings": [
    {
      "id": "sigil.avatar.context_menu.right_click",
      "node_id": "sigil.avatar.body",
      "mode": "idle",
      "gesture": "pointer.right.click",
      "command_id": "sigil.context_menu.open",
      "enabled": true,
      "priority": 100,
      "consume_policy": "route",
      "parameters": {},
      "source_metadata": {}
    },
    {
      "id": "sigil.avatar.selection_mode.double_click",
      "node_id": "sigil.avatar.body",
      "mode": "goto",
      "gesture": "pointer.left.double_click",
      "command_id": "sigil.selection_mode.enter",
      "enabled": true,
      "priority": 100,
      "consume_policy": "consume",
      "parameters": {},
      "source_metadata": {}
    },
    {
      "id": "sigil.selection_mode.escape",
      "node_id": "sigil.avatar.selection_mode",
      "mode": "selection_mode",
      "gesture": "key.escape",
      "command_id": "sigil.selection_mode.cancel",
      "enabled": true,
      "priority": 100,
      "consume_policy": "consume",
      "parameters": {},
      "source_metadata": {}
    },
    {
      "id": "sigil.radial.item.release.context-menu",
      "node_id": "sigil.avatar.radial_menu.item.context-menu",
      "mode": "radial",
      "gesture": "pointer.left.release",
      "command_id": "sigil.radial.release_item",
      "enabled": true,
      "priority": 100,
      "consume_policy": "consume",
      "parameters": { "item_id": "context-menu" },
      "source_metadata": {}
    }
  ],
  "settings": {
    "avatar": { "hit_radius": 40 },
    "radial": {
      "geometry": { "menuRadius": 2.65 },
      "items": {
        "context-menu": { "action": "contextMenu" }
      }
    },
    "visual_overlays": {},
    "overrides": {}
  },
  "metadata": {
    "runtime_state": "read_only_shadow"
  }
