      "resource_refs": [],
      "source_metadata": {}
    },
    {
      "id": "sigil.avatar.selection_mode.cursor_overlay",
      "parent_id": "sigil.avatar.selection_mode",
      "label": "Selection Cursor Overlay",
      "role": "overlay",
      "node_type": "visual_overlay",
      "resource_refs": [],
      "source_metadata": {}
    },
    {
      "id": "sigil.avatar.selection_mode.ancestor_badges",
