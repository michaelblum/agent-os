{
  "type": "aos.playbook_step",
  "schema_version": "2026-05-playbook-step-v0",
  "id": "playbook-step:ungated-replay",
  "label": "Invalid step with ungated replay",
  "playbook_ref": "playbook:invalid",
  "version": "v0",
  "target_dialect": "browser",
  "intent": {
    "summary": "This fixture tries to allow replay without a workflow gate."
  },
  "workflow_gates": {
    "mode": "report_only",
    "replay_requires_workflow_gate": false,
    "repair_requires_workflow_gate": true,
    "gate_refs": []
  },
  "preconditions": [
    {
      "id": "precondition:ready",
      "kind": "browser_xray_text",
      "description": "A browser state exists.",
      "target": "browser:invalid/status",
      "check": {
        "kind": "semantic_target_present",
        "ref": "status"
      },
      "repair_policy": {
        "mode": "manual_review"
      }
    }
  ],
  "target_resolution": {
    "id": "target-resolution:invalid-button",
    "strategy": "semantic_ref",
    "dialect": "browser",
    "target": "browser:invalid",
    "target_with_ref": "browser:invalid/button",
    "ref": "button"
  },
  "action": {
    "verb": "click",
    "target": "browser:invalid/button",
    "command_template": "./aos do click {{target_with_ref}}"
  },
  "postconditions": [
    {
      "id": "postcondition:changed",
      "kind": "browser_xray_text",
      "description": "The browser state changed.",
      "target": "browser:invalid/status",
      "check": {
        "kind": "semantic_target_value_contains",
        "ref": "status",
        "expected": "Changed"
      },
      "repair_policy": {
        "mode": "manual_review"
      }
    }
  ],
  "repair_hints": [
    {
      "kind": "manual_review",
      "note": "Review the invalid fixture."
    }
  ],
  "claim_promotions": [
    {
      "id": "claim-promotion:changed",
      "postcondition_ref": "postcondition:changed",
      "claim_text": "The browser state changed.",
      "scope": "run",
      "acceptance": "The changed postcondition passes."
    }
  ]
}
