{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michaelblum/agent-os/shared/schemas/employer-brand-live-evidence-url-reachability-check-v0.schema.json",
  "title": "Employer Brand Live Evidence URL Reachability Check v0",
  "description": "Supervised, read-only URL reachability preflight for approved live evidence targets. V0 is dry-run/not_checked unless an explicit bounded opener is added; it does not resolve locators, run codegen, take screenshots, capture clips, render reports, export, run workflows, crawl, bypass blockers, identify elements, or perform full-page grabs.",
  "type": "object",
  "required": [
    "type",
    "schema_version",
    "id",
    "label",
    "status",
    "source_refs",
    "summary",
    "results",
    "controls",
    "provenance"
  ],
  "properties": {
    "type": {
      "const": "aos.employer_brand_live_evidence_url_reachability_check"
    },
    "schema_version": {
      "const": "2026-05-employer-brand-live-evidence-url-reachability-check-v0"
    },
    "id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "label": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status": {
      "enum": [
        "dry_run_not_checked",
        "checked",
        "checked_with_blockers"
      ]
    },
    "source_refs": {
      "$ref": "#/$defs/source_refs"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "controls": {
      "$ref": "#/$defs/controls"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "not_checked",
        "reachable",
        "blocked",
        "redirected",
        "login_required",
        "paywall",
        "captcha",
        "consent_required",
        "network_error",
        "safety_gate_blocked"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "source_refs": {
      "type": "object",
      "required": [
        "supervised_locator_plan_id",
        "supervised_locator_plan_path",
        "supervised_locator_plan_schema",
        "locator_readiness_id",
        "locator_readiness_path",
        "reviewed_target_plan_id",
        "reviewed_target_plan_path",
        "data_bundle_id",
        "data_bundle_path",
        "url_open_run_id",
        "url_open_run_path",
        "url_open_run_schema"
      ],
      "properties": {
        "supervised_locator_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supervised_locator_plan_path": {
          "const": "live-evidence-supervised-locator-plan.json"
        },
        "supervised_locator_plan_schema": {
          "const": "shared/schemas/employer-brand-live-evidence-supervised-locator-plan-v0.schema.json"
        },
        "locator_readiness_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "locator_readiness_path": {
          "const": "live-evidence-locator-readiness.json"
        },
        "reviewed_target_plan_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewed_target_plan_path": {
          "enum": [
            "live-evidence-target-plan.reviewed.json",
            "live-evidence-reviewed-target-plan.json"
          ]
        },
        "data_bundle_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "data_bundle_path": {
          "enum": [
            "data-bundle.json",
            null
          ]
        },
        "url_open_run_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "url_open_run_path": {
          "enum": [
            "live-evidence-url-open-run.json",
            null
          ]
        },
        "url_open_run_schema": {
          "enum": [
            "shared/schemas/employer-brand-live-evidence-url-open-run-v0.schema.json",
            null
          ]
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "supervised_locator_work_unit_count",
        "executable_target_count",
        "non_executed_blocked_target_count",
        "checked_count",
        "reachable_count",
        "blocked_count",
        "redirected_count",
        "same_domain_confirmed_count",
        "same_domain_unknown_count",
        "not_checked_count",
        "login_required_count",
        "paywall_count",
        "captcha_count",
        "consent_required_count",
        "network_error_count",
        "safety_gate_blocked_count"
      ],
      "properties": {
        "supervised_locator_work_unit_count": {
          "type": "integer",
          "minimum": 1
        },
        "executable_target_count": {
          "type": "integer",
          "minimum": 0
        },
        "non_executed_blocked_target_count": {
          "type": "integer",
          "minimum": 0
        },
        "checked_count": {
          "type": "integer",
          "minimum": 0
        },
        "reachable_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_count": {
          "type": "integer",
          "minimum": 0
        },
        "redirected_count": {
          "type": "integer",
          "minimum": 0
        },
        "same_domain_confirmed_count": {
          "type": "integer",
          "minimum": 0
        },
        "same_domain_unknown_count": {
          "type": "integer",
          "minimum": 0
        },
        "not_checked_count": {
          "type": "integer",
          "minimum": 0
        },
        "login_required_count": {
          "type": "integer",
          "minimum": 0
        },
        "paywall_count": {
          "type": "integer",
          "minimum": 0
        },
        "captcha_count": {
          "type": "integer",
          "minimum": 0
        },
        "consent_required_count": {
          "type": "integer",
          "minimum": 0
        },
        "network_error_count": {
          "type": "integer",
          "minimum": 0
        },
        "safety_gate_blocked_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": [
        "result_id",
        "work_unit_id",
        "target_id",
        "executable",
        "executed",
        "non_executed",
        "status",
        "url",
        "final_url",
        "same_domain_gate",
        "http",
        "blocker_reason",
        "checked_at",
        "operator_notes",
        "review_status",
        "safety_gates",
        "provenance"
      ],
      "properties": {
        "result_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "executable": {
          "type": "boolean"
        },
        "executed": {
          "type": "boolean"
        },
        "non_executed": {
          "type": "boolean"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "url": {
          "$ref": "#/$defs/non_empty_string"
        },
        "final_url": {
          "$ref": "#/$defs/nullable_string"
        },
        "same_domain_gate": {
          "$ref": "#/$defs/same_domain_gate"
        },
        "http": {
          "$ref": "#/$defs/http"
        },
        "blocker_reason": {
          "$ref": "#/$defs/nullable_string"
        },
        "checked_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "operator_notes": {
          "$ref": "#/$defs/nullable_string"
        },
        "review_status": {
          "$ref": "#/$defs/non_empty_string"
        },
        "safety_gates": {
          "$ref": "#/$defs/string_array"
        },
        "provenance": {
          "$ref": "#/$defs/result_provenance"
        }
      },
      "additionalProperties": false
    },
    "same_domain_gate": {
      "type": "object",
      "required": [
        "requested_origin",
        "requested_hostname",
        "expected_origin",
        "same_domain_required",
        "same_domain"
      ],
      "properties": {
        "requested_origin": {
          "$ref": "#/$defs/nullable_string"
        },
        "requested_hostname": {
          "$ref": "#/$defs/nullable_string"
        },
        "expected_origin": {
          "$ref": "#/$defs/nullable_string"
        },
        "same_domain_required": {
          "const": true
        },
        "same_domain": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "http": {
      "type": "object",
      "required": [
        "status_code",
        "status_text",
        "method",
        "headers_observed"
      ],
      "properties": {
        "status_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "status_text": {
          "$ref": "#/$defs/nullable_string"
        },
        "method": {
          "$ref": "#/$defs/nullable_string"
        },
        "headers_observed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "result_provenance": {
      "type": "object",
      "required": [
        "source_supervised_locator_plan_target_id",
        "source_supervised_locator_plan_work_unit_id",
        "source_index",
        "source_url_open_result_id",
        "planning_check_only",
        "read_only"
      ],
      "properties": {
        "source_supervised_locator_plan_target_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_supervised_locator_plan_work_unit_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_index": {
          "type": "integer",
          "minimum": 0
        },
        "source_url_open_result_id": {
          "$ref": "#/$defs/nullable_string"
        },
        "planning_check_only": {
          "type": "boolean"
        },
        "read_only": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "required": [
        "dry_run_only",
        "human_approval_required",
        "url_opening_performed",
        "autonomous_crawl_authorized",
        "autonomous_browsing_authorized",
        "locator_resolution_authorized",
        "locator_codegen_executed",
        "element_identification_authorized",
        "screenshot_capture_authorized",
        "full_page_grabs_authorized",
        "clip_generation_authorized",
        "report_renderer_authorized",
        "export_execution_authorized",
        "workflow_engine_authorized",
        "login_bypass_authorized",
        "paywall_bypass_authorized",
        "captcha_bypass_authorized",
        "consent_bypass_authorized"
      ],
      "properties": {
        "dry_run_only": {
          "type": "boolean"
        },
        "human_approval_required": {
          "const": true
        },
        "url_opening_performed": {
          "type": "boolean"
        },
        "autonomous_crawl_authorized": {
          "const": false
        },
        "autonomous_browsing_authorized": {
          "const": false
        },
        "locator_resolution_authorized": {
          "const": false
        },
        "locator_codegen_executed": {
          "const": false
        },
        "element_identification_authorized": {
          "const": false
        },
        "screenshot_capture_authorized": {
          "const": false
        },
        "full_page_grabs_authorized": {
          "const": false
        },
        "clip_generation_authorized": {
          "const": false
        },
        "report_renderer_authorized": {
          "const": false
        },
        "export_execution_authorized": {
          "const": false
        },
        "workflow_engine_authorized": {
          "const": false
        },
        "login_bypass_authorized": {
          "const": false
        },
        "paywall_bypass_authorized": {
          "const": false
        },
        "captcha_bypass_authorized": {
          "const": false
        },
        "consent_bypass_authorized": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "created_at",
        "supervised_locator_plan_is_input_source",
        "executable_only_for_approved_targets",
        "blocked_draft_targets_preserved_as_non_executed",
        "rejected_targets_excluded_by_input_plan",
        "final_url_only_when_safely_known",
        "http_metadata_only_when_available_without_escalation",
        "dry_run_not_checked_fixture",
        "planning_check_only",
        "url_open_run_is_input_source",
        "url_open_run_path",
        "url_open_run_schema",
        "read_only",
        "non_goals"
      ],
      "properties": {
        "created_at": {
          "$ref": "#/$defs/nullable_string"
        },
        "supervised_locator_plan_is_input_source": {
          "const": true
        },
        "executable_only_for_approved_targets": {
          "const": true
        },
        "blocked_draft_targets_preserved_as_non_executed": {
          "const": true
        },
        "rejected_targets_excluded_by_input_plan": {
          "const": true
        },
        "final_url_only_when_safely_known": {
          "const": true
        },
        "http_metadata_only_when_available_without_escalation": {
          "const": true
        },
        "dry_run_not_checked_fixture": {
          "type": "boolean"
        },
        "planning_check_only": {
          "type": "boolean"
        },
        "url_open_run_is_input_source": {
          "type": "boolean"
        },
        "url_open_run_path": {
          "enum": [
            "live-evidence-url-open-run.json",
            null
          ]
        },
        "url_open_run_schema": {
          "enum": [
            "shared/schemas/employer-brand-live-evidence-url-open-run-v0.schema.json",
            null
          ]
        },
        "read_only": {
          "const": true
        },
        "non_goals": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    }
